<UserControl x:Class="StudentReminderApp.Views.Main.ThemeToggleButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="60" Height="30" Background="Transparent">
    
    <Viewbox Stretch="Uniform">
        <ToggleButton x:Name="ThemeSwitch" Width="180" Height="90" Click="ThemeSwitch_Click" Cursor="Hand">
            <ToggleButton.Template>
                <ControlTemplate TargetType="ToggleButton">
                    <Grid>
                        <!-- Background Slider -->
                        <Border CornerRadius="45">
                            <Border.Background>
                                <SolidColorBrush x:Name="SliderBg" Color="#4da0ff" />
                            </Border.Background>
                        </Border>
                        
                        <!-- Stars -->
                        <Ellipse x:Name="Star1" Width="4" Height="4" Fill="White" Opacity="0" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="40,20,0,0"/>
                        <Ellipse x:Name="Star2" Width="6" Height="6" Fill="White" Opacity="0" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="70,35,0,0"/>
                        <Ellipse x:Name="Star3" Width="4" Height="4" Fill="White" Opacity="0" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="110,15,0,0"/>

                        <!-- Thumb -->
                        <Grid x:Name="Thumb" Width="74" Height="74" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,0,0,0">
                            <Ellipse>
                                <Ellipse.Fill>
                                    <SolidColorBrush x:Name="ThumbColor" Color="#ffd95c" />
                                </Ellipse.Fill>
                                <Ellipse.Effect>
                                    <DropShadowEffect x:Name="ThumbShadow" Color="#ffdc00" BlurRadius="20" ShadowDepth="0" Opacity="0.7"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <!-- Moon Craters -->
                            <Ellipse x:Name="Crater1" Width="14" Height="14" Fill="#c8c8c8" Opacity="0" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="18,18,0,0"/>
                            <Ellipse x:Name="Crater2" Width="10" Height="10" Fill="#c8c8c8" Opacity="0" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="45,42,0,0"/>
                        </Grid>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ThicknessAnimation Storyboard.TargetName="Thumb" Storyboard.TargetProperty="Margin" To="98,0,0,0" Duration="0:0:0.5">
                                            <ThicknessAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </ThicknessAnimation.EasingFunction>
                                        </ThicknessAnimation>
                                        <ColorAnimation Storyboard.TargetName="SliderBg" Storyboard.TargetProperty="Color" To="#23395d" Duration="0:0:0.5"/>
                                        <ColorAnimation Storyboard.TargetName="ThumbColor" Storyboard.TargetProperty="Color" To="#f2f2f2" Duration="0:0:0.5"/>
                                        <DoubleAnimation Storyboard.TargetName="ThumbShadow" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.5"/>
                                        
                                        <DoubleAnimation Storyboard.TargetName="Star1" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.5"/>
                                        <DoubleAnimation Storyboard.TargetName="Star2" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.5"/>
                                        <DoubleAnimation Storyboard.TargetName="Star3" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.5"/>
                                        <DoubleAnimation Storyboard.TargetName="Crater1" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.5"/>
                                        <DoubleAnimation Storyboard.TargetName="Crater2" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.5"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ThicknessAnimation Storyboard.TargetName="Thumb" Storyboard.TargetProperty="Margin" To="8,0,0,0" Duration="0:0:0.5">
                                            <ThicknessAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </ThicknessAnimation.EasingFunction>
                                        </ThicknessAnimation>
                                        <ColorAnimation Storyboard.TargetName="SliderBg" Storyboard.TargetProperty="Color" To="#4da0ff" Duration="0:0:0.5"/>
                                        <ColorAnimation Storyboard.TargetName="ThumbColor" Storyboard.TargetProperty="Color" To="#ffd95c" Duration="0:0:0.5"/>
                                        <DoubleAnimation Storyboard.TargetName="ThumbShadow" Storyboard.TargetProperty="Opacity" To="0.7" Duration="0:0:0.5"/>
                                        
                                        <DoubleAnimation Storyboard.TargetName="Star1" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.5"/>
                                        <DoubleAnimation Storyboard.TargetName="Star2" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.5"/>
                                        <DoubleAnimation Storyboard.TargetName="Star3" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.5"/>
                                        <DoubleAnimation Storyboard.TargetName="Crater1" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.5"/>
                                        <DoubleAnimation Storyboard.TargetName="Crater2" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.5"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </ToggleButton.Template>
        </ToggleButton>
    </Viewbox>
</UserControl>
