<Window x:Class="StudentReminderApp.Views.Main.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đang tải..." Height="450" Width="800"
        WindowStyle="None" Background="{DynamicResource SurfaceBrush}" WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded" ResizeMode="NoResize" AllowsTransparency="False" Opacity="0">

    <!-- Hiệu ứng Fade In mượt mà -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.8" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <!-- Logo dạng Text hiện đại -->
            <Border Width="80" Height="80" CornerRadius="20" HorizontalAlignment="Center" Margin="0,0,0,20">
                <Border.Background>
                    <ImageBrush ImageSource="/Resources/Images/logo.jpg" Stretch="UniformToFill"/>
                </Border.Background>
            </Border>
            <TextBlock Text="STUDENT REMINDER" FontSize="36" FontWeight="Black" Foreground="#FF000000" HorizontalAlignment="Center"/>
            <TextBlock Text="Đang khởi động hệ thống..." FontSize="15" Foreground="#FF000000" Opacity="0.8" HorizontalAlignment="Center" Margin="0,10,0,40"/>
            
            <!-- Thanh Loading (ProgressBar) -->
            <ProgressBar x:Name="LoadingProgress" Width="250" Height="6" IsIndeterminate="True" Foreground="#FF000000" Background="#00FFFFFF" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>