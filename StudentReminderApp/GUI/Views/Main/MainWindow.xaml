<Window x:Class="StudentReminderApp.Views.Main.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:StudentReminderApp.Views.Main"
        Title="Student Reminder &amp; Advisor"
        Height="720" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgBrush}">

    <Grid>
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="0.85" ScaleY="0.85" />
        </Grid.LayoutTransform>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Width="72" Background="{DynamicResource TextPrimaryBrush}" CornerRadius="36" Margin="16,16,0,16" Padding="0,32">
            <DockPanel>
                <!-- TOP GROUP (Avatar + Main Nav) -->
                <StackPanel DockPanel.Dock="Top" HorizontalAlignment="Center">
                    <!-- Logo -->
                    <Border Width="52" Height="52" CornerRadius="26" BorderBrush="#334155" BorderThickness="1" Margin="0,0,0,32">
                        <Border.Background>
                            <ImageBrush x:Name="AvatarBrush" ImageSource="/GUI/Resources/Images/logo.jpg" Stretch="UniformToFill"/>
                        </Border.Background>
                    </Border>
                    <!-- Ẩn text nhưng vẫn giữ x:Name để không lỗi code-behind -->
                    <TextBlock x:Name="TxtUserName" Visibility="Collapsed"/>
                    
                    <!-- Main Navigation Buttons -->
                    <Button x:Name="BtnDashboard" Tag="Dashboard" Click="NavBtn_Click"
                            Style="{StaticResource NavBtnActive}" ToolTip="Tổng quan">
                        <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="20"/>
                    </Button>
                    <Button x:Name="BtnCalendar" Tag="Calendar" Click="NavBtn_Click"
                            Style="{StaticResource NavBtn}" ToolTip="Lịch học">
                        <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="20"/>
                    </Button>
                    <Button x:Name="BtnCourse" Tag="Course" Click="NavBtn_Click"
                            Style="{StaticResource NavBtn}" ToolTip="Học phần">
                        <TextBlock Text="&#xE82D;" FontFamily="Segoe MDL2 Assets" FontSize="20"/>
                    </Button>
                    <Button x:Name="BtnAdvisor" Tag="Advisor" Click="NavBtn_Click"
                            Style="{StaticResource NavBtn}" ToolTip="Tư vấn ĐKHP">
                        <TextBlock Text="&#xEA80;" FontFamily="Segoe MDL2 Assets" FontSize="20"/>
                    </Button>
                    <Button x:Name="BtnForum" Tag="Forum" Click="NavBtn_Click"
                            Style="{StaticResource NavBtn}" ToolTip="Diễn đàn">
                        <TextBlock Text="&#xE8F2;" FontFamily="Segoe MDL2 Assets" FontSize="20"/>
                    </Button>
                </StackPanel>

                <!-- BOTTOM GROUP (Profile + Management + Logout) -->
                <StackPanel DockPanel.Dock="Bottom" HorizontalAlignment="Center">
                    <Button x:Name="BtnProfile" Tag="Profile" Click="NavBtn_Click"
                            Style="{StaticResource NavBtn}" ToolTip="Hồ sơ cá nhân">
                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="20"/>
                    </Button>
                    <Button x:Name="BtnManagement" Tag="Management" Click="NavBtn_Click"
                            Style="{StaticResource NavBtn}" ToolTip="Quản lý người dùng" Visibility="Collapsed">
                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="20"/>
                    </Button>
                    
                    <local:ThemeToggleButton Margin="0,16,0,0"/>

                    <Button Click="BtnLogout_Click"
                            Margin="0,16,0,0" HorizontalAlignment="Center"
                            Style="{StaticResource NavBtnDanger}" ToolTip="Đăng xuất">
                        <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" FontSize="20"/>
                    </Button>
                </StackPanel>
                
                <!-- Center Empty Space -->
                <Grid />
            </DockPanel>
        </Border>

        <!-- CONTENT FRAME -->
        <Frame x:Name="ContentFrame"
               Grid.Column="1"
               NavigationUIVisibility="Hidden"
               Background="{DynamicResource BgBrush}"/>
    </Grid>
</Window>