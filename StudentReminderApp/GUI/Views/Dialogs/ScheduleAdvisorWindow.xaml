<Window x:Class="StudentReminderApp.Views.Dialogs.ScheduleAdvisorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tư vấn Đăng ký Học phần" Height="650" Width="920" Background="{DynamicResource SurfaceBrush}" WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="0.85" ScaleY="0.85"/>
        </Grid.LayoutTransform>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,16,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="6" Opacity="0.05" ShadowDepth="4" Direction="270"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <Border Background="{DynamicResource BgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,16" CornerRadius="12,12,0,0">
                    <TextBlock Text="CÁC MÔN ĐÃ CHỌN" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}"/>
                </Border>
                
                <ListBox x:Name="CourseListBox" Grid.Row="1" BorderThickness="0" Background="Transparent" Padding="8" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="{DynamicResource BgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12,10" Margin="0,0,0,8">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE73A;" Foreground="#10B981" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding CourseName}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
                
                <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="16" CornerRadius="0,0,12,12">
                    <Button Content="Áp dụng TKB này" Height="48" Foreground="{DynamicResource SurfaceBrush}" FontWeight="SemiBold" FontSize="15" BorderThickness="0" Cursor="Hand" Click="ApplySchedule_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="24" Background="{DynamicResource TextPrimaryBrush}">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="6" Opacity="0.1" ShadowDepth="4" Direction="270"/>
                                    </Border.Effect>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74E;" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#334155"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Border>
            </Grid>
        </Border>
        
        <!-- Main Content -->
        <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="6" Opacity="0.05" ShadowDepth="4" Direction="270"/>
            </Border.Effect>
            
            <TabControl x:Name="ScheduleTabs" Background="Transparent" BorderThickness="0">
                <TabControl.ItemContainerStyle>
                    <Style TargetType="TabItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="Bd" Background="{DynamicResource BgBrush}" BorderBrush="Transparent" BorderThickness="0,0,0,3" Padding="16,12" Cursor="Hand">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock x:Name="TabText" Text="{Binding OptionId}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,10,0"/>
                                            <Border x:Name="Badge" Background="{DynamicResource BorderBrush}" CornerRadius="20" Padding="8,4">
                                                <TextBlock x:Name="BadgeText" Text="{Binding Score, StringFormat='Điểm: {0}'}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource TextPrimaryBrush}"/>
                                            <Setter TargetName="TabText" Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                            <Setter TargetName="Badge" Property="Background" Value="{DynamicResource TextPrimaryBrush}"/>
                                            <Setter TargetName="BadgeText" Property="Foreground" Value="{DynamicResource SurfaceBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="TabText" Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.ItemContainerStyle>
                
                <TabControl.ContentTemplate>
                    <DataTemplate>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding GridCells}" Padding="16">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="11" Columns="8"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,1">
                                            <Border Background="{Binding Background}" BorderBrush="{Binding BorderBrush}" BorderThickness="{Binding BorderThickness}" Padding="2">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding TopText}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Text}" Foreground="{Binding Foreground}" TextWrapping="Wrap" TextAlignment="Center" FontSize="11" FontWeight="Bold" Margin="0,2,0,2"/>
                                                    <TextBlock Text="{Binding BottomText}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DataTemplate>
                </TabControl.ContentTemplate>
            </TabControl>
        </Border>
    </Grid>
</Window>