<Page x:Class="StudentReminderApp.Views.Pages.CalendarPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Lịch" Background="White">

    <Page.Resources>
        <Style x:Key="ViewToggleStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" CornerRadius="6" Background="Transparent" Padding="12,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E8F0FE"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#1A73E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== STYLE MỚI CHO MINI CALENDAR (GOOGLE CALENDAR STYLE) ===== -->
        <Style x:Key="GoogleCalendarDayButtonStyle" TargetType="CalendarDayButton">
            <Setter Property="MinWidth" Value="28" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CalendarDayButton">
                        <Grid>
                            <Border x:Name="BgBorder" CornerRadius="14" Background="Transparent" Width="28" Height="28"/>
                            <ContentPresenter x:Name="NormalText" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="#D2E3FC"/>
                                <Setter Property="Foreground" Value="#1967D2"/>
                            </Trigger>
                            <Trigger Property="IsToday" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="#1A73E8"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsToday" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="BgBorder" Property="Background" Value="#1A73E8"/>
                                <Setter Property="Foreground" Value="White"/>
                            </MultiTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="{DynamicResource BgBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsToday" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="BgBorder" Property="Background" Value="#AECAFA"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsToday" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="BgBorder" Property="Background" Value="#1B66C9"/>
                                <Setter Property="Foreground" Value="White"/>
                            </MultiTrigger>
                            <Trigger Property="IsInactive" Value="True">
                                <Setter Property="Foreground" Value="#BDBDBD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GoogleCalendarButtonStyle" TargetType="CalendarButton">
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CalendarButton">
                        <Grid>
                            <Border x:Name="BgBorder" CornerRadius="4" Background="Transparent" Margin="2"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5,1,5,1"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="{DynamicResource BgBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GoogleCalendarItemStyle" TargetType="CalendarItem">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CalendarItem">
                        <ControlTemplate.Resources>
                            <DataTemplate x:Key="{x:Static CalendarItem.DayTitleTemplateResourceKey}">
                                <TextBlock Text="{Binding}" FontWeight="Medium" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,6,0,6"/>
                            </DataTemplate>
                        </ControlTemplate.Resources>
                        <Grid x:Name="PART_Root">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <Grid Grid.Row="0" Margin="4,4,4,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="PART_HeaderButton" Grid.Column="0" FontWeight="Medium" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Left" Background="Transparent" BorderThickness="0" Margin="4,0,0,0" FocusVisualStyle="{x:Null}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="4" Padding="6,4">
                                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="{DynamicResource BgBrush}"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button x:Name="PART_PreviousButton" Grid.Column="1" FontFamily="Segoe MDL2 Assets" Content="&#xE76B;" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Background="Transparent" BorderThickness="0" Width="26" Height="26" Margin="0,0,4,0" Cursor="Hand" FocusVisualStyle="{x:Null}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="13">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="{DynamicResource BgBrush}"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button x:Name="PART_NextButton" Grid.Column="2" FontFamily="Segoe MDL2 Assets" Content="&#xE76C;" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Background="Transparent" BorderThickness="0" Width="26" Height="26" Cursor="Hand" FocusVisualStyle="{x:Null}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="13">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="{DynamicResource BgBrush}"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                            
                            <Grid Grid.Row="1" x:Name="PART_MonthView" Visibility="Visible" Margin="6,0,6,6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                            </Grid>
                            
                            <Grid Grid.Row="1" x:Name="PART_YearView" Visibility="Hidden" Margin="6,0,6,6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                            </Grid>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding DisplayMode, RelativeSource={RelativeSource AncestorType=Calendar}}" Value="Year">
                                <Setter TargetName="PART_MonthView" Property="Visibility" Value="Hidden"/>
                                <Setter TargetName="PART_YearView" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DisplayMode, RelativeSource={RelativeSource AncestorType=Calendar}}" Value="Decade">
                                <Setter TargetName="PART_MonthView" Property="Visibility" Value="Hidden"/>
                                <Setter TargetName="PART_YearView" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GoogleCalendarStyle" TargetType="Calendar">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="CalendarDayButtonStyle" Value="{StaticResource GoogleCalendarDayButtonStyle}"/>
            <Setter Property="CalendarButtonStyle" Value="{StaticResource GoogleCalendarButtonStyle}"/>
            <Setter Property="CalendarItemStyle" Value="{StaticResource GoogleCalendarItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Calendar">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <CalendarItem x:Name="PART_CalendarItem" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GoogleYearViewCalendarItemStyle" TargetType="CalendarItem">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CalendarItem">
                        <ControlTemplate.Resources>
                            <DataTemplate x:Key="{x:Static CalendarItem.DayTitleTemplateResourceKey}">
                                <TextBlock Text="{Binding}" FontWeight="Medium" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,6,0,6"/>
                            </DataTemplate>
                        </ControlTemplate.Resources>
                        <Grid x:Name="PART_Root">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <Grid Grid.Row="0" Margin="4,4,4,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="PART_HeaderButton" Grid.Column="0" FontWeight="Medium" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Left" Background="Transparent" BorderThickness="0" Margin="4,0,0,0" FocusVisualStyle="{x:Null}" IsHitTestVisible="False">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="4" Padding="6,4">
                                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button x:Name="PART_PreviousButton" Grid.Column="1" Width="0" Height="0" IsHitTestVisible="False" Focusable="False">
                                    <Button.Template><ControlTemplate TargetType="Button"/></Button.Template>
                                </Button>
                                <Button x:Name="PART_NextButton" Grid.Column="2" Width="0" Height="0" IsHitTestVisible="False" Focusable="False">
                                    <Button.Template><ControlTemplate TargetType="Button"/></Button.Template>
                                </Button>
                            </Grid>
                            
                            <Grid Grid.Row="1" x:Name="PART_MonthView" Visibility="Visible" Margin="6,0,6,6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                            </Grid>
                            
                            <Grid Grid.Row="1" x:Name="PART_YearView" Visibility="Hidden" Margin="6,0,6,6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                            </Grid>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding DisplayMode, RelativeSource={RelativeSource AncestorType=Calendar}}" Value="Year">
                                <Setter TargetName="PART_MonthView" Property="Visibility" Value="Hidden"/>
                                <Setter TargetName="PART_YearView" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DisplayMode, RelativeSource={RelativeSource AncestorType=Calendar}}" Value="Decade">
                                <Setter TargetName="PART_MonthView" Property="Visibility" Value="Hidden"/>
                                <Setter TargetName="PART_YearView" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GoogleYearViewCalendarStyle" TargetType="Calendar">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="CalendarDayButtonStyle" Value="{StaticResource GoogleCalendarDayButtonStyle}"/>
            <Setter Property="CalendarButtonStyle" Value="{StaticResource GoogleCalendarButtonStyle}"/>
            <Setter Property="CalendarItemStyle" Value="{StaticResource GoogleYearViewCalendarItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Calendar">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <CalendarItem x:Name="PART_CalendarItem" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== STYLE CHO TEXTBOX TẠO SỰ KIỆN NHANH ===== -->
        <Style x:Key="GoogleTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="0,4,0,8"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="CaretBrush" Value="#1A73E8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" SnapsToDevicePixels="True">
                            <Grid>
                                <TextBlock x:Name="placeholder" Text="{TemplateBinding Tag}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{TemplateBinding FontSize}" Padding="{TemplateBinding Padding}" Visibility="Collapsed" IsHitTestVisible="False" VerticalAlignment="Center"/>
                                <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="">
                                <Setter TargetName="placeholder" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <Trigger Property="IsKeyboardFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#1A73E8"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="0,0,0,2"/>
                                <Setter Property="Padding" Value="0,4,0,7"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#BDBDBD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TimeTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="CaretBrush" Value="#1A73E8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="true">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource BgBrush}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="0,0,0,2"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#1A73E8"/>
                                <Setter TargetName="border" Property="CornerRadius" Value="4,4,0,0"/>
                                <Setter Property="Padding" Value="4,2,4,0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource BgBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="border" Property="Background" Value="{DynamicResource BgBrush}"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="CaretBrush" Value="#1A73E8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <TextBlock x:Name="placeholder" Text="{TemplateBinding Tag}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{TemplateBinding FontSize}" Padding="{TemplateBinding Padding}" Visibility="Collapsed" IsHitTestVisible="False" VerticalAlignment="Center"/>
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="">
                                <Setter TargetName="placeholder" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR BÊN TRÁI -->
        <Border Grid.Column="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0" Padding="10,15,10,10">
            <StackPanel>
                <!-- NÚT TẠO (CREATE BUTTON) -->
                <Button x:Name="BtnCreateEvent" Cursor="Hand" Margin="10,0,0,20" HorizontalAlignment="Left" Click="BtnCreateEvent_Click" ToolTipService.InitialShowDelay="0">
                    <Button.ToolTip>
                        <ToolTip HasDropShadow="True" Placement="Right" HorizontalOffset="10" VerticalOffset="-5">
                            <ToolTip.Template>
                                <ControlTemplate TargetType="ToolTip">
                                    <Border Background="#4A4D51" CornerRadius="4" Padding="10,6">
                                        <TextBlock Text="Tạo sự kiện mới" Foreground="White" FontSize="13" FontFamily="Segoe UI" FontWeight="Medium"/>
                                    </Border>
                                </ControlTemplate>
                            </ToolTip.Template>
                        </ToolTip>
                    </Button.ToolTip>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="BgBorder" Background="White" CornerRadius="24" Padding="12,10,20,10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="4" Opacity="0.1" ShadowDepth="2" Direction="270"/>
                                </Border.Effect>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="+" Foreground="#1A73E8" FontSize="26" FontWeight="Light" Margin="0,-4,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Tạo" FontSize="15" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BgBorder" Property="Background" Value="#F8F9FA"/>
                                    <Setter TargetName="BgBorder" Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect BlurRadius="6" Opacity="0.15" ShadowDepth="3" Direction="270"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Mini Calendar -->
                <Calendar x:Name="MiniCalendar" SelectedDatesChanged="MiniCalendar_SelectedDatesChanged" 
                          Style="{StaticResource GoogleCalendarStyle}" HorizontalAlignment="Center" Margin="0,0,0,15" FontFamily="Segoe UI"/>
                
                <Grid Margin="5,10,15,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnTogglePersonal" Grid.Column="0" Content="&#xE70D;" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextSecondaryBrush}" Cursor="Hand" Click="BtnTogglePersonal_Click" Width="20" FontSize="10" FocusVisualStyle="{x:Null}"/>
                    <CheckBox x:Name="ChkPersonal" Grid.Column="1" Content="Lịch cá nhân" IsChecked="True" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold" FontFamily="Segoe UI" Checked="Filter_Changed" Unchecked="Filter_Changed" VerticalAlignment="Center" Margin="5,0,0,0"/>
                    <Button Grid.Column="2" Content="+" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="18" FontWeight="Medium" Cursor="Hand" Padding="4,0" ToolTip="Tạo tag nhỏ" Click="BtnAddPersonalTag_Click" FocusVisualStyle="{x:Null}"/>
                </Grid>
                <StackPanel x:Name="PersonalTagsPanel" Margin="35,5,15,10"/>

                <Grid Margin="5,10,15,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnToggleAcademic" Grid.Column="0" Content="&#xE70D;" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextSecondaryBrush}" Cursor="Hand" Click="BtnToggleAcademic_Click" Width="20" FontSize="10" FocusVisualStyle="{x:Null}"/>
                    <CheckBox x:Name="ChkAcademic" Grid.Column="1" Content="Lịch học &amp; Thi" IsChecked="True" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold" FontFamily="Segoe UI" Checked="Filter_Changed" Unchecked="Filter_Changed" VerticalAlignment="Center" Margin="5,0,0,0"/>
                    <Button Grid.Column="2" Content="+" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="18" FontWeight="Medium" Cursor="Hand" Padding="4,0" ToolTip="Tạo tag nhỏ" Click="BtnAddAcademicTag_Click" FocusVisualStyle="{x:Null}"/>
                </Grid>
                <StackPanel x:Name="AcademicTagsPanel" Margin="35,5,15,10"/>

                <Grid Margin="5,10,15,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnToggleReminder" Grid.Column="0" Content="&#xE70D;" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextSecondaryBrush}" Cursor="Hand" Click="BtnToggleReminder_Click" Width="20" FontSize="10" FocusVisualStyle="{x:Null}"/>
                    <CheckBox x:Name="ChkReminder" Grid.Column="1" Content="Nhắc nhở" IsChecked="True" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold" FontFamily="Segoe UI" Checked="Filter_Changed" Unchecked="Filter_Changed" VerticalAlignment="Center" Margin="5,0,0,0"/>
                    <Button Grid.Column="2" Content="+" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="18" FontWeight="Medium" Cursor="Hand" Padding="4,0" ToolTip="Tạo tag nhỏ" Click="BtnAddReminderTag_Click" FocusVisualStyle="{x:Null}"/>
                </Grid>
                <StackPanel x:Name="ReminderTagsPanel" Margin="35,5,15,10"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Hôm nay" Margin="0,0,15,0" Click="BtnToday_Click" Padding="12,6" Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" FontWeight="Medium" Cursor="Hand" FocusVisualStyle="{x:Null}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="border" Property="Background" Value="{DynamicResource BgBrush}"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Nhập TKB" Margin="0,0,15,0" Click="BtnImportTKB_Click" Padding="12,6" Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Foreground="#1A73E8" FontSize="14" FontWeight="SemiBold" Cursor="Hand" ToolTip="Nhập Thời khóa biểu từ file JSON">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="border" Property="Background" Value="{DynamicResource BgBrush}"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="&#xE76B;" FontFamily="Segoe MDL2 Assets" Click="BtnPrev_Click" Style="{StaticResource IconButtonStyle}" FontSize="12" Margin="0,0,4,0"/>
                    <Button Content="&#xE76C;" FontFamily="Segoe MDL2 Assets" Click="BtnNext_Click" Style="{StaticResource IconButtonStyle}" FontSize="12" Margin="0,0,15,0"/>
                    <Button x:Name="BtnMonthSelector" Click="BtnMonthSelector_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" FocusVisualStyle="{x:Null}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="Transparent" CornerRadius="4" Padding="8,4">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="border" Property="Background" Value="{DynamicResource BgBrush}"/></Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock x:Name="TxtMonthYear" FontSize="22" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border Background="{DynamicResource BgBrush}" CornerRadius="8" Padding="10,0" Margin="0,0,15,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE71E;" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="TxtSearchEvent" Width="150" Style="{StaticResource SearchTextBoxStyle}" VerticalAlignment="Center" FontSize="14" Tag="Tìm kiếm sự kiện" TextChanged="TxtSearchEvent_TextChanged"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource BgBrush}" CornerRadius="8" Padding="2">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="RbScheduleView" Content="Ngày" GroupName="ViewMode" Width="70" Height="32" Style="{StaticResource ViewToggleStyle}" Click="SwitchView_Click"/>
                            <RadioButton x:Name="RbWeekView" Content="Tuần" GroupName="ViewMode" Width="70" Height="32" Style="{StaticResource ViewToggleStyle}" Click="SwitchView_Click"/>
                            <RadioButton x:Name="RbMonthView" Content="Tháng" IsChecked="True" GroupName="ViewMode" Width="70" Height="32" Style="{StaticResource ViewToggleStyle}" Click="SwitchView_Click"/>
                            <RadioButton x:Name="RbYearView" Content="Năm" GroupName="ViewMode" Width="70" Height="32" Style="{StaticResource ViewToggleStyle}" Click="SwitchView_Click"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="1" Margin="65,10,0,10" x:Name="HeaderDateInfo" Visibility="Collapsed" HorizontalAlignment="Left">
                <TextBlock x:Name="TxtCurrentDayName" Text="THỨ" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <Border x:Name="TodayCircleBorder" Width="46" Height="46" CornerRadius="23">
                    <TextBlock x:Name="TxtCurrentDayNumber" Text="1" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </StackPanel>

            <Grid Grid.Row="1" Margin="65,10,20,10" x:Name="WeekHeaderInfo" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
            </Grid>

            <!-- KHU VỰC SỰ KIỆN CẢ NGÀY (ALL-DAY) - STICKY -->
            <Grid Grid.Row="2" Margin="0,0,20,10" x:Name="AllDayDayContainer" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="65"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="cả ngày" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0" Grid.Column="0"/>
                <StackPanel x:Name="AllDayDayEvents" MinHeight="25" Grid.Column="1" VerticalAlignment="Center"/>
            </Grid>
            
            <Grid Grid.Row="2" Margin="0,0,20,10" x:Name="AllDayWeekContainer" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="65"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="cả ngày" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0" Grid.Column="0"/>
                <Grid x:Name="AllDayWeekEventsGrid" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                </Grid>
            </Grid>

            <Grid Grid.Row="3">
                <Grid x:Name="MonthViewGrid" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <UniformGrid Columns="7" Margin="0,0,0,8">
                        <TextBlock Text="THỨ 2" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="THỨ 3" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="THỨ 4" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="THỨ 5" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="THỨ 6" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="THỨ 7" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="CN" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </UniformGrid>
                    <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,1,0,0">
                        <UniformGrid x:Name="CalendarGrid" Columns="7" Rows="6"/>
                    </Border>
                </Grid>

                <ScrollViewer x:Name="ScheduleViewScroll" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                    <Grid x:Name="TimeGridContainer" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="65"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ItemsControl x:Name="HourLinesControl" Grid.Column="0" Grid.ColumnSpan="2">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="60">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="65"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding HourText}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,-7,8,0"/>
                                        <Border Grid.Column="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" VerticalAlignment="Top"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Canvas Grid.Column="1" x:Name="CurrentTimeCanvas" IsHitTestVisible="False" Panel.ZIndex="10">
                            <Line x:Name="CurrentTimeLine" X1="0" X2="2000" Stroke="#EA4335" StrokeThickness="2" Visibility="Collapsed"/>
                            <Ellipse x:Name="CurrentTimeDot" Fill="#EA4335" Width="12" Height="12" Margin="-6,-6,0,0" Visibility="Collapsed"/>
                        </Canvas>

                        <Canvas x:Name="EventsCanvas" Grid.Column="1" Margin="5,0,20,0" 
                                Background="Transparent" 
                                Height="1440"
                                Panel.ZIndex="99"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top"
                                MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                                MouseMove="Canvas_MouseMove"
                                MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                                MouseLeave="Canvas_MouseLeave">
                            <Border x:Name="GhostEventBorder" Background="#4D1A73E8" BorderBrush="#1A73E8" BorderThickness="1" CornerRadius="4" Visibility="Collapsed" IsHitTestVisible="False" Panel.ZIndex="1000"/>
                        </Canvas>
                    </Grid>
                </ScrollViewer>

                <!-- Lưới lịch Tuần -->
                <ScrollViewer x:Name="WeekViewScroll" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" PreviewMouseWheel="WeekViewScroll_PreviewMouseWheel">
                    <Grid x:Name="WeekGridContainer" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="65"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ItemsControl x:Name="WeekHourLinesControl" Grid.Column="0" Grid.ColumnSpan="2">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="60">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="65"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding HourText}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,-7,8,0"/>
                                        <Border Grid.Column="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" VerticalAlignment="Top"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid Grid.Column="1" Margin="5,0,20,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0" Grid.Column="0"/>
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0" Grid.Column="1"/>
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0" Grid.Column="2"/>
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0" Grid.Column="3"/>
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0" Grid.Column="4"/>
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0" Grid.Column="5"/>
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,1,0" Grid.Column="6"/>
                            <Canvas x:Name="WeekEventsCanvas" Grid.ColumnSpan="7" Background="Transparent" Height="1440" VerticalAlignment="Top" Panel.ZIndex="99" SizeChanged="WeekEventsCanvas_SizeChanged"
                                    MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                                    MouseMove="Canvas_MouseMove"
                                    MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                                    MouseLeave="Canvas_MouseLeave">
                                <Border x:Name="WeekGhostEventBorder" Background="#4D1A73E8" BorderBrush="#1A73E8" BorderThickness="1" CornerRadius="4" Visibility="Collapsed" IsHitTestVisible="False" Panel.ZIndex="1000"/>
                            </Canvas>
                        </Grid>
                    </Grid>
                </ScrollViewer>

                <!-- Lưới lịch Năm -->
                <ScrollViewer x:Name="YearViewScroll" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                    <UniformGrid Columns="4" x:Name="YearCalendarContainer" Margin="10" HorizontalAlignment="Center"/>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- OVERLAY CHẶN TƯƠNG TÁC (TÀNG HÌNH) -->
        <Border x:Name="PopupOverlay" Grid.ColumnSpan="2" Background="Transparent" Visibility="Collapsed" MouseLeftButtonDown="PopupOverlay_MouseLeftButtonDown" Panel.ZIndex="1000"/>

        <!-- POPOVER KẾT QUẢ TÌM KIẾM -->
        <Popup x:Name="SearchResultsPopup" StaysOpen="False" Placement="Bottom" AllowsTransparency="True" PopupAnimation="Fade">
            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Width="250" MaxHeight="350" Margin="5">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2" Direction="270"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="12,8">
                        <CheckBox x:Name="ChkHidePastEvents" Content="Ẩn sự kiện đã qua" Foreground="{DynamicResource TextSecondaryBrush}" Checked="ChkHidePastEvents_Changed" Unchecked="ChkHidePastEvents_Changed"/>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="SearchResultsPanel" Margin="0,5"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Popup>

        <!-- POPOVER XEM NHANH SỰ KIỆN -->
        <Popup x:Name="QuickEventPopup" StaysOpen="False" Placement="Bottom" AllowsTransparency="True" PopupAnimation="Fade" Closed="QuickEventPopup_Closed" PreviewKeyDown="QuickPopup_PreviewKeyDown">
            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="16" Width="300" Margin="5">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Opacity="0.15" ShadowDepth="4" Direction="315"/>
                </Border.Effect>
                <StackPanel>
                    <!-- Action buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                        <Button x:Name="BtnQuickAddAtSameTime" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnQuickAddAtSameTime_Click" ToolTip="Tạo sự kiện mới tại giờ này" FocusVisualStyle="{x:Null}">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE710;" FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,15,0"/>
                        </Button>
                        <Button x:Name="BtnQuickEdit" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnQuickEdit_Click" ToolTip="Sửa" FocusVisualStyle="{x:Null}">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE70F;" FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,15,0"/>
                        </Button>
                        <Button x:Name="BtnQuickDelete" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnQuickDelete_Click" ToolTip="Xóa" FocusVisualStyle="{x:Null}">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74D;" FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Button>
                    </StackPanel>
                    <!-- Detail info -->
                    <TextBlock x:Name="PopupEventTitle" FontSize="18" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE121;" FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock x:Name="PopupEventTime" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" x:Name="PopupLocationPanel" Margin="0,0,0,5">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE707;" FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock x:Name="PopupEventLocation" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                    
                    <!-- Action buttons cho khách mời -->
                    <StackPanel x:Name="RsvpPanel" Orientation="Horizontal" Margin="0,10,0,0" Visibility="Collapsed" HorizontalAlignment="Center">
                        <Button x:Name="BtnAccept" Content="✓ Tham gia" Background="#E8F0FE" Foreground="#1A73E8" Margin="0,0,10,0" Padding="10,5" BorderThickness="0" Cursor="Hand" Click="BtnAccept_Click"/>
                        <Button x:Name="BtnDecline" Content="✕ Từ chối" Background="#FCE8E6" Foreground="#D93025" Padding="10,5" BorderThickness="0" Cursor="Hand" Click="BtnDecline_Click"/>
                    </StackPanel>
                    
                    <CheckBox x:Name="ChkQuickCompleted" 
                              Content="Đánh dấu đã hoàn thành" 
                              FontWeight="SemiBold" 
                              Foreground="#3F51B5"
                              Margin="0,10,0,0" 
                              Visibility="Collapsed"/>
                </StackPanel>
            </Border>
        </Popup>

        <!-- POPOVER TẠO NHANH SỰ KIỆN (GOOGLE CALENDAR STYLE) -->
        <Popup x:Name="QuickCreatePopup" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade" Placement="Bottom" Closed="QuickCreatePopup_Closed" PreviewKeyDown="QuickPopup_PreviewKeyDown">
            <Border Background="White" CornerRadius="8" Width="450" Padding="0" FocusManager.IsFocusScope="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Opacity="0.2" ShadowDepth="5" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <Border Background="{DynamicResource BgBrush}" Padding="15,8" CornerRadius="8,8,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Cursor="Hand" Click="CloseQuickCreate_Click" FocusVisualStyle="{x:Null}"/>
                        </StackPanel>
                    </Border>
                    
                    <StackPanel Margin="24,10,24,24">
                        <TextBox x:Name="QuickTitle" Tag="Thêm tiêu đề" FontSize="22" Margin="0,0,0,24" Style="{StaticResource GoogleTextBoxStyle}"/>
                        
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="35"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE133;" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" FontSize="18"/>
                            <ComboBox x:Name="QuickEventType" Height="36" BorderThickness="0,0,0,1" BorderBrush="#E0E0E0" Background="Transparent" FontSize="14" VerticalContentAlignment="Center" Grid.Column="1" SelectionChanged="QuickEventType_SelectionChanged">
                                <ComboBoxItem Content="📌  Cá nhân" Tag="PERSONAL" IsSelected="True"/>
                                <ComboBoxItem Content="📚  Học &amp; Thi" Tag="ACADEMIC"/>
                                <ComboBoxItem Content="⏰  Nhắc nhở" Tag="REMINDER"/>
                            </ComboBox>
                        </Grid>
                        
                        <Grid Margin="0,0,0,24" x:Name="QuickTagsContainer" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="35"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE302;" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" FontSize="18"/>
                            <Grid Grid.Column="1">
                                <ToggleButton x:Name="QuickTagsDropdownToggle" Tag="Chọn Tag..." Height="36" BorderThickness="0,0,0,1" BorderBrush="#E0E0E0" Background="Transparent" Cursor="Hand">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}">
                                                <Grid>
                                                    <TextBlock Text="{TemplateBinding Tag}" VerticalAlignment="Center" Margin="5,0,30,0" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14"/>
                                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE70D;" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="10"/>
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <Popup PlacementTarget="{Binding ElementName=QuickTagsDropdownToggle}" IsOpen="{Binding IsChecked, ElementName=QuickTagsDropdownToggle}" StaysOpen="False" AllowsTransparency="True">
                                    <Border Background="White" BorderThickness="1" BorderBrush="#E0E0E0" CornerRadius="4" MinWidth="{Binding ActualWidth, ElementName=QuickTagsDropdownToggle}" MaxHeight="200">
                                        <Border.Effect><DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/></Border.Effect>
                                        <ScrollViewer>
                                            <ItemsControl x:Name="QuickTagsListControl">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <CheckBox Content="{Binding TagName}" IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="10,8" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="Medium" Checked="QuickTagCheckBox_Changed" Unchecked="QuickTagCheckBox_Changed"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Grid>
                        
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="35"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE121;" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" FontSize="18"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock x:Name="QuickDateDisplay" Text="Thứ Tư, 3 tháng 6" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14"/>
                                <TextBlock Text=" ⋅ " VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" Margin="5,0"/>
                                <TextBox x:Name="QuickStartTime" Text="08:00" Width="55" FontSize="14" VerticalAlignment="Center" Style="{StaticResource TimeTextBoxStyle}"/>
                                <TextBlock Text=" – " VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" Margin="5,0"/>
                                <TextBox x:Name="QuickEndTime" Text="09:00" Width="55" FontSize="14" VerticalAlignment="Center" Style="{StaticResource TimeTextBoxStyle}"/>
                            </StackPanel>
                        </Grid>
                        
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="35"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE707;" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" FontSize="18"/>
                            <TextBox Grid.Column="1" Tag="Thêm vị trí" FontSize="14" Margin="0,0,0,8" Style="{StaticResource GoogleTextBoxStyle}"/>
                        </Grid>
                    
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                            <Button Content="Tùy chọn khác" Background="Transparent" Foreground="{DynamicResource TextSecondaryBrush}" BorderThickness="0" Padding="12,8" Margin="0,0,16,0" FontWeight="Medium" Cursor="Hand" Click="MoreOptions_Click" FocusVisualStyle="{x:Null}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource BgBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                            </Button>
                            <Button Content="Lưu" Width="80" Height="36" Background="#1A73E8" Foreground="White" BorderThickness="0" FontWeight="Medium" Cursor="Hand" Click="SaveQuickEvent_Click" FocusVisualStyle="{x:Null}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#1B66C9"/>
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect BlurRadius="4" Opacity="0.2" ShadowDepth="2" Direction="270"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Page>