<Page x:Class="StudentReminderApp.Views.Pages.CoursePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:System="clr-namespace:System;assembly=mscorlib"
      xmlns:converters="clr-namespace:StudentReminderApp.Converters"
      Title="Lộ trình học tập"
      Background="{DynamicResource BgBrush}">

    <Page.Resources>
        <!-- Custom Flat RadioButton -->
        <Style TargetType="RadioButton">
            <Setter Property="Margin"
                    Value="0,0,16,0"/>
            <Setter Property="FontSize"
                    Value="13"/>
            <Setter Property="FontWeight"
                    Value="SemiBold"/>
            <Setter Property="Foreground"
                    Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>

        <!-- Custom TabItem Style for Modern Flat Look -->
        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border"
                                Padding="16,10"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                Background="Transparent"
                                Cursor="Hand"
                                Margin="0,0,24,0">
                            <ContentPresenter x:Name="ContentSite"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected"
                                     Value="True">
                                <Setter TargetName="Border"
                                        Property="BorderBrush"
                                        Value="{DynamicResource TextPrimaryBrush}"/>
                                <Setter Property="TextElement.Foreground"
                                        Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected"
                                     Value="False">
                                <Setter Property="TextElement.Foreground"
                                        Value="{DynamicResource TextSecondaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Border"
                                        Property="Background"
                                        Value="{DynamicResource BgBrush}"/>
                                <Setter TargetName="Border"
                                        Property="CornerRadius"
                                        Value="6,6,0,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="FontSize"
                    Value="13"/>
            <Setter Property="FontWeight"
                    Value="Bold"/>
        </Style>

        <!-- Danh sách trạng thái học -->
        <x:Array x:Key="StatusList" Type="{x:Type System:String}">
            <System:String>Đã học</System:String>
            <System:String>Đang học</System:String>
            <System:String>Chưa học</System:String>
        </x:Array>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EBF5FB" />
                    <Setter Property="Foreground" Value="#1F2937" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WrapTextBlockStyle" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,2,0,2" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding CanEditStatus}" Value="False">
                    <Setter Property="Opacity" Value="0.5" />
                    <Setter Property="Background" Value="{DynamicResource BorderBrush}" />
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BgBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DBEAFE" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <converters:WidthToVisibilityConverter x:Key="IsWideEnoughGridVisibilityConverter"
                                               Threshold="1100"
                                               Invert="False" />
        <converters:WidthToVisibilityConverter x:Key="IsNarrowHintVisibilityConverter"
                                               Threshold="1100"
                                               Invert="True" />

        <!-- Flat ComboBox cho Trạng thái viên thuốc -->
        <Style x:Key="PillComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="false"
                                          Background="{TemplateBinding Background}"
                                          Foreground="{TemplateBinding Foreground}"
                                          IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}" BorderThickness="0" CornerRadius="12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Content="{TemplateBinding Content}" Margin="0,0,4,0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <Path Grid.Column="1" Fill="{TemplateBinding Foreground}" Data="M 0 0 L 3 3 L 6 0 Z" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,6,0"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ToggleButton.Content>
                                    <TextBlock Text="{TemplateBinding Text}" Foreground="{TemplateBinding Foreground}" FontWeight="Bold" FontSize="11" Margin="8,4" VerticalAlignment="Center"/>
                                </ToggleButton.Content>
                            </ToggleButton>
                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="{DynamicResource SurfaceBrush}" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" CornerRadius="6">
                                        <ScrollViewer Margin="0,4,0,4" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style thanh cuộn hiện đại (Dọc + Ngang) -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Opacity" Value="0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ScrollViewer}}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.4"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="6"/>
                    <Setter Property="Margin" Value="0,16,0,16"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent">
                                    <Track x:Name="PART_Track" IsDirectionReversed="true">
                                        <Track.Thumb>
                                            <Thumb>
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border Background="#CBD5E1" CornerRadius="3"/>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="6"/>
                    <Setter Property="Margin" Value="16,0,16,0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent">
                                    <Track x:Name="PART_Track" IsDirectionReversed="False">
                                        <Track.Thumb>
                                            <Thumb>
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border Background="#CBD5E1" CornerRadius="3"/>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid x:Name="RootGrid" Margin="32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= TOP: TRẠNG THÁI & CẤU HÌNH ================= -->
        <Grid Grid.Row="0"
              Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Lộ trình Học tập Cá nhân"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,0,0,12"/>
                <TextBlock x:Name="TxtStudentInfo"
                           Text="SV: Nguyễn Quang Hiền - 102240365"
                           FontWeight="SemiBold"
                           FontSize="15"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,0,0,12"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                    <TextBlock Text="&#xE82D;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtCourseStatus"
                               Text="TIẾN ĐỘ HỌC TẬP: Đang tải lộ trình học..."
                               FontSize="14"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>


            </StackPanel>

            <!-- Môn đang đăng ký (Legend/Status) & Quick Edit Controls -->
            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                <Border BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16,12"
                        Background="{DynamicResource SurfaceBrush}">
                    <StackPanel>
                        <TextBlock Text="Chú giải màu sắc"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="#334155"
                                   Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,4">
                            <Ellipse Width="6"
                                     Height="6"
                                     Fill="#10B981"
                                     Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Đã học (Qua môn)" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,4">
                            <Ellipse Width="6"
                                     Height="6"
                                     Fill="#FBBF24"
                                     Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Đang học kỳ này" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,4">
                            <Ellipse Width="6"
                                     Height="6"
                                     Fill="{DynamicResource TextMutedBrush}"
                                     Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Chưa học" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
            </StackPanel>
        </Grid>

        <!-- ================= MAIN CONTENT (TABS) ================= -->
        <Grid Grid.Row="1">
            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Margin="0,38,0,0" VerticalAlignment="Top"/>
            
            <TabControl Background="Transparent"
                        BorderThickness="0">

                <!-- TAB 1: KHUNG CHƯƠNG TRÌNH -->
                <TabItem Header="KHUNG CHƯƠNG TRÌNH">
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Background="{DynamicResource SurfaceBrush}"
                        Padding="0"
                        Margin="0,12,0,0">
                    <Grid>
                        <TextBlock Text="Cửa sổ quá nhỏ. Vui lòng phóng to để xem chi tiết."
                                   Visibility="{Binding ActualWidth, ElementName=RootGrid, Converter={StaticResource IsNarrowHintVisibilityConverter}}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Padding="24"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />

                        <DataGrid x:Name="DgRoadmap" 
                                AutoGenerateColumns="False" 
                                CanUserAddRows="False" 
                                CanUserSortColumns="False"
                                HeadersVisibility="Column" 
                                GridLinesVisibility="Horizontal" 
                                HorizontalGridLinesBrush="#E2E8F0" 
                                BorderThickness="1" 
                                BorderBrush="{DynamicResource BorderBrush}"
                                Background="{DynamicResource SurfaceBrush}" 
                                RowBackground="{DynamicResource SurfaceBrush}" 
                                AlternatingRowBackground="{DynamicResource SurfaceBrush}"
                                MinRowHeight="45" 
                                ColumnHeaderHeight="45" 
                                SelectionMode="Single"
                                IsReadOnly="False"
                                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                VirtualizingPanel.ScrollUnit="Pixel"
                                Margin="0,4,0,0">

                            <DataGrid.Resources>
                                <!-- Override default selection colors -->
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#DBEAFE"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#1E3A8A"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F8FAFC"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#334155"/>

                                <!-- Style Header: Clean white -->
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="10,0"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                                
                                <!-- Style Cell: Bỏ viền đen bao quanh khi click chuột -->
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="5"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource BgBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Resources>

                            <!-- Khai báo đầy đủ các cột tương ứng với file CSV -->
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="TT" Binding="{Binding SerialNumber}" Width="Auto" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Học kỳ" Binding="{Binding HocKy}" Width="Auto" IsReadOnly="True"/>
                                
                                <!-- Cột Tên môn học: Căn trái, tự động xuống dòng -->
                                <DataGridTextColumn Header="Tên học phần" Binding="{Binding TenHocPhan}" Width="2*" MinWidth="180" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                
                                <!-- Cột Xét điều kiện Đăng ký -->
                                <DataGridTemplateColumn Header="ĐK được?" Width="Auto" IsReadOnly="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding RegMainText}" Foreground="{Binding RegistrationColor}" FontWeight="Bold" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                                                <TextBlock Text="{Binding RegSubText}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding RegSubText}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Mã HP" Binding="{Binding MaHocPhan}" Width="Auto" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Số tín chỉ" Binding="{Binding SoTC}" Width="Auto" IsReadOnly="True"/>
                                
                                <!-- Cột Tự chọn: Chữ màu vàng đậm -->
                                <DataGridTextColumn Header="Tự chọn" Binding="{Binding Optional}" Width="Auto" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                            <Setter Property="Foreground" Value="#D97706"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                
                                <DataGridTextColumn Header="HT ĐA" Binding="{Binding HtDa}" Width="Auto" IsReadOnly="True"/>
                                <DataGridTextColumn Header="TQ ĐA" Binding="{Binding TqDa}" Width="Auto" IsReadOnly="True"/>
                                
                                <!-- Cột Học trước -->
                                <DataGridTextColumn Header="Học trước" Binding="{Binding HocTruocStr}" Width="*" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                            <Setter Property="FontSize" Value="11"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                
                                <!-- Cột Song hành -->
                                <DataGridTextColumn Header="Song hành" Binding="{Binding SongHanhStr}" Width="*" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                            <Setter Property="FontSize" Value="11"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                
                                <!-- Cột Tiên quyết -->
                                <DataGridTextColumn Header="Tiên quyết" Binding="{Binding TienQuyetStr}" Width="*" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                            <Setter Property="FontSize" Value="11"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                
                                <!-- Cột Trạng thái (Combo Box cho phép sửa) -->
                                <DataGridTemplateColumn Header="Trạng thái" Width="140">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <CheckBox IsChecked="{Binding IsSelectedForEdit, UpdateSourceTrigger=PropertyChanged}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,8,0"
                                                          IsEnabled="{Binding CanEditStatus}">
                                                    <CheckBox.Style>
                                                        <Style TargetType="CheckBox">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Setter Property="Cursor" Value="Hand"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="CheckBox">
                                                                        <Border x:Name="Bd" 
                                                                                Width="18" Height="18" 
                                                                                Background="{DynamicResource SurfaceBrush}" 
                                                                                BorderBrush="#CBD5E1" 
                                                                                BorderThickness="1.5" 
                                                                                CornerRadius="4">
                                                                            <Path x:Name="CheckMark" 
                                                                                  Data="M 4 9 L 8 13 L 14 5" 
                                                                                  Stroke="{DynamicResource SurfaceBrush}" 
                                                                                  StrokeThickness="2" 
                                                                                  StrokeStartLineCap="Round" 
                                                                                  StrokeEndLineCap="Round" 
                                                                                  StrokeLineJoin="Round"
                                                                                  Visibility="Collapsed" 
                                                                                  HorizontalAlignment="Center" 
                                                                                  VerticalAlignment="Center"
                                                                                  Margin="0,0,0,0"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsChecked" Value="True">
                                                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource TextPrimaryBrush}"/>
                                                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource TextPrimaryBrush}"/>
                                                                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                                                            </Trigger>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource TextPrimaryBrush}"/>
                                                                            </Trigger>
                                                                            <Trigger Property="IsEnabled" Value="False">
                                                                                <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsQuickEditMode}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </CheckBox.Style>
                                                </CheckBox>

                                                <ComboBox ItemsSource="{StaticResource StatusList}"
                                                          SelectedItem="{Binding StatusText, UpdateSourceTrigger=PropertyChanged}"
                                                          Style="{StaticResource PillComboBoxStyle}"
                                                          Background="{Binding BgColor}"
                                                          Foreground="{Binding FgColor}"
                                                          IsEnabled="{Binding CanEditStatus}"
                                                          Margin="2"
                                                          VerticalAlignment="Center"
                                                          HorizontalContentAlignment="Center">
                                                    <ComboBox.ItemContainerStyle>
                                                        <Style TargetType="ComboBoxItem">
                                                            <Setter Property="Padding" Value="12,6"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="ComboBoxItem">
                                                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                                            <ContentPresenter HorizontalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsHighlighted" Value="True">
                                                                                <Setter TargetName="Bd" Property="Background" Value="#F1F5F9"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding}" Value="Đã học">
                                                                    <Setter Property="Foreground" Value="#0F5132"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding}" Value="Đang học">
                                                                    <Setter Property="Foreground" Value="#664D03"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding}" Value="Chưa học">
                                                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ComboBox.ItemContainerStyle>
                                                </ComboBox>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- TAB 2: MÔN ĐANG ĐĂNG KÝ -->
            <TabItem Header="MÔN ĐANG ĐĂNG KÝ">
                <Border Style="{StaticResource Card}"
                        Padding="0"
                        Margin="0,12,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Danh sách môn học đang đăng ký"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Padding="16,16,16,8"/>

                        <DataGrid x:Name="DgCurrentCourses"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserSortColumns="False"
                                  CanUserResizeColumns="True"
                                  CanUserResizeRows="False"
                                  CanUserReorderColumns="False"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  ColumnHeaderHeight="40"
                                  RowBackground="{DynamicResource SurfaceBrush}"
                                  AlternatingRowBackground="{DynamicResource BgBrush}"
                                  BorderThickness="0"
                                  MinRowHeight="36"
                                  FontSize="11.5"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.CanContentScroll="True"
                                  VirtualizingPanel.ScrollUnit="Pixel">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="TT" Binding="{Binding SerialNumber}" Width="Auto" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Học kỳ" Binding="{Binding HocKy}" Width="Auto" IsReadOnly="True"/>
                                
                                <DataGridTextColumn Header="Tên học phần" Binding="{Binding TenHocPhan}" Width="2*" MinWidth="180" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                
                                <DataGridTemplateColumn Header="ĐK được?" Width="Auto" IsReadOnly="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding RegMainText}" Foreground="{Binding RegistrationColor}" FontWeight="Bold" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                                                <TextBlock Text="{Binding RegSubText}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding RegSubText}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Mã HP" Binding="{Binding MaHocPhan}" Width="Auto" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Số tín chỉ" Binding="{Binding SoTC}" Width="Auto" IsReadOnly="True"/>
                                
                                <DataGridTextColumn Header="Tự chọn" Binding="{Binding Optional}" Width="Auto" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                            <Setter Property="Foreground" Value="#D97706"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                
                                <DataGridTextColumn Header="HT ĐA" Binding="{Binding HtDa}" Width="Auto" IsReadOnly="True"/>
                                <DataGridTextColumn Header="TQ ĐA" Binding="{Binding TqDa}" Width="Auto" IsReadOnly="True"/>
                                
                                <DataGridTextColumn Header="Học trước" Binding="{Binding HocTruocStr}" Width="*" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                            <Setter Property="FontSize" Value="11"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                
                                <DataGridTextColumn Header="Song hành" Binding="{Binding SongHanhStr}" Width="*" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                            <Setter Property="FontSize" Value="11"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                
                                <DataGridTextColumn Header="Tiên quyết" Binding="{Binding TienQuyetStr}" Width="*" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                            <Setter Property="FontSize" Value="11"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- TAB 3: LỊCH SỬ ĐÁNH GIÁ -->
            <TabItem Header="LỊCH SỬ ĐÁNH GIÁ">
                <Border Style="{StaticResource Card}"
                        Padding="0"
                        Margin="0,12,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="16,16,16,8">
                            <TextBlock Text="Lịch sử Học tập &amp; Điểm số" FontSize="16" FontWeight="Bold" />
                            <TextBlock x:Name="TxtGPA" Text="GPA Tích Lũy: 0.0" FontSize="15" FontWeight="SemiBold" Foreground="#059669" Margin="20,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>                        <DataGrid x:Name="DgHistory"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserSortColumns="False"
                                  CanUserResizeColumns="True"
                                  CanUserResizeRows="False"
                                  CanUserReorderColumns="False"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  ColumnHeaderHeight="40"
                                  RowBackground="{DynamicResource SurfaceBrush}"
                                  AlternatingRowBackground="{DynamicResource BgBrush}"
                                  BorderThickness="0"
                                  MinRowHeight="36"
                                  FontSize="11.5"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.CanContentScroll="True"
                                  VirtualizingPanel.ScrollUnit="Pixel">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Mã HP"
                                                    Binding="{Binding MaHocPhan}"
                                                    Width="110"
                                                    Foreground="{DynamicResource TextMutedBrush}"
                                                    ElementStyle="{StaticResource WrapTextBlockStyle}" />
                                <DataGridTextColumn Header="Tên học phần"
                                                    Binding="{Binding TenHocPhan}"
                                                    Width="2*"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource TextPrimaryBrush}"
                                                    ElementStyle="{StaticResource WrapTextBlockStyle}" />
                                <DataGridTextColumn Header="Học kỳ"
                                                    Binding="{Binding HocKy}"
                                                    Width="70"
                                                    ElementStyle="{StaticResource WrapTextBlockStyle}" />
                                <DataGridTextColumn Header="Tín chỉ"
                                                    Binding="{Binding SoTC, StringFormat={}{0:0.#}}"
                                                    Width="70"
                                                    ElementStyle="{StaticResource WrapTextBlockStyle}" />
                                <DataGridTemplateColumn Header="Điểm hệ 10" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding DiemTong, UpdateSourceTrigger=PropertyChanged}" 
                                                     HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                     Width="60" TextAlignment="Center"
                                                     Padding="4,2" BorderBrush="#CBD5E1" BorderThickness="1"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Điểm chữ"
                                                    Binding="{Binding DiemChu}"
                                                    Width="90">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextWrapping" Value="Wrap" />
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Setter Property="Margin" Value="0,2,0,2" />
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Điểm hệ 4"
                                                    Binding="{Binding DiemSo}"
                                                    Width="100"/>
                                <DataGridTemplateColumn Header="Trạng thái" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding BgColor}" CornerRadius="12" Padding="8,4" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding StatusText}" Foreground="{Binding FgColor}" FontWeight="Bold" FontSize="11"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>
        
        <!-- Quick Edit Controls Overlay on top of Tab Headers -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,16,0">
            <StackPanel.Resources>
                <Style TargetType="Button" x:Key="PillBtn">
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="16" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </StackPanel.Resources>
            <ToggleButton x:Name="BtnQuickEdit" Padding="16,6" FontWeight="SemiBold" Click="BtnQuickEdit_Click">
                <ToggleButton.Style>
                    <Style TargetType="ToggleButton">
                        <Setter Property="Content" Value="Chỉnh nhanh"/>
                        <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                        <Setter Property="BorderBrush" Value="#CBD5E1"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="16" Padding="{TemplateBinding Padding}" BorderThickness="1" BorderBrush="{TemplateBinding BorderBrush}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Content" Value="Hủy"/>
                                <Setter Property="Background" Value="#DC2626"/>
                                <Setter Property="BorderBrush" Value="#DC2626"/>
                                <Setter Property="Foreground" Value="{DynamicResource SurfaceBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ToggleButton.Style>
            </ToggleButton>
            <StackPanel x:Name="PanelQuickActions" Orientation="Horizontal" Visibility="Collapsed" Margin="8,0,0,0">
                <Button Content="Đã học" Background="#D1FAE5" Foreground="#065F46" Padding="12,6" FontWeight="Bold" Margin="4,0" Click="BtnQuickAction_Click" Tag="Đã học" Style="{StaticResource PillBtn}"/>
                <Button Content="Đang học" Background="#FEF3C7" Foreground="#92400E" Padding="12,6" FontWeight="Bold" Margin="4,0" Click="BtnQuickAction_Click" Tag="Đang học" Style="{StaticResource PillBtn}"/>
                <Button Content="Chưa học" Background="#F1F5F9" Foreground="{DynamicResource TextSecondaryBrush}" Padding="12,6" FontWeight="Bold" Margin="4,0" Click="BtnQuickAction_Click" Tag="Chưa học" Style="{StaticResource PillBtn}"/>
            </StackPanel>
        </StackPanel>
        </Grid>
    </Grid>
</Page>