<Page x:Class="StudentReminderApp.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BgBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Hidden">
        <StackPanel Margin="32,28">
            <TextBlock x:Name="TxtGreeting" FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBlock x:Name="TxtDate" FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,24"/>

            <!-- Two column -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="360"/>
                </Grid.ColumnDefinitions>

                <!-- Cột trái: Thống kê + Sự kiện sắp tới -->
                <StackPanel Grid.Column="0">
                    <!-- Khối Stat cards bố trí dạng 2x2 giống ảnh mẫu -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/><ColumnDefinition Width="16"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/><RowDefinition Height="16"/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        
                        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}" CornerRadius="16" Padding="24">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <Border Width="40" Height="40" CornerRadius="10" Background="#F1F5F9" Margin="0,0,12,0">
                                        <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Sự kiện 7 ngày tới" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock x:Name="StatUpcoming" Text="0" FontSize="36" FontWeight="ExtraBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource Card}" CornerRadius="16" Padding="24">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <Border Width="40" Height="40" CornerRadius="10" Background="#F1F5F9" Margin="0,0,12,0">
                                        <TextBlock Text="&#xE82D;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Học phần đang học" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock x:Name="StatCourses" Text="0" FontSize="36" FontWeight="ExtraBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource Card}" CornerRadius="16" Padding="24">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <Border Width="40" Height="40" CornerRadius="10" Background="#F1F5F9" Margin="0,0,12,0">
                                        <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Sự kiện hôm nay" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock x:Name="StatEvents" Text="0" FontSize="36" FontWeight="ExtraBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource Card}" CornerRadius="16" Padding="24">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <Border Width="40" Height="40" CornerRadius="10" Background="#F1F5F9" Margin="0,0,12,0">
                                        <TextBlock Text="&#xEA8F;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Thông báo mới" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock x:Name="StatNotifs" Text="0" FontSize="36" FontWeight="ExtraBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Style="{StaticResource Card}" CornerRadius="16" Padding="24">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,24">
                                <TextBlock Text="Sự kiện sắp tới (7 ngày)" FontSize="18" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                <Button HorizontalAlignment="Right" Height="40" Padding="16,0" Cursor="Hand"
                                        Click="BtnAddEvent_Click">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="{DynamicResource TextPrimaryBrush}"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="20">
                                                            <Border.Effect>
                                                                <DropShadowEffect Color="Black" BlurRadius="4" Opacity="0.1" ShadowDepth="2"/>
                                                            </Border.Effect>
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource SurfaceBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                                <TextBlock Text="Thêm sự kiện" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource SurfaceBrush}" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource TextPrimaryBrush}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DockPanel>
                        <ItemsControl x:Name="EventList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                        <Border Background="{DynamicResource BgBrush}" CornerRadius="12" Padding="16,12" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="48"/>
                                                <ColumnDefinition/>
                                                    <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                                <Border Width="40" Height="40" CornerRadius="20" Background="{DynamicResource SurfaceBrush}" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding EventTypeIcon}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" Margin="4,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}" FontWeight="Bold"
                                                               FontSize="14"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding Location}" FontSize="12"
                                                           Foreground="{DynamicResource TextMutedBrush}"/>
                                            </StackPanel>
                                                <Border Grid.Column="2" Background="{DynamicResource PrimaryLightBrush}" CornerRadius="8" Padding="10,6" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding StartTime, StringFormat='dd/MM HH:mm'}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource PrimaryBrush}"
                                                               TextAlignment="Center"/>
                                                </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock x:Name="TxtNoEvent"
                                   Text="Không có sự kiện nào trong 7 ngày tới."
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="14" FontStyle="Italic" HorizontalAlignment="Center"
                                   Margin="0,40" Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- 4 ô nhắc nhở checklist -->
                <Border Style="{StaticResource Card}" CornerRadius="16" Padding="0" Margin="0,20,0,0">
                    <StackPanel>
                        <Grid Margin="24,20,24,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/><ColumnDefinition Width="16"/><ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition Height="16"/><RowDefinition/>
                            </Grid.RowDefinitions>

                            <!-- Nhắc nhở hôm nay -->
                            <Border Grid.Row="0" Grid.Column="0" Background="{DynamicResource BgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="16">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Border Width="32" Height="32" CornerRadius="8" Background="#EFF6FF" Margin="0,0,10,0">
                                            <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#3B82F6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Nhắc nhở hôm nay" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ItemsControl x:Name="CheckToday">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding Title}" IsChecked="{Binding IsChecked, Mode=TwoWay}" Checked="OnReminderChecked" Unchecked="OnReminderChecked"
                                                          Tag="{Binding IdEvent}"
                                                          Foreground="#334155" FontSize="13" Margin="0,4"
                                                          Cursor="Hand"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock x:Name="TxtNoToday" Text="Không có nhắc nhở" FontStyle="Italic" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,6,0,0" Visibility="Collapsed"/>
                                </StackPanel>
                            </Border>

                            <!-- Nhắc nhở ngày mai -->
                            <Border Grid.Row="0" Grid.Column="2" Background="{DynamicResource BgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="16">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Border Width="32" Height="32" CornerRadius="8" Background="#FFF7ED" Margin="0,0,10,0">
                                            <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#F97316" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Nhắc nhở ngày mai" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ItemsControl x:Name="CheckTomorrow">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding Title}" IsChecked="{Binding IsChecked, Mode=TwoWay}" Checked="OnReminderChecked" Unchecked="OnReminderChecked"
                                                          Tag="{Binding IdEvent}"
                                                          Foreground="#334155" FontSize="13" Margin="0,4"
                                                          Cursor="Hand"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock x:Name="TxtNoTomorrow" Text="Không có nhắc nhở" FontStyle="Italic" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,6,0,0" Visibility="Collapsed"/>
                                </StackPanel>
                            </Border>

                            <!-- Nhắc nhở tuần này -->
                            <Border Grid.Row="2" Grid.Column="0" Background="{DynamicResource BgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="16">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Border Width="32" Height="32" CornerRadius="8" Background="#F0FDF4" Margin="0,0,10,0">
                                            <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#22C55E" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Nhắc nhở tuần này" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ItemsControl x:Name="CheckWeek">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding Title}" IsChecked="{Binding IsChecked, Mode=TwoWay}" Checked="OnReminderChecked" Unchecked="OnReminderChecked"
                                                          Tag="{Binding IdEvent}"
                                                          Foreground="#334155" FontSize="13" Margin="0,4"
                                                          Cursor="Hand"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock x:Name="TxtNoWeek" Text="Không có nhắc nhở" FontStyle="Italic" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,6,0,0" Visibility="Collapsed"/>
                                </StackPanel>
                            </Border>

                            <!-- Nhắc nhở theo tháng -->
                            <Border Grid.Row="2" Grid.Column="2" Background="{DynamicResource BgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="16">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Border Width="32" Height="32" CornerRadius="8" Background="#FDF4FF" Margin="0,0,10,0">
                                            <TextBlock Text="&#xE8BF;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#A855F7" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Nhắc nhở tháng này" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ItemsControl x:Name="CheckMonth">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding Title}" IsChecked="{Binding IsChecked, Mode=TwoWay}" Checked="OnReminderChecked" Unchecked="OnReminderChecked"
                                                          Tag="{Binding IdEvent}"
                                                          Foreground="#334155" FontSize="13" Margin="0,4"
                                                          Cursor="Hand"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock x:Name="TxtNoMonth" Text="Không có nhắc nhở" FontStyle="Italic" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,6,0,0" Visibility="Collapsed"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
                </StackPanel>

                <!-- Cột phải -->
                <StackPanel Grid.Column="2" VerticalAlignment="Top">
                    <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="16" Padding="24" Margin="0,0,0,24" MinHeight="350">
                        <StackPanel>
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,20">
                                <TextBlock Text="Lịch hôm nay" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </Border>
                            <ItemsControl x:Name="TodaySchedule">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource BgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                CornerRadius="12" Padding="16,14" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="{Binding TenMonHoc}" FontWeight="SemiBold"
                                                           FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0">
                                                    <Run Text="Thời gian: "/><Run Text="{Binding StartTime}"/>
                                                    <Run Text=" — "/><Run Text="{Binding TenPhong}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="TxtNoSchedule" Text="Hôm nay không có lịch học."
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14" FontStyle="Italic" HorizontalAlignment="Center"
                                       Margin="0,20" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="16" Padding="24" MinHeight="350">
                        <StackPanel>
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,20">
                                <TextBlock Text="Lịch ngày mai" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </Border>
                            <ItemsControl x:Name="TomorrowSchedule">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource BgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                CornerRadius="12" Padding="16,14" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="{Binding TenMonHoc}" FontWeight="SemiBold"
                                                           FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0">
                                                    <Run Text="Thời gian: "/><Run Text="{Binding StartTime}"/>
                                                    <Run Text=" — "/><Run Text="{Binding TenPhong}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="TxtNoScheduleTomorrow" Text="Ngày mai không có lịch học."
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14" FontStyle="Italic" HorizontalAlignment="Center"
                                       Margin="0,20" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>