<Page x:Class="StudentReminderApp.Views.Pages.ManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="ManagementPage" Background="{DynamicResource BgBrush}">
    <TabControl Margin="32" Background="Transparent" BorderThickness="0">
        <TabControl.Resources>
            <Style TargetType="TabItem">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border Name="Border" Padding="16,8" Margin="0,0,8,0" CornerRadius="8,8,0,0" Background="Transparent" BorderThickness="0,0,0,3" BorderBrush="Transparent">
                                <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="10,2"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource TextPrimaryBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </TabControl.Resources>
        
        <TabItem Header="Danh sách người dùng" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}">
            <Grid Margin="0,16,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="QUẢN LÝ NGƯỜI DÙNG" FontSize="28" FontWeight="Black" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
            <TextBlock Text="Xem thông tin và quản lý tất cả tài khoản trong hệ thống." FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"/>
        </StackPanel>

        <!-- Filters & Search Bar -->
        <Grid Grid.Row="1" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/> <!-- Search -->
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="200"/> <!-- Truong -->
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="180"/> <!-- Khoa -->
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="150"/> <!-- Lop -->
            </Grid.ColumnDefinitions>
            <!-- Search -->
            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="12" Padding="12,0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Height="42">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="🔍" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource TextMutedBrush}"/>
                    <TextBox Grid.Column="1" x:Name="TxtSearch" FontSize="14" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" VerticalContentAlignment="Center" TextChanged="TxtSearch_TextChanged"/>
                    <TextBlock Grid.Column="1" Text="Tìm MSSV hoặc Tên..." IsHitTestVisible="False" Foreground="{DynamicResource TextMutedBrush}" FontSize="14" VerticalAlignment="Center" Margin="2,0,0,0" x:Name="TxtSearchPlaceholder"/>
                </Grid>
            </Border>
            
            <!-- Filters -->
            <ComboBox Grid.Column="2" x:Name="CboFilterTruong" Style="{StaticResource ModernComboBox}" Height="42" FontSize="14" VerticalContentAlignment="Center" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" SelectionChanged="Filter_SelectionChanged">
                <ComboBoxItem Content="Tất cả trường" IsSelected="True"/>
                <ComboBoxItem Content="Trường ĐH Bách Khoa Đà Nẵng"/>
            </ComboBox>
            <ComboBox Grid.Column="4" x:Name="CboFilterKhoa" Style="{StaticResource ModernComboBox}" Height="42" FontSize="14" VerticalContentAlignment="Center" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" SelectionChanged="Filter_SelectionChanged">
                <ComboBoxItem Content="Tất cả khoa" IsSelected="True"/>
                <ComboBoxItem Content="Công Nghệ Thông Tin"/>
            </ComboBox>
            <ComboBox Grid.Column="6" x:Name="CboFilterLop" Style="{StaticResource ModernComboBox}" Height="42" FontSize="14" VerticalContentAlignment="Center" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" SelectionChanged="Filter_SelectionChanged">
                <ComboBoxItem Content="Tất cả lớp" IsSelected="True"/>
            </ComboBox>
        </Grid>

        <!-- DataGrid -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" ClipToBounds="True" Padding="10">
            <DataGrid x:Name="DgUsers" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column" Background="Transparent" RowHeight="50" ColumnHeaderHeight="40" BorderThickness="0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E2E8F0">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="10,0"/>
                    </Style>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#F1F5F9"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="10,0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="MSSV" Binding="{Binding Username}" Width="120" />
                    <DataGridTextColumn Header="Họ và tên" Binding="{Binding HoTen}" Width="*" />
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*" />
                    <DataGridTextColumn Header="Trường" Binding="{Binding TruongHoc}" Width="*" />
                    <DataGridTextColumn Header="Khoa" Binding="{Binding Khoa}" Width="*" />
                    <DataGridTextColumn Header="Lớp" Binding="{Binding TenLop}" Width="*" />
                    <DataGridTemplateColumn Header="Thao tác" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="Chi tiết" Background="#EFF6FF" Foreground="#2563EB" BorderThickness="0" Padding="12,6" Cursor="Hand" Click="BtnDetail_Click" Tag="{Binding}" Margin="0,0,8,0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Content="Xóa" Background="#FEF2F2" Foreground="#EF4444" BorderThickness="0" Padding="16,6" Cursor="Hand" Click="BtnDelete_Click" Tag="{Binding}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
            </Grid>
        </TabItem>

        <TabItem Header="Quản lý danh mục lõi" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}">
            <Grid Margin="0,16,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tiêu đề lớn đã được xóa vì bị thừa so với TabItem Header -->

                <!-- Thao tác -->
                <Grid Grid.Row="1" Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto" x:Name="ColNienKhoa"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <ComboBox Grid.Column="0" x:Name="CboCategory" Style="{StaticResource ModernComboBox}" Height="42" FontSize="14" VerticalContentAlignment="Center" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" SelectionChanged="CboCategory_SelectionChanged">
                        <ComboBoxItem Content="Trường Đại Học" Tag="TRUONG" IsSelected="True"/>
                        <ComboBoxItem Content="Khoa" Tag="KHOA"/>
                        <ComboBoxItem Content="Ngành Học" Tag="NGANH"/>
                        <ComboBoxItem Content="Lớp Sinh Hoạt" Tag="LOP"/>
                        <ComboBoxItem Content="Nhóm Hiện Tại" Tag="NHOM"/>
                    </ComboBox>

                    <TextBox Grid.Column="2" x:Name="TxtDanhMucValue" Height="42" FontSize="14" Padding="12,0" VerticalContentAlignment="Center" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" TextChanged="TxtDanhMucValue_TextChanged"/>
                    <TextBlock Grid.Column="2" Text="Nhập giá trị (cách nhau dấu phẩy để thêm nhiều)..." IsHitTestVisible="False" Foreground="{DynamicResource TextMutedBrush}" FontSize="14" VerticalAlignment="Center" Margin="14,0,0,0" x:Name="TxtDanhMucValuePlaceholder"/>

                    <TextBox Grid.Column="4" x:Name="TxtNienKhoa" Height="42" Width="150" FontSize="14" Padding="12,0" VerticalContentAlignment="Center" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Visibility="Collapsed" TextChanged="TxtNienKhoa_TextChanged"/>
                    <TextBlock Grid.Column="4" Text="Niên khóa (VD: 2024-2028)" IsHitTestVisible="False" Foreground="{DynamicResource TextMutedBrush}" FontSize="14" VerticalAlignment="Center" Margin="14,0,0,0" x:Name="TxtNienKhoaPlaceholder" Visibility="Collapsed"/>

                    <Grid Grid.Column="4" x:Name="SpJsonFile" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="TxtJsonFile" Height="42" Width="150" FontSize="14" Padding="12,0" VerticalContentAlignment="Center" Background="#F1F5F9" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" IsReadOnly="True"/>
                        <TextBlock Grid.Column="0" Text="Đính kèm JSON..." IsHitTestVisible="False" Foreground="{DynamicResource TextMutedBrush}" FontSize="14" VerticalAlignment="Center" Margin="14,0,0,0" x:Name="TxtJsonFilePlaceholder"/>
                        <Button Grid.Column="2" Content="Chọn File" Height="42" Padding="12,0" Background="#3B82F6" Foreground="{DynamicResource SurfaceBrush}" BorderThickness="0" Cursor="Hand" Click="BtnSelectJson_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <StackPanel Grid.Column="6" Orientation="Horizontal">
                        <Button Content="Thêm" Background="#10B981" Foreground="{DynamicResource SurfaceBrush}" FontWeight="Bold" Height="42" Padding="24,0" BorderThickness="0" Cursor="Hand" Click="BtnAddDanhMuc_Click" Margin="0,0,8,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="Cập nhật" Background="#F59E0B" Foreground="{DynamicResource SurfaceBrush}" FontWeight="Bold" Height="42" Padding="24,0" BorderThickness="0" Cursor="Hand" Click="BtnUpdateDanhMuc_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- DataGrid -->
                <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" ClipToBounds="True" Padding="10">
                    <DataGrid x:Name="DgDanhMuc" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column" Background="Transparent" RowHeight="50" ColumnHeaderHeight="40" BorderThickness="0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E2E8F0" SelectionChanged="DgDanhMuc_SelectionChanged">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="10,0"/>
                            </Style>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#F1F5F9"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80" />
                            <DataGridTextColumn Header="Giá trị danh mục" Binding="{Binding Value}" Width="*" />
                            <DataGridTextColumn Header="Niên khóa (Lớp)" Binding="{Binding NienKhoa}" Width="150" />
                            <DataGridTemplateColumn Header="Thao tác" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Xóa" Background="#FEF2F2" Foreground="#EF4444" BorderThickness="0" Padding="16,6" Cursor="Hand" Click="BtnDeleteDanhMuc_Click" Tag="{Binding}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </TabItem>
    </TabControl>
</Page>
