<Page x:Class="StudentReminderApp.Views.Pages.ManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="ManagementPage" Background="{DynamicResource BgBrush}">
    <TabControl Margin="32" Background="Transparent" BorderThickness="0">
        <TabControl.Resources>
            <Style TargetType="TabItem">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border Name="Border" Padding="16,8" Margin="0,0,8,0" CornerRadius="8,8,0,0" Background="Transparent" BorderThickness="0,0,0,3" BorderBrush="Transparent">
                                <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="10,2"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource TextPrimaryBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </TabControl.Resources>
        
        <TabItem Header="Danh sách người dùng" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}">
            <Grid Margin="0,16,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="QUẢN LÝ NGƯỜI DÙNG" FontSize="28" FontWeight="Black" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
            <TextBlock Text="Xem thông tin và quản lý tất cả tài khoản trong hệ thống." FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"/>
        </StackPanel>

        <!-- Filters & Search Bar -->
        <Grid Grid.Row="1" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/> <!-- Search -->
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="200"/> <!-- Truong -->
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="180"/> <!-- Khoa -->
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="150"/> <!-- Lop -->
            </Grid.ColumnDefinitions>
            <!-- Search -->
            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="12" Padding="12,0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Height="42">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="🔍" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource TextMutedBrush}"/>
                    <TextBox Grid.Column="1" x:Name="TxtSearch" FontSize="14" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" VerticalContentAlignment="Center" TextChanged="TxtSearch_TextChanged"/>
                    <TextBlock Grid.Column="1" Text="Tìm MSSV hoặc Tên..." IsHitTestVisible="False" Foreground="{DynamicResource TextMutedBrush}" FontSize="14" VerticalAlignment="Center" Margin="2,0,0,0" x:Name="TxtSearchPlaceholder"/>
                </Grid>
            </Border>
            
            <!-- Filters -->
            <ComboBox Grid.Column="2" x:Name="CboFilterTruong" Style="{StaticResource ModernComboBox}" Height="42" FontSize="14" VerticalContentAlignment="Center" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" SelectionChanged="Filter_SelectionChanged">
                <ComboBoxItem Content="Tất cả trường" IsSelected="True"/>
                <ComboBoxItem Content="Trường ĐH Bách Khoa Đà Nẵng"/>
            </ComboBox>
            <ComboBox Grid.Column="4" x:Name="CboFilterKhoa" Style="{StaticResource ModernComboBox}" Height="42" FontSize="14" VerticalContentAlignment="Center" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" SelectionChanged="Filter_SelectionChanged">
                <ComboBoxItem Content="Tất cả khoa" IsSelected="True"/>
                <ComboBoxItem Content="Công Nghệ Thông Tin"/>
            </ComboBox>
            <ComboBox Grid.Column="6" x:Name="CboFilterLop" Style="{StaticResource ModernComboBox}" Height="42" FontSize="14" VerticalContentAlignment="Center" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" SelectionChanged="Filter_SelectionChanged">
                <ComboBoxItem Content="Tất cả lớp" IsSelected="True"/>
            </ComboBox>
        </Grid>

        <!-- DataGrid -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" ClipToBounds="True" Padding="10">
            <DataGrid x:Name="DgUsers" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column" Background="Transparent" RowHeight="50" ColumnHeaderHeight="40" BorderThickness="0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource BorderBrush}">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="10,0"/>
                    </Style>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BgBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="10,0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="MSSV" Binding="{Binding Username}" Width="120" />
                    <DataGridTextColumn Header="Họ và tên" Binding="{Binding HoTen}" Width="*" />
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*" />
                    <DataGridTextColumn Header="Trường" Binding="{Binding TruongHoc}" Width="*" />
                    <DataGridTextColumn Header="Khoa" Binding="{Binding Khoa}" Width="*" />
                    <DataGridTextColumn Header="Lớp" Binding="{Binding TenLop}" Width="*" />
                    <DataGridTemplateColumn Header="Thao tác" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="Chi tiết" Background="#EFF6FF" Foreground="#2563EB" BorderThickness="0" Padding="12,6" Cursor="Hand" Click="BtnDetail_Click" Tag="{Binding}" Margin="0,0,8,0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Content="Xóa" Background="#FEF2F2" Foreground="#EF4444" BorderThickness="0" Padding="16,6" Cursor="Hand" Click="BtnDelete_Click" Tag="{Binding}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
            </Grid>
        </TabItem>

        <TabItem Header="Quản lý danh mục lõi" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}">
            <Grid Margin="0,16,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="Cấu trúc Tổ chức (Trường -> Khoa -> Ngành -> Lớp -> Nhóm)" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <Button Content="Lưu Thay Đổi" Background="#10B981" Foreground="White" FontWeight="Bold" Height="40" Padding="20,0" BorderThickness="0" Cursor="Hand" Click="BtnSaveOrg_Click" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Cột Trường -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Trường" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <ListBox x:Name="LstTruong" Grid.Row="1" DisplayMemberPath="Name" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" SelectionChanged="LstTruong_SelectionChanged" Margin="0,0,0,8"/>
                        <Button Grid.Row="2" Content="Xóa chọn" Background="#FEF2F2" Foreground="#EF4444" BorderThickness="0" Margin="0,0,0,8" Padding="0,5" Click="BtnDelTruong_Click"/>
                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtNewTruong" Margin="0,0,4,0" Padding="4"/>
                            <Button Grid.Column="1" Content="+" Width="30" Background="#3B82F6" Foreground="White" BorderThickness="0" Click="BtnAddTruong_Click"/>
                        </Grid>
                    </Grid>

                    <!-- Cột Khoa -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Khoa" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <ListBox x:Name="LstKhoa" Grid.Row="1" DisplayMemberPath="Name" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" SelectionChanged="LstKhoa_SelectionChanged" Margin="0,0,0,8"/>
                        <Button Grid.Row="2" Content="Xóa chọn" Background="#FEF2F2" Foreground="#EF4444" BorderThickness="0" Margin="0,0,0,8" Padding="0,5" Click="BtnDelKhoa_Click"/>
                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtNewKhoa" Margin="0,0,4,0" Padding="4"/>
                            <Button Grid.Column="1" Content="+" Width="30" Background="#3B82F6" Foreground="White" BorderThickness="0" Click="BtnAddKhoa_Click"/>
                        </Grid>
                    </Grid>

                    <!-- Cột Ngành -->
                    <Grid Grid.Column="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Ngành" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <ListBox x:Name="LstNganh" Grid.Row="1" DisplayMemberPath="Name" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" SelectionChanged="LstNganh_SelectionChanged" Margin="0,0,0,8"/>
                        <Button Grid.Row="2" Content="Xóa chọn" Background="#FEF2F2" Foreground="#EF4444" BorderThickness="0" Margin="0,0,0,8" Padding="0,5" Click="BtnDelNganh_Click"/>
                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtNewNganh" Margin="0,0,4,0" Padding="4"/>
                            <Button Grid.Column="1" Content="+" Width="30" Background="#3B82F6" Foreground="White" BorderThickness="0" Click="BtnAddNganh_Click"/>
                        </Grid>
                    </Grid>

                    <!-- Cột Lớp -->
                    <Grid Grid.Column="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Lớp" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <ListBox x:Name="LstLop" Grid.Row="1" DisplayMemberPath="Name" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" SelectionChanged="LstLop_SelectionChanged" Margin="0,0,0,8"/>
                        <Button Grid.Row="2" Content="Xóa chọn" Background="#FEF2F2" Foreground="#EF4444" BorderThickness="0" Margin="0,0,0,8" Padding="0,5" Click="BtnDelLop_Click"/>
                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtNewLop" Margin="0,0,4,0" Padding="4"/>
                            <Button Grid.Column="1" Content="+" Width="30" Background="#3B82F6" Foreground="White" BorderThickness="0" Click="BtnAddLop_Click"/>
                        </Grid>
                    </Grid>

                    <!-- Cột Nhóm -->
                    <Grid Grid.Column="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Nhóm" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <ListBox x:Name="LstNhom" Grid.Row="1" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,8"/>
                        <Button Grid.Row="2" Content="Xóa chọn" Background="#FEF2F2" Foreground="#EF4444" BorderThickness="0" Margin="0,0,0,8" Padding="0,5" Click="BtnDelNhom_Click"/>
                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtNewNhom" Margin="0,0,4,0" Padding="4"/>
                            <Button Grid.Column="1" Content="+" Width="30" Background="#3B82F6" Foreground="White" BorderThickness="0" Click="BtnAddNhom_Click"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </TabItem>
    </TabControl>
</Page>
