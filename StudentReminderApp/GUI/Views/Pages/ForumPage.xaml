<UserControl
    x:Class="StudentReminderApp.Views.Pages.ForumPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:fa="http://schemas.fontawesome.io/icons/"
    xmlns:vm="clr-namespace:StudentReminderApp.ViewModels"
    Background="{DynamicResource BgBrush}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#65676B" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource BgBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E4E6EB" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <UserControl.DataContext>
        <vm:ForumViewModel />
    </UserControl.DataContext>

    <!-- ═══════════════════════════════════════════════════════
         TabControl: Tab 1 = Diễn đàn (cũ), Tab 2 = Duyệt bài (Admin)
         ═══════════════════════════════════════════════════════ -->
    <TabControl Background="Transparent" BorderThickness="0" Margin="10,0,10,0">
        <TabControl.Resources>
            <Style TargetType="TabItem">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border Name="Border" Padding="16,8" Margin="0,0,8,0" CornerRadius="8,8,0,0" Background="Transparent" BorderThickness="0,0,0,3" BorderBrush="Transparent">
                                <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="10,2"/>
                            </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource TextPrimaryBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource SurfaceBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        </TabControl.Resources>

        <!-- ══════════════════════════════════════════
             TAB 1: DIỄN ĐÀN — giữ nguyên giao diện cũ
             ══════════════════════════════════════════ -->
        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <fa:ImageAwesome Icon="Home" Width="16" Height="16" Margin="0,0,8,0" Foreground="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=Foreground}"/>
                    <TextBlock Text="Diễn đàn"/>
                </StackPanel>
            </TabItem.Header>
            <Grid>
                <!-- YÊU CẦU XÁC THỰC THẺ SINH VIÊN -->
                <Border x:Name="VerificationOverlay" Background="{DynamicResource SurfaceBrush}" Panel.ZIndex="10" Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="400">
                        <TextBlock Text="🔒 Diễn đàn bị khóa" FontSize="28" FontWeight="Bold" Foreground="#1C1E21" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock x:Name="TxtVerificationStatus" Text="Để bảo vệ cộng đồng sinh viên an toàn, bạn cần tải lên ảnh thẻ sinh viên để Quản trị viên duyệt trước khi có thể đọc và tham gia diễn đàn." FontSize="15" Foreground="#65676B" TextAlignment="Center" TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,0,0,25"/>
                        
                        <Image x:Name="ImgIdCardPreview" Height="150" Margin="0,0,0,20" Stretch="Uniform" Visibility="Collapsed"/>
                        
                        <Button x:Name="BtnUploadIdCard" Content="Tải lên ảnh Thẻ Sinh Viên" Padding="15,12" Background="{DynamicResource TextPrimaryBrush}" Foreground="{DynamicResource SurfaceBrush}" FontSize="15" FontWeight="SemiBold" Cursor="Hand" Click="BtnUploadIdCard_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>

                <Grid x:Name="MainGrid">
                    <ScrollViewer
                        x:Name="PostScrollViewer"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="MainStackPanel">

                        <!-- HEADER ảnh bìa — GIỮ NGUYÊN -->
                        <Border
                            x:Name="HeaderBorder"
                            Background="#2D3436"
                            ClipToBounds="True"
                            CornerRadius="0,0,20,20">
                            <Grid>
                                <Image
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Top"
                                    Source="/GUI/Resources/Images/APUIp.jpg"
                                    Stretch="Uniform" />
                                <Border Height="120" VerticalAlignment="Bottom">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Offset="0" Color="Transparent" />
                                            <GradientStop Offset="1" Color="#CC000000" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <StackPanel Margin="40,0,40,25" VerticalAlignment="Bottom">
                                    <TextBlock
                                        FontSize="32"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource SurfaceBrush}"
                                        Text="Nhóm Sinh viên Đại học">
                                        <TextBlock.Effect>
                                            <DropShadowEffect BlurRadius="10" Opacity="0.8" ShadowDepth="2" />
                                        </TextBlock.Effect>
                                    </TextBlock>
                                    <TextBlock
                                        FontSize="14"
                                        Foreground="{DynamicResource BorderBrush}"
                                        Text="Chia sẻ kiến thức • Kết nối bạn bè" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Ô tạo bài viết — GIỮ NGUYÊN -->
                        <Border
                            x:Name="CreatePostArea"
                            MaxWidth="500"
                            Margin="0,20,0,20"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                            <Grid Margin="15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border
                                    Width="45" Height="45"
                                    Margin="0,0,12,0"
                                    ClipToBounds="True"
                                    CornerRadius="22.5">
                                    <Image Source="/GUI/Resources/Images/user.png" Stretch="UniformToFill" />
                                </Border>
                                <Border
                                    x:Name="PostInputTrigger"
                                    Grid.Column="1"
                                    Height="45"
                                    Background="{DynamicResource BgBrush}"
                                    CornerRadius="22.5"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="OpenCreatePost_Click">
                                    <TextBlock
                                        Margin="20,0,20,0"
                                        VerticalAlignment="Center"
                                        FontSize="15"
                                        Foreground="#65676B"
                                        Text="Bạn đang nghĩ gì?" />
                                </Border>
                                <Button
                                    x:Name="BtnCreatePost"
                                    Grid.Column="2"
                                    Margin="12,0,0,0"
                                    Background="{DynamicResource TextPrimaryBrush}"
                                    Click="OpenCreatePost_Click"
                                    Content="Đăng bài"
                                    Cursor="Hand"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource SurfaceBrush}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border
                                                Padding="15,0,15,0"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="18">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- ══ THANH LỌC DANH MỤC ══════════════════════════════ -->
                        <Border MaxWidth="500" Margin="0,0,0,12">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled">
                                <StackPanel Orientation="Horizontal" Margin="4,0">

                                    <!-- Nút TẤT CẢ -->
                                    <Button Margin="0,0,8,0" Cursor="Hand"
                                            Command="{Binding SelectAllCommand}"
                                            BorderThickness="0">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                                <Setter Property="Foreground" Value="#65676B"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="FontSize" Value="13"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Padding="16,8"
                                                                    Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    CornerRadius="20">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAllSelected}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource TextPrimaryBrush}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource SurfaceBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="🌐 Tất cả"/>
                                    </Button>

                                    <!-- Nút HOT -->
                                    <Button Margin="0,0,8,0" Cursor="Hand"
                                            Command="{Binding SelectHotCommand}"
                                            BorderThickness="0">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                                <Setter Property="Foreground" Value="#65676B"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="FontSize" Value="13"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Padding="16,8"
                                                                    Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    CornerRadius="20">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsHotSelected}" Value="True">
                                                        <Setter Property="Background" Value="#FF5722"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource SurfaceBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="🔥 HOT"/>
                                    </Button>

                                    <!-- Nút DIỄN ĐÀN SV -->
                                    <Button Margin="0,0,8,0" Cursor="Hand"
                                            Command="{Binding SelectStudentCommand}"
                                            BorderThickness="0">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                                <Setter Property="Foreground" Value="#65676B"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="FontSize" Value="13"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Padding="16,8"
                                                                    Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    CornerRadius="20">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsStudentSelected}" Value="True">
                                                        <Setter Property="Background" Value="#4CAF50"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource SurfaceBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="🎓 Diễn đàn SV"/>
                                    </Button>

                                    <!-- Nút BẢNG TIN TRƯỜNG -->
                                    <Button Cursor="Hand"
                                            Command="{Binding SelectAnnouncementCommand}"
                                            BorderThickness="0">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                                <Setter Property="Foreground" Value="#65676B"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="FontSize" Value="13"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Padding="16,8"
                                                                    Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    CornerRadius="20">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAnnouncementSelected}" Value="True">
                                                        <Setter Property="Background" Value="#9C27B0"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource SurfaceBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="📢 Bảng tin trường"/>
                                    </Button>

                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <!-- DANH SÁCH BÀI VIẾT — GIỮ NGUYÊN + thêm nút Admin Delete -->
                        <ItemsControl
                            x:Name="ForumPostsControl"
                            MaxWidth="500"
                            Margin="0,0,0,30"
                            ItemsSource="{Binding Posts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="0,0,0,15"
                                        Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Header: Avatar + Tên + Nút xóa -->
                                            <Border Grid.Row="0" Padding="15,12,15,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border
                                                        Width="40" Height="40"
                                                        ClipToBounds="True"
                                                        CornerRadius="20">
                                                        <Image Source="{Binding DisplayAvatar}" Stretch="UniformToFill" />
                                                    </Border>
                                                    <StackPanel
                                                        Grid.Column="1"
                                                        Margin="12,0,12,0"
                                                        VerticalAlignment="Center">
                                                        <TextBlock
                                                            FontSize="15" FontWeight="Bold"
                                                            Foreground="#050505"
                                                            Text="{Binding DisplayName}" />
                                                        <TextBlock
                                                            FontSize="12" Foreground="#65676B"
                                                            Text="{Binding TimeAgo}" />
                                                    </StackPanel>

                                                    <!-- Nút 3 chấm: hiện khi là bài của mình HOẶC là Admin -->
                                                    <Button
                                                        Grid.Column="2"
                                                        Width="32" Height="32"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Click="OptionButton_Click"
                                                        Cursor="Hand"
                                                        FontSize="18"
                                                        Foreground="#65676B"
                                                        Visibility="{Binding CanDelete, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border
                                                                    Background="{TemplateBinding Background}"
                                                                    CornerRadius="16">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Style.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter Property="Background" Value="{DynamicResource BgBrush}" />
                                                                                </Trigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                        <Button.ContextMenu>
                                                            <ContextMenu>
                                                                <!-- Xóa bài của mình (User thường) -->
                                                                <MenuItem
                                                                    Command="{Binding DataContext.DeletePostCommand,
                                                                              Source={x:Reference ForumPostsControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    FontWeight="SemiBold"
                                                                    Foreground="#E53935"
                                                                    Header="🗑️  Xóa bài viết"
                                                                    Visibility="{Binding IsMyPost, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                                <!-- Xóa bài bất kỳ (Admin) -->
                                                                <MenuItem
                                                                    Command="{Binding DataContext.AdminDeleteCommand,
                                                                              Source={x:Reference ForumPostsControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    FontWeight="SemiBold"
                                                                    Foreground="#B71C1C"
                                                                    Header="🛡️  Xóa (Admin)"
                                                                    Visibility="{Binding DataContext.IsAdmin,
                                                                                  Source={x:Reference ForumPostsControl},
                                                                                  Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                            </ContextMenu>
                                                        </Button.ContextMenu>
                                                        <TextBlock Text="···" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                                                    </Button>
                                                </Grid>
                                            </Border>

                                            <!-- Nội dung bài — GIỮ NGUYÊN -->
                                            <Border Grid.Row="1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsColored}" Value="True">
                                                                <Setter Property="Background" Value="{Binding BackgroundColor}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock
                                                    Margin="15,5,15,10"
                                                    LineHeight="22"
                                                    Text="{Binding Content}"
                                                    TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="FontSize" Value="15" />
                                                            <Setter Property="Foreground" Value="#050505" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsColored}" Value="True">
                                                                    <Setter Property="FontSize" Value="24" />
                                                                    <Setter Property="FontWeight" Value="Bold" />
                                                                    <Setter Property="Foreground" Value="{DynamicResource SurfaceBrush}" />
                                                                    <Setter Property="TextAlignment" Value="Center" />
                                                                    <Setter Property="Margin" Value="30,60,30,60" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>

                                            <!-- Ảnh đính kèm — GIỮ NGUYÊN -->
                                            <ItemsControl Grid.Row="2" ItemsSource="{Binding ImagePaths}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="{DynamicResource BgBrush}" BorderThickness="0,1,0,1">
                                                            <Image MaxHeight="500" Source="{Binding}" Stretch="Uniform" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Bài gốc (share) — GIỮ NGUYÊN -->
                                            <Border
                                                Grid.Row="3"
                                                Margin="15,10,15,0"
                                                Padding="12"
                                                Background="{DynamicResource BgBrush}"
                                                BorderBrush="#CED0D4"
                                                BorderThickness="1"
                                                CornerRadius="10">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsShared}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <TextBlock
                                                        Margin="0,0,0,5"
                                                        FontWeight="Bold"
                                                        Foreground="#050505"
                                                        Text="{Binding OriginalPost.DisplayName}" />
                                                    <TextBlock
                                                        MaxHeight="60"
                                                        Foreground="#050505"
                                                        Text="{Binding OriginalPost.Content}"
                                                        TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>

                                            <!-- Thống kê like/comment/share — GIỮ NGUYÊN -->
                                            <StackPanel Grid.Row="4" Margin="15,10,15,5">
                                                <DockPanel LastChildFill="False">
                                                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                                        <TextBlock FontSize="13" Text="👍 " />
                                                        <TextBlock
                                                            FontSize="13" Foreground="#65676B"
                                                            Text="{Binding Likes, StringFormat='{}{0} lượt thích'}" />
                                                    </StackPanel>
                                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                        <TextBlock
                                                            FontSize="13" Foreground="#65676B"
                                                            Text="{Binding CommentCount, StringFormat='{}{0} bình luận'}" />
                                                        <TextBlock
                                                            Margin="5,0,5,0" VerticalAlignment="Center"
                                                            Foreground="#65676B" Text=" • " />
                                                        <TextBlock
                                                            FontSize="13" Foreground="#65676B"
                                                            Text="{Binding ShareCount, StringFormat='{}{0} chia sẻ'}" />
                                                    </StackPanel>
                                                </DockPanel>
                                                <Rectangle Height="1" Margin="0,8,0,0" Fill="{DynamicResource BorderBrush}" />
                                            </StackPanel>

                                            <!-- Nút hành động Like/Bình luận/Chia sẻ — GIỮ NGUYÊN -->
                                            <UniformGrid Grid.Row="5" Margin="5,0,5,5" Columns="3">
                                                <Button
                                                    Command="{Binding DataContext.LikeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsLiked}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="👍 " />
                                                        <TextBlock FontWeight="SemiBold" Text="Thích" />
                                                    </StackPanel>
                                                </Button>

                                                <Button
                                                    Style="{StaticResource ActionButtonStyle}"
                                                    Click="CommentButton_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="💬 " />
                                                        <TextBlock FontWeight="SemiBold" Text="Bình luận" />
                                                    </StackPanel>
                                                </Button>

                                                <Button
                                                    Style="{StaticResource ActionButtonStyle}"
                                                    Click="ShareButton_Click"
                                                    CommandParameter="{Binding}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="↪️ " />
                                                        <TextBlock FontWeight="SemiBold" Text="Chia sẻ" />
                                                    </StackPanel>
                                                </Button>
                                            </UniformGrid>

                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
            </Grid>
        </TabItem>

        <!-- ══════════════════════════════════════════════════════
             TAB 2: DUYỆT BÀI — CHỈ HIỆN KHI IsAdmin = true
             ══════════════════════════════════════════════════════ -->
        <TabItem Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <fa:ImageAwesome Icon="Shield" Width="16" Height="16" Margin="0,0,8,0" Foreground="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=Foreground}"/>
                    <TextBlock Text="Duyệt bài"/>
                </StackPanel>
            </TabItem.Header>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Toolbar Admin -->
                <Border Grid.Row="0" Background="#FFF3E0" Padding="16,10">
                    <DockPanel LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="14" FontWeight="SemiBold"
                                Foreground="Black"
                                Text="🛡️ Bài chờ duyệt: " />
                            <Border
                                Margin="4,0,0,0" Padding="8,2"
                                Background="#E65100" CornerRadius="10">
                                <TextBlock
                                    FontWeight="Bold" Foreground="{DynamicResource SurfaceBrush}"
                                    Text="{Binding PendingPosts.Count}" />
                            </Border>
                        </StackPanel>
                        <Button
                            DockPanel.Dock="Right"
                            Padding="14,6"
                            Background="{DynamicResource TextPrimaryBrush}"
                            Click="RefreshPending_Click"
                            Cursor="Hand"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource SurfaceBrush}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border
                                        Padding="{TemplateBinding Padding}"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="🔄 Làm mới" />
                        </Button>
                    </DockPanel>
                </Border>

                <!-- Danh sách bài chờ duyệt -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding PendingPosts}" Margin="0,10,0,20">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    MaxWidth="600"
                                    Margin="20,0,20,12"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="#FF9800"
                                    BorderThickness="2"
                                    CornerRadius="12">
                                    <StackPanel Margin="15">

                                        <!-- Header: Badge + Tên + Thời gian -->
                                        <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                                            <Border Background="#FFF3E0" CornerRadius="6" Padding="8,3">
                                                <TextBlock
                                                    FontSize="11" FontWeight="Bold"
                                                    Foreground="#E65100"
                                                    Text="⏳ CHỜ DUYỆT" />
                                            </Border>
                                            <TextBlock
                                                Margin="10,0,0,0"
                                                VerticalAlignment="Center"
                                                FontWeight="SemiBold"
                                                Text="{Binding DisplayName}" />
                                            <TextBlock
                                                Margin="6,0,0,0"
                                                VerticalAlignment="Center"
                                                FontSize="12" Foreground="#65676B"
                                                Text="{Binding TimeAgo}" />
                                        </StackPanel>

                                        <!-- Nội dung -->
                                        <TextBlock
                                            Margin="0,0,0,10"
                                            FontSize="14"
                                            Text="{Binding Content}"
                                            TextWrapping="Wrap" />

                                        <!-- Ảnh (nếu có) -->
                                        <ItemsControl ItemsSource="{Binding ImagePaths}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Image
                                                        Margin="0,0,0,8"
                                                        MaxHeight="200"
                                                        Source="{Binding}"
                                                        Stretch="Uniform" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <Rectangle Height="1" Margin="0,8,0,10" Fill="{DynamicResource BorderBrush}" />

                                        <!-- Nút hành động Admin -->
                                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">

                                            <!-- Nút DUYỆT -->
                                            <Button
                                                Margin="0,0,8,0"
                                                Padding="16,8"
                                                Background="#4CAF50"
                                                Command="{Binding DataContext.ApprovePostCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Cursor="Hand"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource SurfaceBrush}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border
                                                            Padding="{TemplateBinding Padding}"
                                                            Background="{TemplateBinding Background}"
                                                            CornerRadius="8">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <TextBlock Text="✅ Duyệt bài" />
                                            </Button>

                                            <!-- Nút TỪ CHỐI -->
                                            <Button
                                                Margin="0,0,8,0"
                                                Padding="16,8"
                                                Background="#FF9800"
                                                Command="{Binding DataContext.RejectPostCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Cursor="Hand"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource SurfaceBrush}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border
                                                            Padding="{TemplateBinding Padding}"
                                                            Background="{TemplateBinding Background}"
                                                            CornerRadius="8">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <TextBlock Text="🚫 Từ chối" />
                                            </Button>

                                            <!-- Nút XÓA -->
                                            <Button
                                                Padding="16,8"
                                                Background="#F44336"
                                                Command="{Binding DataContext.AdminDeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Cursor="Hand"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource SurfaceBrush}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border
                                                            Padding="{TemplateBinding Padding}"
                                                            Background="{TemplateBinding Background}"
                                                            CornerRadius="8">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <TextBlock Text="🗑️ Xóa bài" />
                                            </Button>
                                        </StackPanel>

                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

            </Grid>
        </TabItem>

        <!-- ══════════════════════════════════════════════════════
             TAB 3: QUẢN LÝ — CHỈ HIỆN KHI IsAdmin = true
             ══════════════════════════════════════════════════════ -->
        <TabItem Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <fa:ImageAwesome Icon="Users" Width="16" Height="16" Margin="0,0,8,0" Foreground="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=Foreground}"/>
                    <TextBlock Text="Quản lý"/>
                </StackPanel>
            </TabItem.Header>
            <Frame NavigationUIVisibility="Hidden"
                   Source="/GUI/Views/Pages/StudentManagementPage.xaml"/>
        </TabItem>

        <!-- ══════════════════════════════════════════════════════
             TAB 4: NHẬT KÝ DIỄN ĐÀN — CHỈ HIỆN KHI IsAdmin = true
             ══════════════════════════════════════════════════════ -->
        <TabItem Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <fa:ImageAwesome Icon="ListAlt" Width="16" Height="16" Margin="0,0,8,0" Foreground="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=Foreground}"/>
                    <TextBlock Text="Nhật ký"/>
                </StackPanel>
            </TabItem.Header>
            <Frame NavigationUIVisibility="Hidden"
                   Source="/GUI/Views/Pages/ForumLogPage.xaml"/>
        </TabItem>

    </TabControl>
</UserControl>
