<Window x:Class="StudentReminderApp.Views.Main.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Student Reminder &amp; Advisor"
        Height="720" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <DockPanel>
                <!-- Logo -->
                <StackPanel DockPanel.Dock="Top" Margin="0,24,0,32" HorizontalAlignment="Center">
                    <Border Width="46" Height="46" CornerRadius="16" Background="#FFD15858">
                        <TextBlock Text="S" Foreground="White" FontSize="26" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <!-- Ẩn text nhưng vẫn giữ x:Name để không lỗi code-behind -->
                    <TextBlock x:Name="TxtUserName" Visibility="Collapsed"/>
                </StackPanel>

                <!-- Nav items -->
                <StackPanel DockPanel.Dock="Top" Margin="8,0">
                    <Button x:Name="BtnDashboard" Tag="Dashboard" Click="NavBtn_Click"
                            Style="{StaticResource NavBtnActive}" ToolTip="Tổng quan" Height="50" Margin="0,0,0,10">
                        <TextBlock Text="🏠" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Button x:Name="BtnCalendar" Tag="Calendar" Click="NavBtn_Click"
                            Style="{StaticResource NavBtn}" ToolTip="Lịch học" Height="50" Margin="0,0,0,10">
                        <TextBlock Text="📅" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Button x:Name="BtnCourse" Tag="Course" Click="NavBtn_Click"
                            Style="{StaticResource NavBtn}" ToolTip="Học phần" Height="50" Margin="0,0,0,10">
                        <TextBlock Text="📚" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Button x:Name="BtnAdvisor" Tag="Advisor" Click="NavBtn_Click"
                            Style="{StaticResource NavBtn}" ToolTip="Tư vấn ĐKHP" Height="50" Margin="0,0,0,10">
                        <TextBlock Text="🎯" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Button x:Name="BtnForum" Tag="Forum" Click="NavBtn_Click"
                            Style="{StaticResource NavBtn}" ToolTip="Diễn đàn" Height="50" Margin="0,0,0,10">
                        <TextBlock Text="💬" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Button x:Name="BtnProfile" Tag="Profile" Click="NavBtn_Click"
                            Style="{StaticResource NavBtn}" ToolTip="Hồ sơ cá nhân" Height="50" Margin="0,0,0,10">
                        <TextBlock Text="👤" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>

                <!-- Logout -->
                <Button DockPanel.Dock="Bottom"
                        Click="BtnLogout_Click"
                        Margin="8,0,8,24"
                        Style="{StaticResource NavBtnDanger}" ToolTip="Đăng xuất" Height="50">
                    <TextBlock Text="🚪" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>

                <StackPanel/>
            </DockPanel>
        </Border>

        <!-- CONTENT FRAME -->
        <Frame x:Name="ContentFrame"
               Grid.Column="1"
               NavigationUIVisibility="Hidden"
               Background="{StaticResource BgBrush}"/>
    </Grid>
</Window>