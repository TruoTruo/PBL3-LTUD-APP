<Window x:Class="StudentReminderApp.Views.Auth.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng nhập — Student Reminder"
        Height="680" Width="1060"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseDown="Window_MouseDown">

    <!-- Nền của toàn app được bo góc và có màu xám đậm hơn (#E2E8F0) -->
    <Border Background="#E2E8F0" CornerRadius="24" Opacity="0">
        <Border.RenderTransform>
            <TranslateTransform Y="30"/>
        </Border.RenderTransform>
        <Border.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.6"/>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="30" To="0" Duration="0:0:0.6">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Thanh tiêu đề giả lập (Title Bar) -->
            <Grid Grid.Row="0">
                <TextBlock Text="Đăng nhập — Student Reminder" VerticalAlignment="Center" Margin="24,0,0,0" Foreground="#64748B" FontWeight="SemiBold" FontSize="13"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,16,0">
                    <Button Content="—" Width="30" Height="30" Background="Transparent" BorderThickness="0" 
                            FontSize="16" Foreground="Gray" Cursor="Hand" Click="BtnMinimize_Click"/>
                    <Button Content="✕" Width="30" Height="30" Background="Transparent" BorderThickness="0" 
                            FontSize="14" Foreground="Gray" Cursor="Hand" Click="BtnClose_Click"/>
                </StackPanel>
            </Grid>

            <!-- Nội dung chính (Cột trái & Form màu trắng) -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="480"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0">
                    <StackPanel VerticalAlignment="Center" Margin="56,0,56,40">
                        <TextBlock Text="Student Reminder" FontSize="32" FontWeight="Bold"
                                   Foreground="Black" Margin="0,0,0,8"/>
                        <TextBlock Text="&amp; Advisor" FontSize="22" FontWeight="Light"
                                   Foreground="#64748B" Margin="0,0,0,32"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="White" CornerRadius="20" Margin="16,0,16,16">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="25" ShadowDepth="4" Opacity="0.15" Direction="270"/>
                    </Border.Effect>
                    <Grid VerticalAlignment="Center" Margin="40">
                            <StackPanel>
                                <Border Width="80" Height="80" CornerRadius="20" Background="#FFD15858" HorizontalAlignment="Center" Margin="0,0,0,10">
                                    <TextBlock Text="S" FontSize="40" FontWeight="Black" Foreground="{DynamicResource ThemePrimaryColor}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <!-- <TextBlock Text="✦" FontSize="32" Foreground="Black" HorizontalAlignment="Center" Margin="0,0,0,10"/> -->

                                <TextBlock Text="Welcome back!"
                                           FontSize="26" FontWeight="Bold"
                                           Foreground="#111111" HorizontalAlignment="Center"
                                           Margin="0,0,0,5"/>
                                <TextBlock Text="Please enter your details"
                                           FontSize="14" Foreground="#777777" HorizontalAlignment="Center"
                                           Margin="0,0,0,25"/>

                                <TextBlock Text="Username" FontSize="13" FontWeight="SemiBold" FontFamily="Segoe UI" Foreground="#777777" Margin="0,0,0,4"/>
                                <TextBox x:Name="TxtUsername" Height="36" Background="Transparent" FontSize="16" Padding="0,8,0,8" Margin="0,0,0,20" TextChanged="TxtUsername_TextChanged" KeyDown="TxtUsername_KeyDown">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="BorderBrush" Value="#D1D1D1"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsKeyboardFocused" Value="True">
                                                    <Setter Property="BorderBrush" Value="Black"/>
                                                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>

                                <TextBlock x:Name="LblPassword" Text="Password" FontSize="13" FontWeight="SemiBold" FontFamily="Segoe UI" Foreground="#777777" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,15">
                                    <PasswordBox x:Name="TxtPassword" Height="36" Background="Transparent" FontSize="16" Padding="0,8,30,8" PasswordChanged="TxtPassword_PasswordChanged" KeyDown="TxtPassword_KeyDown">
                                        <PasswordBox.Style>
                                            <Style TargetType="PasswordBox">
                                                <Setter Property="BorderBrush" Value="#D1D1D1"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                                        <Setter Property="BorderBrush" Value="Black"/>
                                                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </PasswordBox.Style>
                                    </PasswordBox>
                                    <TextBox x:Name="TxtPasswordVisible" Height="36" Background="Transparent" FontSize="16" Padding="0,8,30,8" Visibility="Collapsed" TextChanged="TxtPasswordVisible_TextChanged" KeyDown="TxtPassword_KeyDown">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="BorderBrush" Value="#D1D1D1"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                                        <Setter Property="BorderBrush" Value="Black"/>
                                                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                    <TextBlock x:Name="BtnTogglePassword" Text="👁️" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="14" Margin="0,0,5,0" Cursor="Hand" MouseLeftButtonDown="BtnTogglePassword_Click"/>
                                </Grid>

                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox x:Name="ChkRememberMe" IsChecked="True" Content="Remember for 30 days" FontSize="13" FontFamily="Segoe UI" Foreground="#555555" VerticalAlignment="Center" Cursor="Hand" Padding="6,0,0,0"/>
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Cursor="Hand" MouseLeftButtonDown="TxtForgotPwd_Click" Background="Transparent">
                                        <Run Text="Forgot password?" Foreground="#999999" FontSize="13" TextDecorations="None"/>
                                    </TextBlock>
                                </Grid>

                                <TextBlock x:Name="TxtError"
                                           Foreground="#FF4D4F"
                                           FontSize="12" Margin="0,0,0,10"
                                           Visibility="Hidden"/>

                                <Button Height="50" Cursor="Hand" Click="BtnLogin_Click" Margin="0,0,0,10">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="#1A1A1A" CornerRadius="25">
                                                <TextBlock Text="Log In" Foreground="White" FontWeight="SemiBold" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnToRegister_Click" HorizontalAlignment="Center" Margin="0,10,0,0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="Transparent">
                                                <TextBlock FontSize="13" Foreground="#777777">
                                                    <Run Text="Don't have an account? "/>
                                                    <Run Text="Sign Up" Foreground="#111111" FontWeight="SemiBold"/>
                                                </TextBlock>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Grid>
            </Border>
            </Grid>
        </Grid>
    </Border>
</Window>