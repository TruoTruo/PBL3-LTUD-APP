<Window x:Class="StudentReminderApp.Views.Auth.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng ký — Student Reminder"
        Height="680" Width="1060"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseDown="Window_MouseDown">

    <Border Background="#E2E8F0" CornerRadius="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Thanh tiêu đề -->
            <Grid Grid.Row="0">
                <TextBlock Text="Đăng ký — Student Reminder" VerticalAlignment="Center" Margin="24,0,0,0" Foreground="#64748B" FontWeight="SemiBold" FontSize="13"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,16,0">
                    <Button Content="—" Width="30" Height="30" Background="Transparent" BorderThickness="0" 
                            FontSize="16" Foreground="Gray" Cursor="Hand" Click="BtnMinimize_Click"/>
                    <Button Content="✕" Width="30" Height="30" Background="Transparent" BorderThickness="0" 
                            FontSize="14" Foreground="Gray" Cursor="Hand" Click="BtnClose_Click"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="480"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0">
                    <StackPanel VerticalAlignment="Center" Margin="56,0,56,40">
                        <TextBlock Text="Student Reminder" FontSize="32" FontWeight="Bold"
                                   Foreground="Black" Margin="0,0,0,8"/>
                        <TextBlock Text="&amp; Advisor" FontSize="22" FontWeight="Light"
                                   Foreground="#64748B" Margin="0,0,0,32"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="White" CornerRadius="20" Margin="16,0,16,16">
                    <Grid VerticalAlignment="Center" Margin="40">
                            <StackPanel>
                                <TextBlock Text="✦" FontSize="32" Foreground="Black" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                                <TextBlock Text="Create an account" FontSize="26" FontWeight="Bold" Foreground="#111111" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <TextBlock Text="Please fill in the details below" FontSize="14" Foreground="#777777" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                                <TextBlock Text="HỌ VÀ TÊN *" FontSize="13" FontWeight="SemiBold" FontFamily="Segoe UI" Foreground="#777777" Margin="0,0,0,4"/>
                                <TextBox x:Name="TxtHoTen" Height="36" Background="Transparent" FontSize="16" Padding="0,8,0,8" Margin="0,0,0,20">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="BorderBrush" Value="#D1D1D1"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsKeyboardFocused" Value="True">
                                                    <Setter Property="BorderBrush" Value="Black"/>
                                                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>

                                <TextBlock Text="MÃ SỐ SINH VIÊN (MSSV) *" FontSize="13" FontWeight="SemiBold" FontFamily="Segoe UI" Foreground="#777777" Margin="0,0,0,4"/>
                                <TextBox x:Name="TxtMssv" Height="36" Background="Transparent" FontSize="16" Padding="0,8,0,8" Margin="0,0,0,4" MaxLength="9">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="BorderBrush" Value="#D1D1D1"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsKeyboardFocused" Value="True">
                                                    <Setter Property="BorderBrush" Value="Black"/>
                                                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                <TextBlock Text="MSSV gồm 9 chữ số, bắt đầu bằng '102'" FontSize="11" Foreground="#999999" Margin="0,0,0,20"/>

                                <TextBlock Text="MẬT KHẨU *" FontSize="13" FontWeight="SemiBold" FontFamily="Segoe UI" Foreground="#777777" Margin="0,0,0,4"/>
                                <PasswordBox x:Name="TxtPwd" Height="36" Background="Transparent" FontSize="16" Padding="0,8,0,8" Margin="0,0,0,20">
                                    <PasswordBox.Style>
                                        <Style TargetType="PasswordBox">
                                            <Setter Property="BorderBrush" Value="#D1D1D1"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsKeyboardFocused" Value="True">
                                                    <Setter Property="BorderBrush" Value="Black"/>
                                                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </PasswordBox.Style>
                                </PasswordBox>

                                <TextBlock Text="XÁC NHẬN MẬT KHẨU *" FontSize="13" FontWeight="SemiBold" FontFamily="Segoe UI" Foreground="#777777" Margin="0,0,0,4"/>
                                <PasswordBox x:Name="TxtConfirm" Height="36" Background="Transparent" FontSize="16" Padding="0,8,0,8" Margin="0,0,0,20">
                                    <PasswordBox.Style>
                                        <Style TargetType="PasswordBox">
                                            <Setter Property="BorderBrush" Value="#D1D1D1"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsKeyboardFocused" Value="True">
                                                    <Setter Property="BorderBrush" Value="Black"/>
                                                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </PasswordBox.Style>
                                </PasswordBox>

                                <TextBlock x:Name="TxtError" Foreground="#FF4D4F" FontSize="12" Visibility="Collapsed" Margin="0,0,0,10"/>
                                <TextBlock x:Name="TxtSuccess" Foreground="#10B981" FontSize="12" Visibility="Collapsed" Margin="0,0,0,10"/>

                                <Button Height="50" Cursor="Hand" Click="BtnRegister_Click" Margin="0,0,0,10">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="#1A1A1A" CornerRadius="25">
                                                <TextBlock Text="Sign Up" Foreground="White" FontWeight="SemiBold" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnBack_Click" HorizontalAlignment="Center" Margin="0,10,0,0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="Transparent">
                                                <TextBlock FontSize="13" Foreground="#777777">
                                                    <Run Text="Already have an account? "/>
                                                    <Run Text="Log In" Foreground="#111111" FontWeight="SemiBold"/>
                                                </TextBlock>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                </Grid>
            </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
