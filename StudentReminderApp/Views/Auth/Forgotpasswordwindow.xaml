<Window x:Class="StudentReminderApp.Views.Auth.ForgotPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quên mật khẩu — Student Reminder"
        Height="680" Width="1060"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseDown="Window_MouseDown">

    <Border Background="#E2E8F0" CornerRadius="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <TextBlock Text="Quên mật khẩu — Student Reminder" VerticalAlignment="Center" Margin="24,0,0,0" Foreground="#64748B" FontWeight="SemiBold" FontSize="13"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,16,0">
                    <Button Content="—" Width="30" Height="30" Background="Transparent" BorderThickness="0" 
                            FontSize="16" Foreground="Gray" Cursor="Hand" Click="BtnMinimize_Click"/>
                    <Button Content="✕" Width="30" Height="30" Background="Transparent" BorderThickness="0" 
                            FontSize="14" Foreground="Gray" Cursor="Hand" Click="BtnClose_Click"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="480"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0">
                    <StackPanel VerticalAlignment="Center" Margin="56,0,56,40">
                        <TextBlock Text="Student Reminder" FontSize="32" FontWeight="Bold"
                                   Foreground="Black" Margin="0,0,0,8"/>
                        <TextBlock Text="&amp; Advisor" FontSize="22" FontWeight="Light"
                                   Foreground="#64748B" Margin="0,0,0,32"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="White" CornerRadius="20" Margin="16,0,16,16">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid VerticalAlignment="Center" Margin="40">
                            <StackPanel>
                                <Border Width="80" Height="80" CornerRadius="20" Background="#FFD15858" HorizontalAlignment="Center" Margin="0,0,0,10">
                                    <TextBlock Text="S" FontSize="40" FontWeight="Black" Foreground="{DynamicResource ThemePrimaryColor}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <!-- <TextBlock Text="✦" FontSize="32" Foreground="Black" HorizontalAlignment="Center" Margin="0,0,0,10"/> -->
                                <TextBlock Text="Forgot Password" FontSize="26" FontWeight="Bold" Foreground="#111111" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <TextBlock x:Name="TxtSubtitle"
                                           Text="Nhập địa chỉ Email đăng ký để nhận mã OTP."
                                           FontSize="14" Foreground="#777777" HorizontalAlignment="Center"
                                           Margin="0,0,0,25" TextWrapping="Wrap" TextAlignment="Center"/>

                                <!-- STEP 1 -->
                                <StackPanel x:Name="PanelStep1">
                                    <TextBlock Text="ĐỊA CHỈ GMAIL" FontSize="13" FontWeight="SemiBold" FontFamily="Segoe UI" Foreground="#777777" Margin="0,0,0,4"/>
                                    <TextBox x:Name="TxtEmail" Height="36" Background="Transparent" FontSize="16" Padding="0,8,0,8" Margin="0,0,0,20">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="BorderBrush" Value="#D1D1D1"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                                        <Setter Property="BorderBrush" Value="Black"/>
                                                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>

                                    <TextBlock x:Name="TxtStep1Error" Foreground="#FF4D4F" FontSize="12" Margin="0,0,0,10" Visibility="Collapsed" TextWrapping="Wrap"/>

                                    <Button Height="50" Cursor="Hand" Click="BtnSendOtp_Click" Margin="0,0,0,10">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#1A1A1A" CornerRadius="25">
                                                    <TextBlock Text="Gửi mã OTP" Foreground="White" FontWeight="SemiBold" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnBackToLogin_Click" HorizontalAlignment="Center" Margin="0,10,0,0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="Transparent">
                                                    <TextBlock Text="← Quay lại đăng nhập" Foreground="#111111" FontWeight="SemiBold" FontSize="13"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>

                                <!-- STEP 2 -->
                                <StackPanel x:Name="PanelStep2" Visibility="Collapsed">
                                    <TextBlock Text="MÃ OTP" FontSize="13" FontWeight="SemiBold" FontFamily="Segoe UI" Foreground="#777777" Margin="0,0,0,4"/>
                                    <TextBox x:Name="TxtOtp" Height="40" Background="Transparent" MaxLength="6" FontFamily="Consolas" FontSize="22" FontWeight="Bold" TextAlignment="Center" CharacterCasing="Upper" Margin="0,0,0,8">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="BorderBrush" Value="#D1D1D1"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                                        <Setter Property="BorderBrush" Value="Black"/>
                                                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                    <TextBlock Text="Kiểm tra hộp thư đến (hoặc Spam) của Gmail." FontSize="11" Foreground="#999999" Margin="0,0,0,20"/>

                                    <TextBlock x:Name="TxtStep2Error" Foreground="#FF4D4F" FontSize="12" Margin="0,0,0,10" Visibility="Collapsed"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Height="50" Cursor="Hand" Click="BtnBackToStep1_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="Transparent" BorderBrush="#D1D1D1" BorderThickness="1" CornerRadius="25">
                                                        <TextBlock Text="Quay lại" Foreground="#111111" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Button Grid.Column="2" Height="50" Cursor="Hand" Click="BtnConfirmOtp_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="#1A1A1A" CornerRadius="25">
                                                        <TextBlock Text="Xác nhận mã" Foreground="White" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>

                                    <TextBlock HorizontalAlignment="Center" Margin="0,20,0,0" Cursor="Hand" MouseLeftButtonDown="TxtResendOtp_Click" Background="Transparent">
                                        <Run Text="Chưa nhận được mã? " Foreground="#777777" FontSize="13"/>
                                        <Run Text="Gửi lại" Foreground="#111111" FontSize="13" FontWeight="Bold" TextDecorations="Underline"/>
                                    </TextBlock>
                                </StackPanel>

                                <!-- STEP 3 -->
                                <StackPanel x:Name="PanelStep3" Visibility="Collapsed">
                                    <TextBlock Text="MẬT KHẨU MỚI" FontSize="13" FontWeight="SemiBold" FontFamily="Segoe UI" Foreground="#777777" Margin="0,0,0,4"/>
                                    <PasswordBox x:Name="PwdNew" Height="36" Background="Transparent" FontSize="16" Padding="0,8,0,8" Margin="0,0,0,20">
                                        <PasswordBox.Style>
                                            <Style TargetType="PasswordBox">
                                                <Setter Property="BorderBrush" Value="#D1D1D1"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                                        <Setter Property="BorderBrush" Value="Black"/>
                                                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </PasswordBox.Style>
                                    </PasswordBox>

                                    <TextBlock Text="XÁC NHẬN MẬT KHẨU MỚI" FontSize="13" FontWeight="SemiBold" FontFamily="Segoe UI" Foreground="#777777" Margin="0,0,0,4"/>
                                    <PasswordBox x:Name="PwdConfirm" Height="36" Background="Transparent" FontSize="16" Padding="0,8,0,8" Margin="0,0,0,4">
                                        <PasswordBox.Style>
                                            <Style TargetType="PasswordBox">
                                                <Setter Property="BorderBrush" Value="#D1D1D1"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                                        <Setter Property="BorderBrush" Value="Black"/>
                                                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </PasswordBox.Style>
                                    </PasswordBox>
                                    <TextBlock Text="Tối thiểu 8 ký tự." FontSize="11" Foreground="#999999" Margin="0,0,0,20"/>

                                    <TextBlock x:Name="TxtStep3Msg" Foreground="#FF4D4F" FontSize="12" Margin="0,0,0,12" Visibility="Collapsed" TextWrapping="Wrap"/>

                                    <Button Height="50" Cursor="Hand" Click="BtnResetPwd_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#1A1A1A" CornerRadius="25">
                                                    <TextBlock Text="✓ Đặt lại mật khẩu" Foreground="White" FontWeight="SemiBold" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>

                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>