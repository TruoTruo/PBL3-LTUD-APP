<Window x:Class="StudentReminderApp.Views.Auth.ForgotPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quên mật khẩu — Student Reminder"
        Height="520" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,32">

            <TextBlock Text="🔐 Quên mật khẩu" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
            <TextBlock x:Name="TxtSubtitle"
                       Text="Nhập địa chỉ Email đăng ký tài khoản để nhận mã OTP."
                       FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,28" TextWrapping="Wrap"/>

            <StackPanel x:Name="PanelStep1">
                <TextBlock Text="ĐỊA CHỈ GMAIL" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtEmail" Style="{StaticResource InputModern}"
                         Margin="0,0,0,20"/>

                <TextBlock x:Name="TxtStep1Error"
                           Foreground="{StaticResource DangerBrush}"
                           FontSize="12" Margin="0,0,0,12" Visibility="Collapsed"
                           TextWrapping="Wrap"/>

                <Button Content="Gửi mã OTP →"
                        Style="{StaticResource BtnPrimary}"
                        Click="BtnSendOtp_Click"/>
            </StackPanel>

            <StackPanel x:Name="PanelStep2" Visibility="Collapsed">
                <TextBlock Text="MÃ OTP" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtOtp"
                         Style="{StaticResource InputModern}"
                         MaxLength="6" FontFamily="Consolas" FontSize="22"
                         TextAlignment="Center" CharacterCasing="Upper"
                         Margin="0,0,0,8"/>
                <TextBlock Text="Kiểm tra hộp thư đến (hoặc Spam) của Gmail."
                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,20"/>

                <TextBlock x:Name="TxtStep2Error"
                           Foreground="{StaticResource DangerBrush}"
                           FontSize="12" Margin="0,0,0,12" Visibility="Collapsed"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="← Quay lại"
                            Style="{StaticResource BtnSecondary}"
                            Click="BtnBackToStep1_Click"/>
                    <Button Grid.Column="2" Content="Xác nhận mã →"
                            Style="{StaticResource BtnPrimary}"
                            Click="BtnConfirmOtp_Click"/>
                </Grid>

                <TextBlock HorizontalAlignment="Center" Margin="0,16,0,0"
                           Cursor="Hand" MouseLeftButtonUp="TxtResendOtp_Click">
                    <Run Text="Chưa nhận được mã? " Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    <Run Text="Gửi lại" Foreground="#2563EB" FontSize="12" TextDecorations="Underline"/>
                </TextBlock>
            </StackPanel>

            <StackPanel x:Name="PanelStep3" Visibility="Collapsed">
                <TextBlock Text="MẬT KHẨU MỚI" Style="{StaticResource FieldLabel}"/>
                <PasswordBox x:Name="PwdNew" Style="{StaticResource PwdModern}" Margin="0,0,0,16"/>

                <TextBlock Text="XÁC NHẬN MẬT KHẨU MỚI" Style="{StaticResource FieldLabel}"/>
                <PasswordBox x:Name="PwdConfirm" Style="{StaticResource PwdModern}" Margin="0,0,0,8"/>
                <TextBlock Text="Tối thiểu 8 ký tự." FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,20"/>

                <TextBlock x:Name="TxtStep3Msg"
                           FontSize="12" Margin="0,0,0,12" Visibility="Collapsed"
                           TextWrapping="Wrap"/>

                <Button Content="✓ Đặt lại mật khẩu"
                        Style="{StaticResource BtnPrimary}"
                        Click="BtnResetPwd_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>