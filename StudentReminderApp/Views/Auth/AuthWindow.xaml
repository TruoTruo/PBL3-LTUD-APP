<Window x:Class="StudentReminderApp.Views.Auth.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Student Reminder"
        Height="680" Width="1060"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseDown="Window_MouseDown"
        MouseMove="Window_MouseMove">

    <!-- Nền của toàn app được bo góc và có hiệu ứng xuất hiện -->
    <Border Background="#E2E8F0" CornerRadius="24" Opacity="0">
        <Border.RenderTransform>
            <TranslateTransform Y="30"/>
        </Border.RenderTransform>
        <Border.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.6"/>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="30" To="0" Duration="0:0:0.6">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Thanh tiêu đề giả lập (Title Bar) -->
            <Grid Grid.Row="0">
                <TextBlock x:Name="TitleText" Text="Đăng nhập — Student Reminder" VerticalAlignment="Center" Margin="24,0,0,0" Foreground="#64748B" FontWeight="SemiBold" FontSize="13"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,16,0">
                    <Button Content="—" Width="30" Height="30" Background="Transparent" BorderThickness="0" 
                            FontSize="16" Foreground="Gray" Cursor="Hand" Click="BtnMinimize_Click"/>
                    <Button Content="✕" Width="30" Height="30" Background="Transparent" BorderThickness="0" 
                            FontSize="14" Foreground="Gray" Cursor="Hand" Click="BtnClose_Click"/>
                </StackPanel>
            </Grid>

            <!-- Nội dung chính (Cột trái & Form màu trắng) -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="480"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0">
                    <wv2:WebView2 x:Name="AnimationWebView" DefaultBackgroundColor="Transparent"/>
                </Border>

                <Border Grid.Column="1" Background="White" CornerRadius="20" Margin="16,0,16,16">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="25" ShadowDepth="4" Opacity="0.15" Direction="270"/>
                    </Border.Effect>
                    
                    <!-- "Sân khấu" để hiển thị các form (Login, Register, ForgotPwd) -->
                    <ContentControl x:Name="FormContainer" />
                    
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>