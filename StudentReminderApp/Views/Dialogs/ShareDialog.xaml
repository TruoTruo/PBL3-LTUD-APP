<Window x:Class="StudentReminderApp.Views.Dialogs.ShareDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chia sẻ" Height="350" Width="500"
        WindowStartupLocation="CenterOwner" AllowsTransparency="True"
        WindowStyle="None" Background="Transparent">
    
    <Border CornerRadius="15" Background="White" BorderBrush="#E2E8F0" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="15">
                <Grid>
                    <TextBlock Text="Chia sẻ" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center"/>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Background="Transparent" BorderThickness="0" FontWeight="Bold" FontSize="16"
                            Cursor="Hand" Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <Border Grid.Row="1" Padding="15">
                <StackPanel Orientation="Horizontal">
                    <Border Width="50" Height="50" CornerRadius="25" ClipToBounds="True">
                        <Image Source="{Binding CurrentUserAvatar, FallbackValue='/Resources/Images/user.png'}" Stretch="UniformToFill"/>
                    </Border>
                    <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentUserName}" FontWeight="Bold" FontSize="15"/>
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                            <Border Background="#F0F2F5" CornerRadius="5" Padding="5,2">
                                <TextBlock Text="Bảng feed" FontSize="12"/>
                            </Border>
                            <ComboBox Margin="10,0,0,0" Width="120" FontSize="12"
                                      ItemsSource="{Binding PrivacyOptions}"
                                      SelectedItem="{Binding SelectedPrivacyMode}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBox Grid.Row="2" Margin="15,0" BorderThickness="0"
                     Text="{Binding UserComment, UpdateSourceTrigger=PropertyChanged}"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     FontSize="14" Tag="Hãy nói gì đó về nội dung này..."
                     VerticalScrollBarVisibility="Auto"
                     VerticalAlignment="Top"/>

            <Button Grid.Row="3" Content="Chia sẻ ngay" Margin="15" Padding="20,10"
                    FontSize="14" FontWeight="Bold" Cursor="Hand" Foreground="White"
                    Command="{Binding ShareNowCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#1877F2" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Border>
</Window>