<Window x:Class="StudentReminderApp.Views.Dialogs.ShareDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chia sẻ" 
        Height="600" Width="550" 
        WindowStartupLocation="CenterOwner" 
        AllowsTransparency="True"
        WindowStyle="None" 
        Background="Transparent">
    
    <Border CornerRadius="15" Background="White" BorderBrush="#E2E8F0" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    <RowDefinition Height="Auto"/> </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="15">
                <Grid>
                    <TextBlock Text="Chia sẻ bài viết" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" Foreground="#050505"/>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Background="Transparent" BorderThickness="0" FontWeight="Bold" FontSize="18"
                            Foreground="#65676B" Cursor="Hand" Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <Border Grid.Row="1" Padding="15,15,15,5">
                <StackPanel Orientation="Horizontal">
                    <Border Width="45" Height="45" CornerRadius="22.5" ClipToBounds="True">
                        <Image Source="{Binding CurrentUserAvatar, FallbackValue='/Resources/Images/user.png'}" Stretch="UniformToFill"/>
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentUserName, FallbackValue='Thành viên'}" FontWeight="Bold" FontSize="15" Foreground="#050505"/>
                        <Border Background="#F0F2F5" CornerRadius="5" Padding="6,2" HorizontalAlignment="Left" Margin="0,3,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🌎 Công khai" FontSize="12" Foreground="#65676B"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="15,10">
                <StackPanel>
                    <TextBox Text="{Binding UserComment, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             FontSize="16" BorderThickness="0"
                             MinWidth="200" MinHeight="80"
                             Margin="0,0,0,15"
                             Tag="Hãy nói gì đó về nội dung này..."/>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="3" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="15">
                <Button Content="Chia sẻ ngay" Height="40"
                        FontSize="15" FontWeight="Bold" Cursor="Hand" Foreground="White"
                        Command="{Binding ShareNowCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#1877F2" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Border>
        </Grid>
    </Border>
</Window>