<Window x:Class="StudentReminderApp.Views.Dialogs.UserDetailsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chi tiết người dùng" Height="650" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F8FAFC">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="THÔNG TIN CHI TIẾT" FontSize="20" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Center" Margin="0,0,0,24"/>

        <!-- Avatar & Basic Info -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,24">
            <Border Width="100" Height="100" CornerRadius="50" Background="#EFF6FF" BorderBrush="#DBEAFE" BorderThickness="2" Margin="0,0,0,16" ClipToBounds="True">
                <Grid>
                    <TextBlock x:Name="TxtInitials" FontSize="40" FontWeight="Bold" Foreground="#2563EB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Image x:Name="ImgAvatar" Stretch="UniformToFill" Visibility="Collapsed"/>
                </Grid>
            </Border>
            <TextBlock x:Name="TxtName" FontSize="20" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Center"/>
            <TextBlock x:Name="TxtRole" FontSize="14" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Detailed Info -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="SpDetails">
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="MSSV / Tên đăng nhập" FontSize="12" Foreground="#94A3B8" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtUsername" FontSize="15" Foreground="#334155" Margin="0,4,0,0" FontWeight="Medium"/>
                </StackPanel>
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Email" FontSize="12" Foreground="#94A3B8" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtEmail" FontSize="15" Foreground="#334155" Margin="0,4,0,0" FontWeight="Medium"/>
                </StackPanel>
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Số điện thoại" FontSize="12" Foreground="#94A3B8" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtSdt" FontSize="15" Foreground="#334155" Margin="0,4,0,0" FontWeight="Medium"/>
                </StackPanel>
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Ngày sinh" FontSize="12" Foreground="#94A3B8" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtDob" FontSize="15" Foreground="#334155" Margin="0,4,0,0" FontWeight="Medium"/>
                </StackPanel>
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Trường học" FontSize="12" Foreground="#94A3B8" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtTruong" FontSize="15" Foreground="#334155" Margin="0,4,0,0" FontWeight="Medium"/>
                </StackPanel>
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Ngành học" FontSize="12" Foreground="#94A3B8" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtNganh" FontSize="15" Foreground="#334155" Margin="0,4,0,0" FontWeight="Medium"/>
                </StackPanel>
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Lớp sinh hoạt" FontSize="12" Foreground="#94A3B8" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtLop" FontSize="15" Foreground="#334155" Margin="0,4,0,0" FontWeight="Medium"/>
                </StackPanel>
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Nhóm" FontSize="12" Foreground="#94A3B8" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtNhom" FontSize="15" Foreground="#334155" Margin="0,4,0,0" FontWeight="Medium"/>
                </StackPanel>
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Quê quán" FontSize="12" Foreground="#94A3B8" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtQueQuan" FontSize="15" Foreground="#334155" Margin="0,4,0,0" FontWeight="Medium"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Close button -->
        <Button Grid.Row="3" Content="Đóng" Width="100" Height="40" Background="#E2E8F0" Foreground="#334155" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnClose_Click" Margin="0,16,0,0" HorizontalAlignment="Center">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</Window>
