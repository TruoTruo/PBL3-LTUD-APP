<Window x:Class="StudentReminderApp.Views.Dialogs.EventDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sự kiện" Height="500" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgBrush}">
    <StackPanel Margin="32,28">

        <TextBlock x:Name="TxtDialogTitle" Text="Thêm sự kiện"
                   FontSize="20" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24"/>

        <TextBlock Text="TIÊU ĐỀ *" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="TxtEventTitle" Style="{StaticResource InputModern}" Margin="0,0,0,14"/>

        <TextBlock Text="LOẠI SỰ KIỆN" Style="{StaticResource FieldLabel}"/>
        <ComboBox x:Name="CmbType" Height="42" Margin="0,0,0,14">
            <ComboBoxItem Content="📌  Cá nhân"   Tag="PERSONAL"  IsSelected="True"/>
            <ComboBoxItem Content="📚  Học thuật"  Tag="ACADEMIC"/>
            <ComboBoxItem Content="⏰  Deadline"   Tag="DEADLINE"/>
        </ComboBox>

        <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/><ColumnDefinition Width="16"/><ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="NGÀY BẮT ĐẦU *" Style="{StaticResource FieldLabel}"/>
                <DatePicker x:Name="DpStart" Height="42"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="NGÀY KẾT THÚC *" Style="{StaticResource FieldLabel}"/>
                <DatePicker x:Name="DpEnd" Height="42"/>
            </StackPanel>
        </Grid>

        <TextBlock Text="ĐỊA ĐIỂM" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="TxtLocation" Style="{StaticResource InputModern}" Margin="0,0,0,14"/>

        <TextBlock Text="MÔ TẢ" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="TxtDesc" Height="70" AcceptsReturn="True" TextWrapping="Wrap"
                 Background="#F8FAFC" BorderBrush="{StaticResource BorderBrush}"
                 BorderThickness="1.5" Padding="12,8" FontSize="13"
                 VerticalScrollBarVisibility="Auto" Margin="0,0,0,16"/>

        <TextBlock x:Name="TxtErr" Foreground="{StaticResource DangerBrush}"
                   FontSize="12" Visibility="Collapsed" Margin="0,0,0,12"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Lưu sự kiện"
                    Style="{StaticResource BtnPrimary}" Click="BtnSave_Click"/>
            <Button Grid.Column="2" Content="Hủy"
                    Style="{StaticResource BtnSecondary}" Click="BtnCancel_Click"/>
        </Grid>
    </StackPanel>
</Window>
