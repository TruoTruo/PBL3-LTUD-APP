<Window x:Class="StudentReminderApp.Views.Dialogs.EventDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sự kiện" Height="520" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White" 
        WindowStyle="None" AllowsTransparency="True">
    
    <Border BorderThickness="1" BorderBrush="#DDDDDD" CornerRadius="8" Background="White">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="2" Opacity="0.2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>      <RowDefinition Height="Auto"/>   </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="0,0,0,0">
                <StackPanel Margin="28,24,28,10">
                    <TextBlock x:Name="TxtDialogTitle" Text="Thêm sự kiện"
                               FontSize="22" FontWeight="SemiBold"
                               Foreground="#3C4043" Margin="0,0,0,24"/>

                    <TextBlock Text="TIÊU ĐỀ *" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtEventTitle" Style="{StaticResource InputModern}" Margin="0,0,0,16" 
                             Tag="Thêm tiêu đề"/>

                    <TextBlock Text="LOẠI SỰ KIỆN" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="CmbType" Height="40" Margin="0,0,0,16" BorderThickness="1">
                        <ComboBoxItem Content="📌  Cá nhân"   Tag="PERSONAL"  IsSelected="True"/>
                        <ComboBoxItem Content="📚  Học thuật"  Tag="ACADEMIC"/>
                        <ComboBoxItem Content="⏰  Deadline"   Tag="DEADLINE"/>
                    </ComboBox>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="BẮT ĐẦU *" Style="{StaticResource FieldLabel}"/>
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="65"/>
                                </Grid.ColumnDefinitions>
                                <DatePicker x:Name="DpStart" Height="38" Grid.Column="0" Margin="0,0,8,0"/>
                                <TextBox x:Name="TxtStartTime" Height="38" Grid.Column="1" 
                                         Style="{StaticResource InputModern}" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="KẾT THÚC *" Style="{StaticResource FieldLabel}"/>
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="65"/>
                                </Grid.ColumnDefinitions>
                                <DatePicker x:Name="DpEnd" Height="38" Grid.Column="0" Margin="0,0,8,0"/>
                                <TextBox x:Name="TxtEndTime" Height="38" Grid.Column="1" 
                                         Style="{StaticResource InputModern}" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="ĐỊA ĐIỂM" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtLocation" Style="{StaticResource InputModern}" Margin="0,0,0,16"/>

                    <TextBlock Text="MÔ TẢ" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtDesc" Height="80" AcceptsReturn="True" TextWrapping="Wrap"
                             Background="#F1F3F4" BorderThickness="0" Padding="12" FontSize="13"
                             VerticalScrollBarVisibility="Auto" Margin="0,0,0,10"/>
                    
                    <TextBlock x:Name="TxtErr" Foreground="#D93025" FontSize="12" Visibility="Collapsed"/>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="1" Background="White" BorderBrush="#EEEEEE" BorderThickness="0,1,0,0" Padding="20,12">
                <Grid>
                    <Button x:Name="BtnDelete" Content="🗑" Width="40" Height="40" 
                            Background="Transparent" BorderThickness="0" FontSize="18"
                            Foreground="#5F6368" Visibility="Collapsed" Click="BtnDelete_Click"
                            ToolTip="Xóa sự kiện"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Hủy" Width="80" Height="36" 
                                Style="{StaticResource BtnSecondary}" BorderThickness="0"
                                Click="BtnCancel_Click" Margin="0,0,8,0"/>
                        <Button Content="Lưu" Width="100" Height="36" 
                                Background="#1A73E8" Foreground="White" FontWeight="SemiBold"
                                Click="BtnSave_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>