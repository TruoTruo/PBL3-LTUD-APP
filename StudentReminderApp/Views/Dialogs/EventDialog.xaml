<Window x:Class="StudentReminderApp.Views.Dialogs.EventDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        Title="Tạo/Sửa Sự Kiện" 
        Width="580" Height="750" MaxHeight="750"
        WindowStartupLocation="CenterOwner" 
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent">

    <Window.Resources>
        <!-- Style cho Input Line (đường gạch dưới) -->
        <Style x:Key="InputLineStyle" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="0,8"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource TextPrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style cho Input Box (ô vuông xám) -->
        <Style x:Key="InputBoxStyle" TargetType="Control">
            <Setter Property="Background" Value="#f1f5f9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="10,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Control">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <!-- Đối với TextBox/ComboBox, sẽ cần định nghĩa sâu hơn nếu muốn tuỳ chỉnh triệt để, ở đây dùng tạm Border bọc ngoài -->
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Nút Primary (Lưu) -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#475569" Offset="0" />
                        <GradientStop Color="#1e293b" Offset="1" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="32,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Nút Trắng viền xám (Thêm) -->
        <Style x:Key="BtnOutline" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#cbd5e1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#f1f5f9"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource TextMutedBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ColorRadioStyle" TargetType="RadioButton">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Width="24" Height="24" CornerRadius="12" Background="{TemplateBinding Background}" BorderThickness="2" BorderBrush="Transparent">
                            <Ellipse x:Name="CheckMark" Width="10" Height="10" Fill="{DynamicResource SurfaceBrush}" Visibility="Collapsed"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        </Style>
        <Style x:Key="InputModern" TargetType="TextBox" BasedOn="{StaticResource InputLineStyle}">
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <!-- Modal Card Container -->
    <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="8" Opacity="0.1" Direction="270" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Body -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0" Padding="32,24,32,16">
                <TextBlock x:Name="TxtDialogTitle" Text="Tạo/Sửa Sự Kiện" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
            </Border>

            <!-- BODY -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="32,16">
                    
                    <!-- TIÊU ĐỀ -->
                    <StackPanel Margin="0,0,0,24">
                        <TextBlock Text="TIÊU ĐỀ *" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <TextBox x:Name="TxtEventTitle" Style="{StaticResource InputLineStyle}"/>
                    </StackPanel>

                    <!-- ĐỊA ĐIỂM & MÔ TẢ -->
                    <StackPanel Margin="0,0,0,24">
                        <TextBlock Text="ĐỊA ĐIỂM" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <TextBox x:Name="TxtLocation" Style="{StaticResource InputLineStyle}" Margin="0,0,0,16"/>
                        
                        <TextBlock Text="MÔ TẢ" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <TextBox x:Name="TxtDesc" Style="{StaticResource InputLineStyle}" TextWrapping="Wrap" AcceptsReturn="True" Height="60"/>
                    </StackPanel>

                    <!-- LOẠI SỰ KIỆN & LẶP LẠI -->
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="LOẠI SỰ KIỆN" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                            <ComboBox x:Name="CmbType" Padding="10,8" FontSize="14" BorderThickness="0" Background="#f1f5f9" SelectionChanged="CmbType_SelectionChanged">
                                <ComboBoxItem Tag="PERSONAL" Content="&#x1F4CB; Cá nhân"/>
                                <ComboBoxItem Tag="ACADEMIC" Content="&#x1F4DA; Học tập"/>
                                <ComboBoxItem Tag="EXAM" Content="&#x1F4DD; Lịch thi"/>
                                <ComboBoxItem Tag="DEADLINE" Content="&#x23F2; Deadline"/>
                                <ComboBoxItem Tag="REMINDER" Content="&#x23F0; Nhắc nhở"/>
                            </ComboBox>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="LẶP LẠI" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                            <ComboBox x:Name="CmbRecurrence" Padding="10,8" FontSize="14" BorderThickness="0" Background="#f1f5f9">
                                <ComboBoxItem Tag="NONE" Content="Không lặp lại"/>
                                <ComboBoxItem Tag="DAILY" Content="Hàng ngày"/>
                                <ComboBoxItem Tag="WEEKLY" Content="Hàng tuần"/>
                                <ComboBoxItem Tag="MONTHLY" Content="Hàng tháng"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <!-- TAGS SỰ KIỆN -->
                    <StackPanel Margin="0,0,0,24">
                        <TextBlock Text="TAGS SỰ KIỆN" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <!-- Select Rounded -->
                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="20" HorizontalAlignment="Left" MinWidth="150" Background="Transparent">
                            <ComboBox x:Name="TagsDropdownToggle" Text="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" IsEditable="True" IsReadOnly="True" Background="Transparent" BorderThickness="0" Padding="16,8" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}">
                                <ComboBoxItem Padding="0">
                                    <ItemsControl x:Name="TagsListControl">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding TagName}" IsChecked="{Binding IsSelected}" Margin="8,4" Checked="TagCheckBox_Changed" Unchecked="TagCheckBox_Changed"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ComboBoxItem>
                            </ComboBox>
                        </Border>
                    </StackPanel>

                    <!-- MÀU SẮC -->
                    <StackPanel Margin="0,0,0,24">
                        <TextBlock Text="MÀU SẮC" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="RbColorBlue" Background="#1A73E8" GroupName="Colors" IsChecked="True" Style="{StaticResource ColorRadioStyle}"/>
                            <RadioButton x:Name="RbColorRed" Background="#D93025" GroupName="Colors" Style="{StaticResource ColorRadioStyle}"/>
                            <RadioButton x:Name="RbColorGreen" Background="#1E8E3E" GroupName="Colors" Style="{StaticResource ColorRadioStyle}"/>
                            <RadioButton x:Name="RbColorYellow" Background="#F9AB00" GroupName="Colors" Style="{StaticResource ColorRadioStyle}"/>
                            <RadioButton x:Name="RbColorPurple" Background="#9334E6" GroupName="Colors" Style="{StaticResource ColorRadioStyle}"/>
                            <RadioButton x:Name="RbColorTeal" Background="#009688" GroupName="Colors" Style="{StaticResource ColorRadioStyle}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- KHÁCH MỜI -->
                    <StackPanel Margin="0,0,0,24">
                        <TextBlock x:Name="LblGuestOrCourse" Text="KHÁCH MỜI (Nhập MSSV hoặc Tên)" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtGuestSearch" Grid.Column="0" Style="{StaticResource InputLineStyle}" Foreground="{DynamicResource TextMutedBrush}"/>
                            <Button Grid.Column="2" Content="Thêm" Style="{StaticResource BtnOutline}" Click="BtnAddGuest_Click" />
                        </Grid>
                        <StackPanel x:Name="GuestListPanel" Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- NHẮC NHỞ -->
                    <StackPanel Margin="0,0,0,24">
                        <TextBlock Text="NHẮC NHỞ" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        
                        <StackPanel x:Name="ReminderPanel" Margin="0,0,0,12">
                        </StackPanel>

                        <TextBlock Text="+ Thêm thông báo nhắc nhở" Foreground="#334155" FontSize="13" FontWeight="SemiBold" Cursor="Hand" MouseEnter="Link_MouseEnter" MouseLeave="Link_MouseLeave" MouseLeftButtonDown="BtnAddReminder_Click"/>
                    </StackPanel>

                    <!-- THỜI GIAN -->
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="THỜI GIAN" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                        <StackPanel x:Name="SchedulePanel"/>
                        <TextBlock Text="+ Thêm khung giờ" Foreground="#334155" FontSize="13" FontWeight="SemiBold" Cursor="Hand" MouseEnter="Link_MouseEnter" MouseLeave="Link_MouseLeave" MouseLeftButtonDown="BtnAddSchedule_Click" Margin="0,8,0,0"/>
                    </StackPanel>
                    
                    <TextBlock x:Name="TxtErr" Foreground="#ef4444" Visibility="Collapsed" Margin="0,10,0,0"/>
                </StackPanel>
            </ScrollViewer>

            <!-- FOOTER -->
            <Border Grid.Row="2" Padding="32,20" Background="{DynamicResource SurfaceBrush}" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BorderBrush}" CornerRadius="0,0,12,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Icon Xoá -->
                    <Button x:Name="BtnDelete" Grid.Column="0" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="8" ToolTip="Xóa sự kiện" Click="BtnDelete_Click">
                        <fa:ImageAwesome Icon="TrashOutline" Width="18" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Button>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button x:Name="BtnCancel" Content="Hủy" Padding="20,10" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14" FontWeight="SemiBold" Cursor="Hand" Margin="0,0,12,0" Click="BtnCancel_Click"/>
                        <Button x:Name="BtnSave" Content="Lưu" Style="{StaticResource BtnPrimary}" Click="BtnSave_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
