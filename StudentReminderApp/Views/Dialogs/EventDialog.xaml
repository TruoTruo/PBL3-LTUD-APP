<Window x:Class="StudentReminderApp.Views.Dialogs.EventDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sự kiện" Height="680" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White" 
        WindowStyle="None" AllowsTransparency="True">
    
    <Window.Resources>
        <Style x:Key="ColorRadioStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid Width="24" Height="24" Margin="0,0,12,0" Cursor="Hand">
                            <Ellipse Fill="{TemplateBinding Background}" StrokeThickness="0"/>
                            <Ellipse x:Name="checkMark" Fill="White" Width="10" Height="10" Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderThickness="1" BorderBrush="#DDDDDD" CornerRadius="8" Background="White">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="2" Opacity="0.2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>      <RowDefinition Height="Auto"/>   </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="0,0,0,0">
                <StackPanel Margin="28,24,28,10">
                    <TextBlock x:Name="TxtDialogTitle" Text="Thêm sự kiện"
                               FontSize="22" FontWeight="SemiBold"
                               Foreground="#3C4043" Margin="0,0,0,24"/>

                    <TextBlock Text="TIÊU ĐỀ *" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtEventTitle" BorderThickness="0,0,0,1" BorderBrush="#E0E0E0" Background="Transparent" Padding="0,4,0,8" FontSize="18" FontWeight="Medium" Margin="0,0,0,16" 
                             Tag="Thêm tiêu đề" Foreground="#3C4043"/>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="LOẠI SỰ KIỆN" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="CmbType" Height="36" Margin="0,4,0,0" BorderThickness="0,0,0,1" BorderBrush="#E0E0E0" Background="Transparent" VerticalContentAlignment="Center">
                                <ComboBoxItem Content="📌  Cá nhân"   Tag="PERSONAL"  IsSelected="True"/>
                                <ComboBoxItem Content="📚  Học &amp; Thi"  Tag="ACADEMIC"/>
                                <ComboBoxItem Content="⏰  Nhắc nhở"   Tag="REMINDER"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="LẶP LẠI" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="CmbRecurrence" Height="36" Margin="0,4,0,0" BorderThickness="0,0,0,1" BorderBrush="#E0E0E0" Background="Transparent" VerticalContentAlignment="Center">
                                <ComboBoxItem Content="Không lặp lại" Tag="NONE" IsSelected="True"/>
                                <ComboBoxItem Content="Hàng ngày" Tag="DAILY"/>
                                <ComboBoxItem Content="Hàng tuần" Tag="WEEKLY"/>
                                <ComboBoxItem Content="Hàng tháng" Tag="MONTHLY"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="TAGS SỰ KIỆN" Style="{StaticResource FieldLabel}"/>
                    <Grid Margin="0,0,0,16">
                        <ToggleButton x:Name="TagsDropdownToggle" Tag="Chọn Tag..." Height="36" BorderThickness="0,0,0,1" BorderBrush="#E0E0E0" Background="Transparent" Cursor="Hand">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}">
                                        <Grid>
                                            <TextBlock Text="{TemplateBinding Tag}" VerticalAlignment="Center" Margin="5,0,30,0" Foreground="#3C4043" FontSize="14"/>
                                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE70D;" Foreground="#5F6368" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="10"/>
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <Popup PlacementTarget="{Binding ElementName=TagsDropdownToggle}" IsOpen="{Binding IsChecked, ElementName=TagsDropdownToggle}" StaysOpen="False" AllowsTransparency="True">
                            <Border Background="White" BorderThickness="1" BorderBrush="#E0E0E0" CornerRadius="4" MinWidth="{Binding ActualWidth, ElementName=TagsDropdownToggle}" MaxHeight="200">
                                <Border.Effect><DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/></Border.Effect>
                                <ScrollViewer>
                                    <ItemsControl x:Name="TagsListControl">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding TagName}" IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="10,8" Foreground="#3C4043" FontWeight="Medium" Checked="TagCheckBox_Changed" Unchecked="TagCheckBox_Changed"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>

                    <TextBlock x:Name="LblGuestOrCourse" Text="KHÁCH MỜI (Nhập MSSV hoặc Tên)" Style="{StaticResource FieldLabel}"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtGuestSearch" BorderThickness="0,0,0,1" BorderBrush="#E0E0E0" Background="Transparent" Padding="0,4,0,8"/>
                        <Button x:Name="BtnAddGuest" Content="Thêm" Grid.Column="1" Margin="8,0,0,0" Style="{StaticResource BtnSecondary}" Click="BtnAddGuest_Click"/>
                    </Grid>
                    <StackPanel x:Name="GuestListPanel" Margin="0,0,0,16"/>

                    <TextBlock Text="NHẮC NHỞ" Style="{StaticResource FieldLabel}"/>
                    <StackPanel x:Name="ReminderPanel" Margin="0,0,0,8"/>
                    <Button x:Name="BtnAddReminder" Content="+ Thêm thông báo nhắc nhở" Background="Transparent" Foreground="#1A73E8" FontWeight="SemiBold" BorderThickness="0" HorizontalAlignment="Left" Click="BtnAddReminder_Click" Margin="0,0,0,16" Cursor="Hand"/>

                    <TextBlock Text="THỜI GIAN" Style="{StaticResource FieldLabel}"/>
                    <StackPanel x:Name="SchedulePanel" Margin="0,0,0,8"/>
                    <Button x:Name="BtnAddSchedule" Content="+ Thêm khung thời gian" Background="Transparent" Foreground="#1A73E8" FontWeight="SemiBold" BorderThickness="0" HorizontalAlignment="Left" Click="BtnAddSchedule_Click" Margin="0,0,0,16" Cursor="Hand"/>

                    <TextBlock Text="MÀU SẮC" Style="{StaticResource FieldLabel}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <RadioButton x:Name="RbColorBlue" Background="#1A73E8" GroupName="EventColor" IsChecked="True" Style="{StaticResource ColorRadioStyle}"/>
                        <RadioButton x:Name="RbColorRed" Background="#D93025" GroupName="EventColor" Style="{StaticResource ColorRadioStyle}"/>
                        <RadioButton x:Name="RbColorGreen" Background="#1E8E3E" GroupName="EventColor" Style="{StaticResource ColorRadioStyle}"/>
                        <RadioButton x:Name="RbColorYellow" Background="#F9AB00" GroupName="EventColor" Style="{StaticResource ColorRadioStyle}"/>
                        <RadioButton x:Name="RbColorPurple" Background="#9334E6" GroupName="EventColor" Style="{StaticResource ColorRadioStyle}"/>
                        <RadioButton x:Name="RbColorTeal" Background="#009688" GroupName="EventColor" Style="{StaticResource ColorRadioStyle}"/>
                    </StackPanel>

                    <TextBlock Text="ĐỊA ĐIỂM" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtLocation" BorderThickness="0,0,0,1" BorderBrush="#E0E0E0" Background="Transparent" Padding="0,4,0,8" Margin="0,0,0,16"/>

                    <TextBlock Text="MÔ TẢ" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtDesc" Height="80" AcceptsReturn="True" TextWrapping="Wrap"
                             Background="#F8F9FA" BorderThickness="1" BorderBrush="#E0E0E0" Padding="12" FontSize="13"
                             VerticalScrollBarVisibility="Auto" Margin="0,0,0,10"/>
                    
                    <TextBlock x:Name="TxtErr" Foreground="#D93025" FontSize="12" Visibility="Collapsed"/>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="1" Background="White" BorderBrush="#EEEEEE" BorderThickness="0,1,0,0" Padding="20,12">
                <Grid>
                    <Button x:Name="BtnDelete" Content="🗑" Width="40" Height="40" 
                            Background="Transparent" BorderThickness="0" FontSize="18"
                            Foreground="#5F6368" Visibility="Collapsed" Click="BtnDelete_Click"
                            ToolTip="Xóa sự kiện"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Hủy" Width="80" Height="36" 
                                Style="{StaticResource BtnSecondary}" BorderThickness="0"
                                Click="BtnCancel_Click" Margin="0,0,8,0"/>
                        <Button Content="Lưu" Width="100" Height="36" 
                                Background="#1A73E8" Foreground="White" FontWeight="SemiBold"
                                Click="BtnSave_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>