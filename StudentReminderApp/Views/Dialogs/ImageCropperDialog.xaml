<Window x:Class="StudentReminderApp.Views.Dialogs.ImageCropperDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cắt ảnh đại diện" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F8FAFC">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="CẮT ẢNH ĐẠI DIỆN" FontSize="20" FontWeight="Bold" Foreground="#0F172A" Margin="24,16"/>
        <TextBlock Text="Di chuyển khung chọn hoặc kéo các góc để phóng to / thu nhỏ ảnh đại diện" FontSize="14" Foreground="#64748B" Margin="24,45,0,16"/>

        <!-- Crop Area -->
        <Border Grid.Row="1" Margin="24,0" Background="#E2E8F0" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
            <Canvas x:Name="ImageCanvas" Background="Transparent" MouseDown="Canvas_MouseDown" MouseMove="Canvas_MouseMove" MouseUp="Canvas_MouseUp" SizeChanged="Canvas_SizeChanged">
                <Image x:Name="ImgSource" Stretch="Uniform"/>
                <!-- Dim Overlay -->
                <Path Fill="#80000000" x:Name="OverlayPath" IsHitTestVisible="False"/>
                <!-- Selection Box -->
                <Rectangle x:Name="SelectionBox" Stroke="#2563EB" StrokeThickness="2" Fill="Transparent" Visibility="Collapsed" IsHitTestVisible="False"/>
                
                <!-- Corner Handles -->
                <Ellipse x:Name="HandleTL" Width="12" Height="12" Fill="White" Stroke="#2563EB" StrokeThickness="2" Margin="-6,-6,0,0" Visibility="Collapsed" IsHitTestVisible="False"/>
                <Ellipse x:Name="HandleTR" Width="12" Height="12" Fill="White" Stroke="#2563EB" StrokeThickness="2" Margin="-6,-6,0,0" Visibility="Collapsed" IsHitTestVisible="False"/>
                <Ellipse x:Name="HandleBL" Width="12" Height="12" Fill="White" Stroke="#2563EB" StrokeThickness="2" Margin="-6,-6,0,0" Visibility="Collapsed" IsHitTestVisible="False"/>
                <Ellipse x:Name="HandleBR" Width="12" Height="12" Fill="White" Stroke="#2563EB" StrokeThickness="2" Margin="-6,-6,0,0" Visibility="Collapsed" IsHitTestVisible="False"/>
            </Canvas>
        </Border>

        <!-- Footer Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,0">
            <Button Content="Hủy" Width="100" Height="40" Background="White" BorderBrush="#CBD5E1" BorderThickness="1" FontWeight="Bold" Cursor="Hand" Click="BtnCancel_Click" Margin="0,0,16,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Xác nhận" Width="120" Height="40" Background="#2563EB" Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand" Click="BtnConfirm_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
