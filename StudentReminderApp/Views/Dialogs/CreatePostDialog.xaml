<Window
    x:Class="StudentReminderApp.Views.Dialogs.CreatePostDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Tạo bài viết"
    Width="480"
    Height="620"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="ColorCircleStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="6" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FacebookSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#E4E6EB" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border
                            x:Name="SwitchBackground"
                            Background="{TemplateBinding Background}"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="12">
                            <Grid>
                                <Ellipse
                                    x:Name="Thumb"
                                    Width="18"
                                    Height="18"
                                    Margin="2"
                                    HorizontalAlignment="Left"
                                    Fill="White">
                                    <Ellipse.RenderTransform>
                                        <TranslateTransform x:Name="ThumbTranslate" />
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchBackground" Property="Background" Value="#1877F2" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="ThumbTranslate"
                                                Storyboard.TargetProperty="X"
                                                To="16"
                                                Duration="0:0:0.1" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="ThumbTranslate"
                                                Storyboard.TargetProperty="X"
                                                To="0"
                                                Duration="0:0:0.1" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border
        Background="White"
        BorderBrush="#E2E8F0"
        BorderThickness="1"
        CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="18"
                    FontWeight="Bold"
                    Text="Tạo bài viết" />
                <Button
                    Width="30"
                    Height="30"
                    Margin="10"
                    HorizontalAlignment="Right"
                    Background="#E4E6EB"
                    BorderThickness="0"
                    Click="Close_Click"
                    Content="✕"
                    Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="15" />
                        </Style>
                    </Button.Resources>
                </Button>
                <Separator VerticalAlignment="Bottom" Background="#E2E8F0" />
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border
                        Margin="15,15,15,5"
                        Padding="10"
                        Background="#F7F8FA"
                        CornerRadius="8">
                        <DockPanel>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontWeight="SemiBold"
                                Text="Đăng ẩn danh" />
                            <ToggleButton
                                x:Name="BtnAnonymous"
                                Width="40"
                                Height="24"
                                HorizontalAlignment="Right"
                                Checked="BtnAnonymous_Toggle"
                                IsChecked="{Binding IsAnonymous, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource FacebookSwitchStyle}"
                                Unchecked="BtnAnonymous_Toggle" />
                        </DockPanel>
                    </Border>

                    <StackPanel Margin="15,10" Orientation="Horizontal">
                        <Ellipse
                            Width="40"
                            Height="40"
                            Fill="#1877F2" />
                        <StackPanel Margin="10,0" VerticalAlignment="Center">
                            <TextBlock
                                x:Name="TxtUserName"
                                FontSize="15"
                                FontWeight="Bold"
                                Text="Đang tải..." />
                            <TextBlock
                                FontSize="11"
                                Foreground="Gray"
                                Text="🌐 Nhóm công khai" />
                        </StackPanel>
                    </StackPanel>

                    <Border x:Name="PostBackgroundBorder" Margin="15,0" Background="Transparent" CornerRadius="8">
                        <StackPanel>
                            <Grid>
                                <TextBox
                                    x:Name="TxtPostContent"
                                    MinHeight="100"
                                    Padding="5"
                                    AcceptsReturn="True"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    FontSize="18"
                                    Text="{Binding NewContent, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                    TextWrapping="Wrap" />

                                <TextBlock
                                    x:Name="TxtPlaceholder"
                                    Margin="10,5"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    FontSize="18"
                                    Foreground="Gray"
                                    IsHitTestVisible="False"
                                    Text="Bạn đang nghĩ gì thế?">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=TxtPostContent}" Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding SelectedFiles}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,5,0,10" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                                            <Grid>
                                                <Image MaxHeight="500" Source="{Binding FilePath}" Stretch="Uniform"
                                                       Visibility="{Binding IsImage, Converter={StaticResource BoolToVis}}" />
                                                <Button Background="#F0F2F5" BorderThickness="0" Cursor="Hand"
                                                        Command="{Binding DataContext.ViewFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Visibility="{Binding IsNotImage, Converter={StaticResource BoolToVis}}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Height="60" Background="{TemplateBinding Background}">
                                                                <DockPanel Margin="10">
                                                                    <TextBlock Margin="0,0,10,0" VerticalAlignment="Center" FontSize="20" Text="📄" />
                                                                    <StackPanel VerticalAlignment="Center">
                                                                        <TextBlock FontWeight="SemiBold" Foreground="#1877F2" Text="{Binding FileName}"
                                                                                   TextDecorations="Underline" TextTrimming="CharacterEllipsis" />
                                                                        <TextBlock FontSize="10" Foreground="Gray" Text="Nhấn để xem nội dung" />
                                                                    </StackPanel>
                                                                </DockPanel>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <Button Width="24" Height="24" Margin="10" HorizontalAlignment="Right" VerticalAlignment="Top" Panel.ZIndex="1"
                                                        Background="#CC000000" Foreground="White" Content="✕" Cursor="Hand"
                                                        Command="{Binding DataContext.RemoveFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Resources>
                                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="12" /></Style>
                                                    </Button.Resources>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <StackPanel Margin="15,10">
                        <StackPanel x:Name="ColorPickerPanel" Margin="0,5" Orientation="Horizontal" Visibility="Collapsed">
                            <Button Background="White" Style="{StaticResource ColorCircleStyle}" Click="SelectColor_Click" Tag="Normal" />
                            <Button Background="#FF5252" Style="{StaticResource ColorCircleStyle}" Click="SelectColor_Click" Tag="Color" />
                            <Button Background="#448AFF" Style="{StaticResource ColorCircleStyle}" Click="SelectColor_Click" Tag="Color" />
                            <Button Background="#4CAF50" Style="{StaticResource ColorCircleStyle}" Click="SelectColor_Click" Tag="Color" />
                            <Button Background="#FFEB3B" Style="{StaticResource ColorCircleStyle}" Click="SelectColor_Click" Tag="Color" />
                            <Button Background="#9C27B0" Style="{StaticResource ColorCircleStyle}" Click="SelectColor_Click" Tag="Color" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <Image Width="30" Height="30" Cursor="Hand" Source="/Resources/Icons/rgb.png" 
                                   MouseLeftButtonDown="ToggleColorPicker_Click" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Background="White">
                <Border Margin="15,10" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="12,8">
                    <Grid>
                        <TextBlock Text="Thêm vào bài viết của bạn" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Image Source="/Resources/Icons/image-gallery.png" Width="24" Height="24" Margin="8,0" Cursor="Hand" MouseLeftButtonDown="SelectFile_Click"/>
                            
                            <Grid>
                                <Image x:Name="ImgEmoji" 
                                       Source="/Resources/Icons/smiling-face.png" 
                                       Width="24" Height="24" Margin="8,0" Cursor="Hand" 
                                       PreviewMouseLeftButtonUp="ToggleEmojiPopup_Click"/>

                                <Popup x:Name="EmojiPopup" 
                                       PlacementTarget="{Binding ElementName=ImgEmoji}" 
                                       Placement="Top" StaysOpen="False" 
                                       AllowsTransparency="True" PopupAnimation="Fade" 
                                       VerticalOffset="-5">
                                    <Border Background="White" CornerRadius="8" BorderThickness="1" BorderBrush="#E2E8F0" Width="220" Padding="5">
                                        <Border.Effect><DropShadowEffect BlurRadius="10" ShadowDepth="1" Color="#CCCCCC"/></Border.Effect>
                                        <ListBox x:Name="EmojiListBox" BorderThickness="0" Background="Transparent" 
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled" 
                                                 SelectionChanged="EmojiListBox_SelectionChanged">
                                            <ListBox.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="6"/></ItemsPanelTemplate></ListBox.ItemsPanel>
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="Padding" Value="5"/><Setter Property="Cursor" Value="Hand"/>
                                                    <Setter Property="FontFamily" Value="Segoe UI Emoji"/> 
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                <Border Name="Border" Padding="2" CornerRadius="4"><ContentPresenter /></Border>
                                                                <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Border" Property="Background" Value="#F0F2F5"/></Trigger></ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <TextBlock FontSize="20">😀</TextBlock><TextBlock FontSize="20">😃</TextBlock><TextBlock FontSize="20">😄</TextBlock>
                                            <TextBlock FontSize="20">🥰</TextBlock><TextBlock FontSize="20">😍</TextBlock><TextBlock FontSize="20">🤩</TextBlock>
                                            <TextBlock FontSize="20">🤣</TextBlock><TextBlock FontSize="20">😂</TextBlock><TextBlock FontSize="20">😅</TextBlock>
                                            <TextBlock FontSize="20">👍</TextBlock><TextBlock FontSize="20">🙌</TextBlock><TextBlock FontSize="20">❤️</TextBlock>
                                            <TextBlock FontSize="20">🔥</TextBlock><TextBlock FontSize="20">✨</TextBlock><TextBlock FontSize="20">🎉</TextBlock>
                                            <TextBlock FontSize="20">😭</TextBlock><TextBlock FontSize="20">😡</TextBlock><TextBlock FontSize="20">🤔</TextBlock>
                                        </ListBox>
                                    </Border>
                                </Popup>
                            </Grid>
                            <TextBlock Text="..." FontSize="18" FontWeight="Bold" Foreground="Gray" Margin="8,0" Cursor="Hand" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Button Content="Đăng" Margin="15,0,15,15" Height="40" Background="#1877F2" Foreground="White" FontWeight="Bold" Command="{Binding PostCommand}">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>