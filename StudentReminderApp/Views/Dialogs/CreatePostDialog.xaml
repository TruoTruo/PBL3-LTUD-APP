<Window x:Class="StudentReminderApp.Views.Dialogs.CreatePostDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tạo bài viết" Height="520" Width="480" 
        WindowStartupLocation="CenterOwner" WindowStyle="None" 
        AllowsTransparency="True" Background="Transparent">
    
    <Window.Resources>
        <Style x:Key="FacebookSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#E4E6EB"/> 
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="SwitchBackground" CornerRadius="12" Background="{TemplateBinding Background}" BorderThickness="1" BorderBrush="#E2E8F0">
                            <Grid>
                                <Ellipse x:Name="Thumb" Fill="White" Width="18" Height="18" HorizontalAlignment="Left" Margin="2">
                                    <Ellipse.RenderTransform>
                                        <TranslateTransform x:Name="ThumbTranslate"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchBackground" Property="Background" Value="#1877F2"/> 
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate" Storyboard.TargetProperty="X" To="16" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PostButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1877F2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <TextBlock Text="Tạo bài viết" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" FontWeight="Bold"/>
                <Button Click="Close_Click" HorizontalAlignment="Right" Width="30" Height="30" Margin="10" Background="#E4E6EB" BorderThickness="0" Cursor="Hand" Content="✕"/>
                <Separator VerticalAlignment="Bottom" Background="#E2E8F0"/>
            </Grid>

            <Border Grid.Row="1" Background="#F7F8FA" Margin="15,15,15,5" Padding="10" CornerRadius="8">
                <DockPanel>
                    <TextBlock Text="Đăng ẩn danh" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <ToggleButton x:Name="BtnAnonymous" 
                                 Style="{StaticResource FacebookSwitchStyle}" 
                                 HorizontalAlignment="Right" Width="40" Height="24"
                                 Checked="BtnAnonymous_Toggle" Unchecked="BtnAnonymous_Toggle"
                                 IsChecked="{Binding IsAnonymous, UpdateSourceTrigger=PropertyChanged}"/>
                </DockPanel> 
            </Border>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="15,10">
                <Ellipse Width="40" Height="40" Fill="#1877F2"/>
                <StackPanel Margin="10,0">
                    <TextBlock x:Name="TxtUserName" Text="Đang tải..." FontWeight="Bold"/>
                    <TextBlock Text="🌐 Nhóm công khai" FontSize="11" Foreground="Gray"/>
                </StackPanel>
            </StackPanel>

            <Grid Grid.Row="3" Margin="15,5">
                <TextBox x:Name="TxtPostContent" BorderThickness="0" FontSize="16" TextWrapping="Wrap" AcceptsReturn="True" 
                         VerticalScrollBarVisibility="Auto" 
                         Text="{Binding NewContent, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
                
                <TextBlock x:Name="TxtPlaceholder" IsHitTestVisible="False" FontSize="16" Foreground="Gray" Text="Bạn đang nghĩ gì thế?">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=TxtPostContent}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <Button Grid.Row="4" Content="Đăng" Style="{StaticResource PostButtonStyle}" Margin="15,10,15,15" Height="40" 
                    Command="{Binding PostCommand}"/>
        </Grid>
    </Border>
</Window>