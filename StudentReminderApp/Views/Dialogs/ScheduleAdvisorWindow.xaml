<Window x:Class="StudentReminderApp.Views.Dialogs.ScheduleAdvisorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tư vấn Đăng ký Học phần" Height="700" Width="1000" Background="White" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Các môn đã chọn" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
            <ListBox x:Name="CourseListBox" Grid.Row="1" BorderThickness="1" BorderBrush="#E0E0E0" DisplayMemberPath="CourseName">
            </ListBox>
            <Button Grid.Row="2" Content="Áp dụng TKB này" Padding="10" Margin="0,10,0,0" Background="#34A853" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="ApplySchedule_Click"/>
        </Grid>
        <TabControl x:Name="ScheduleTabs" Grid.Column="1" Margin="10">
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding OptionId}" FontWeight="Bold"/>
                        <TextBlock Text=" - Điểm: "/>
                        <TextBlock Text="{Binding Score}"/>
                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate>
                    <ItemsControl ItemsSource="{Binding GridCells}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="11" Columns="7"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{Binding Background}" BorderBrush="{Binding BorderBrush}" BorderThickness="{Binding BorderThickness}" Padding="2">
                                    <Grid>
                                        <TextBlock Text="{Binding TopText}" Foreground="#888" FontSize="9" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="2,0,0,0"/>
                                        <TextBlock Text="{Binding Text}" Foreground="{Binding Foreground}" TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
                                        <TextBlock Text="{Binding BottomText}" Foreground="#888" FontSize="9" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,2,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
    </Grid>
</Window>