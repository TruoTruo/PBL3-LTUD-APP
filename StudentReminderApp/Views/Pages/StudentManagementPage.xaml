<UserControl x:Class="StudentReminderApp.Views.Pages.StudentManagementPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:StudentReminderApp.ViewModels"
             xmlns:local="clr-namespace:StudentReminderApp.Views.Pages"
             Background="#F0F2F5">

    <UserControl.DataContext>
        <vm:StudentViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:IndexPlusOneConverter  x:Key="IdxPlus1"/>

        <Style x:Key="FilterBtnStyle" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="17">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToggleFilterStyle" TargetType="ToggleButton">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="17">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#E53935"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="#E53935"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--
            ══════════════════════════════════════════════════════════
            WATERMARK FIX: TextBox có watermark ẩn ngay khi focused
            Dùng Trigger IsKeyboardFocused thay vì code-behind
            ══════════════════════════════════════════════════════════
        -->
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="White"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="17">
                            <Grid>
                                <TextBlock x:Name="Watermark"
                                           Text="🔍 Tìm tên hoặc MSSV..."
                                           Foreground="#9CA3AF" FontSize="12"
                                           Margin="14,0,0,0" VerticalAlignment="Center"
                                           IsHitTestVisible="False" Visibility="Collapsed"/>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="10,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Hiện watermark khi text rỗng VÀ không focused -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Text" Value=""/>
                                    <Condition Property="IsKeyboardFocused" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Watermark" Property="Visibility" Value="Visible"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EBF5FB"/>
                    <Setter Property="Foreground" Value="#1A1A1A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#F3F4F6"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F9FAFB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="White" Padding="20,16" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="👥 Quản lý sinh viên" FontSize="20" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="Xem và quản lý tài khoản sinh viên trong hệ thống" FontSize="12" Foreground="#6B7280" Margin="0,2,0,0"/>
                </StackPanel>
                <Button DockPanel.Dock="Right" Style="{StaticResource FilterBtnStyle}"
                        Background="#1877F2" Foreground="White" BorderBrush="#1877F2"
                        Command="{Binding RefreshCommand}" VerticalAlignment="Center">
                    <TextBlock Text="🔄 Làm mới"/>
                </Button>
            </DockPanel>
        </Border>

        <!-- FILTER BAR -->
        <Border Grid.Row="1" Background="White" Padding="16,12" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
            <WrapPanel Orientation="Horizontal">
                <Grid Width="240" Margin="0,0,10,0">
                    <TextBox Style="{StaticResource SearchBoxStyle}" x:Name="TxtSearch"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

                <ComboBox Width="160" Height="34" Margin="0,0,10,0"
                          ItemsSource="{Binding ClassList}" SelectedItem="{Binding SelectedClass}"
                          DisplayMemberPath="TenLop" VerticalContentAlignment="Center" FontSize="12"/>

                <ToggleButton Style="{StaticResource ToggleFilterStyle}" Margin="0,0,8,0"
                              IsChecked="{Binding ShowBannedOnly}">
                    <TextBlock Text="🔒 Bị khóa"/>
                </ToggleButton>

                <ToggleButton Style="{StaticResource ToggleFilterStyle}" Margin="0,0,8,0"
                              IsChecked="{Binding ShowUnverifiedOnly}">
                    <TextBlock Text="❌ Chưa xác thực"/>
                </ToggleButton>

                <Button Style="{StaticResource FilterBtnStyle}" Background="Transparent"
                        Foreground="#6B7280" BorderBrush="#DDD" Command="{Binding ClearFilterCommand}">
                    <TextBlock Text="✕ Xóa lọc"/>
                </Button>
            </WrapPanel>
        </Border>

        <!-- STATS -->
        <Border Grid.Row="2" Background="#F8F9FA" Padding="20,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock FontSize="12" Foreground="#6B7280">
                    <Run Text="Hiển thị "/>
                    <Run Text="{Binding FilteredCount}" FontWeight="Bold" Foreground="#111827"/>
                    <Run Text=" / "/>
                    <Run Text="{Binding TotalCount}" FontWeight="Bold" Foreground="#111827"/>
                    <Run Text=" sinh viên"/>
                </TextBlock>
                <Border Margin="16,0,0,0" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="⏳ Đang tải..." FontSize="12" Foreground="#6B7280"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- DATA GRID -->
        <!--
            ══════════════════════════════════════════════════════════
            KEY FIX — Context Menu binding pattern:
            DataGrid.Tag = DataContext (StudentViewModel)
            ContextMenu truy cập commands qua:
                PlacementTarget.Tag.XxxCommand
            CommandParameter = {Binding} = StudentModel của row đó
            ══════════════════════════════════════════════════════════
        -->
        <DataGrid x:Name="dgStudents" Grid.Row="3"
                  ItemsSource="{Binding StudentsView}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  LoadingRow="dgStudents_LoadingRow"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#F3F4F6"
                  Background="White" BorderThickness="0"
                  RowHeaderWidth="0"
                  EnableRowVirtualization="True"
                  Tag="{Binding DataContext, RelativeSource={RelativeSource Self}}">

            <!-- ContextMenu gắn vào từng Row -->
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                    <Setter Property="ContextMenu">
                        <Setter.Value>
                            <ContextMenu>
                                <!--
                                    PlacementTarget = DataGridRow
                                    DataGridRow.Tag = DataGrid (được gán bên dưới)
                                    DataGrid.Tag    = StudentViewModel
                                    DataContext     = StudentModel (item hiện tại)
                                -->

                                <!-- ① Xác thực -->
                                <MenuItem Header="✅  Xác thực tài khoản"
                                          CommandParameter="{Binding}"
                                          Command="{Binding Path=PlacementTarget.Tag.Tag.VerifyCommand,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                    <MenuItem.Style>
                                        <Style TargetType="MenuItem">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsVerified}" Value="True">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                    <Setter Property="Opacity"   Value="0.45"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </MenuItem.Style>
                                </MenuItem>

                                <Separator/>

                                <!-- ② Ban → Sub-menu -->
                                <MenuItem Header="🔒  Ban (Khóa tài khoản)">
                                    <MenuItem.Style>
                                        <Style TargetType="MenuItem">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBanned}" Value="True">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                    <Setter Property="Opacity"   Value="0.45"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </MenuItem.Style>
                                    <MenuItem Header="⏱  Khóa 24 giờ"
                                              CommandParameter="{Binding}"
                                              Command="{Binding Path=PlacementTarget.Tag.Tag.Ban24hCommand,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="♾  Khóa vĩnh viễn"
                                              CommandParameter="{Binding}"
                                              Command="{Binding Path=PlacementTarget.Tag.Tag.BanPermanentCommand,
                                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                </MenuItem>

                                <!-- ③ Unban — chỉ hiện khi bị khóa -->
                                <MenuItem Header="🔓  Mở khóa (Unban)"
                                          CommandParameter="{Binding}"
                                          Command="{Binding Path=PlacementTarget.Tag.Tag.UnbanCommand,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                    <MenuItem.Style>
                                        <Style TargetType="MenuItem">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBanned}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </MenuItem.Style>
                                </MenuItem>

                            </ContextMenu>
                        </Setter.Value>
                    </Setter>

                    <!--
                        Row.Tag = DataGrid (cha của Row).
                        Dùng để ContextMenu leo lên: Row.Tag → DataGrid → DataGrid.Tag → ViewModel
                    -->
                    <Setter Property="Tag"
                            Value="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>

                <!-- STT -->
                <DataGridTextColumn Header="STT" Width="55"
                    Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=Header}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="Foreground" Value="#9CA3AF"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Họ và tên -->
                <DataGridTextColumn Header="Họ và tên" Width="180" Binding="{Binding HoTen}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="12,8"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- MSSV -->
                <DataGridTextColumn Header="MSSV" Width="120" Binding="{Binding Mssv}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="Consolas"/>
                            <Setter Property="Foreground" Value="#374151"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="12,8"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Lớp -->
                <DataGridTextColumn Header="Lớp" Width="130" Binding="{Binding TenLop}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="12,8"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Trạng thái -->
                <DataGridTemplateColumn Header="Trạng thái" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Padding="8,3" CornerRadius="12" HorizontalAlignment="Left" Margin="12,6">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#DCFCE7"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBanned}" Value="True">
                                                <Setter Property="Background" Value="#FEE2E2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding StatusDisplay}" FontSize="11" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#16A34A"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBanned}" Value="True">
                                                    <Setter Property="Foreground" Value="#DC2626"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Thời hạn khóa -->
                <DataGridTextColumn Header="Thời hạn khóa" Width="150"
                                    Binding="{Binding LockUntilDisplay}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#DC2626"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="12,8"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!--
                    ══════════════════════════════════════════════════
                    CỘT XÁC THỰC — FIX:
                    Dùng DataTemplate với Border badge thay vì Text
                    emoji để đảm bảo render đúng và cập nhật reactive.
                    Binding vào VerifiedIcon (✓/✗), VerifiedColor,
                    VerifiedBg — tất cả đều notify khi IsVerified thay đổi.
                    ══════════════════════════════════════════════════
                -->
                <DataGridTemplateColumn Header="Xác thực" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Width="32" Height="32" CornerRadius="16"
                                    Background="{Binding VerifiedBg}"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{Binding VerifiedIcon}"
                                           FontSize="15" FontWeight="Bold"
                                           Foreground="{Binding VerifiedColor}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</UserControl>
