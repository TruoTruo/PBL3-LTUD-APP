<Page x:Class="StudentReminderApp.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBrush}">
    <ScrollViewer>
        <StackPanel Margin="32,28">
            <TextBlock x:Name="TxtGreeting" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBlock x:Name="TxtDate" FontSize="13"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,28"/>

            <!-- Stat cards -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/><ColumnDefinition Width="14"/>
                    <ColumnDefinition/><ColumnDefinition Width="14"/>
                    <ColumnDefinition/><ColumnDefinition Width="14"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="📅 Sự kiện hôm nay" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="StatEvents" Text="0" FontSize="30" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="📚 Học phần đang học" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="StatCourses" Text="0" FontSize="30" FontWeight="Bold"
                                   Foreground="{StaticResource SuccessBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="4" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="⚠ Deadline sắp tới" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="StatDeadlines" Text="0" FontSize="30" FontWeight="Bold"
                                   Foreground="{StaticResource WarningBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="6" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="🔔 Thông báo mới" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="StatNotifs" Text="0" FontSize="30" FontWeight="Bold"
                                   Foreground="{StaticResource InfoBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Two column -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="340"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,16">
                            <TextBlock Text="Sự kiện sắp tới (7 ngày)" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <Button Content="+ Thêm sự kiện" Style="{StaticResource BtnSecondary}"
                                    HorizontalAlignment="Right" Height="32" FontSize="12"
                                    Click="BtnAddEvent_Click"/>
                        </DockPanel>
                        <ItemsControl x:Name="EventList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="0,0,0,1" Padding="0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="36"/>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="90"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding EventTypeIcon}" FontSize="18"
                                                       VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Margin="8,0">
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                           FontSize="13"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding Location}" FontSize="11"
                                                           Foreground="{StaticResource TextMutedBrush}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding StartTime, StringFormat='dd/MM HH:mm'}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center" TextAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock x:Name="TxtNoEvent"
                                   Text="Không có sự kiện nào trong 7 ngày tới."
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="13" HorizontalAlignment="Center"
                                   Margin="0,20" Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Lịch hôm nay" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,14"/>
                        <ItemsControl x:Name="TodaySchedule">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource PrimaryLightBrush}"
                                            CornerRadius="8" Padding="12,10" Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding TenMonHoc}" FontWeight="SemiBold"
                                                       FontSize="13"
                                                       Foreground="{StaticResource PrimaryBrush}"/>
                                            <TextBlock FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Margin="0,4,0,0">
                                                <Run Text="Tiết "/><Run Text="{Binding StartTime}"/>
                                                <Run Text=" — "/><Run Text="{Binding TenPhong}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock x:Name="TxtNoSchedule" Text="Hôm nay không có lịch học."
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="13" HorizontalAlignment="Center"
                                   Margin="0,20" Visibility="Collapsed"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
