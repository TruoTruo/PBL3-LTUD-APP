<Page x:Class="StudentReminderApp.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBrush}">
    <ScrollViewer>
        <StackPanel Margin="32,28">
            <TextBlock x:Name="TxtGreeting" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBlock x:Name="TxtDate" FontSize="13"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,24"/>

            <!-- Two column -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="360"/>
                </Grid.ColumnDefinitions>

                <!-- Cột trái: Thống kê + Sự kiện sắp tới -->
                <StackPanel Grid.Column="0">
                    <!-- Khối Stat cards bố trí dạng 2x2 giống ảnh mẫu -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/><ColumnDefinition Width="16"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/><RowDefinition Height="16"/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        
                        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}" CornerRadius="16" Padding="20">
                            <StackPanel>
                                <TextBlock Text="📅 Sự kiện hôm nay" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="StatEvents" Text="0" FontSize="36" FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource Card}" CornerRadius="16" Padding="20">
                            <StackPanel>
                                <TextBlock Text="📚 Học phần đang học" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="StatCourses" Text="0" FontSize="36" FontWeight="Bold"
                                           Foreground="{StaticResource SuccessBrush}" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource Card}" CornerRadius="16" Padding="20">
                            <StackPanel>
                                <TextBlock Text="⚠ Deadline sắp tới" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="StatDeadlines" Text="0" FontSize="36" FontWeight="Bold"
                                           Foreground="{StaticResource WarningBrush}" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource Card}" CornerRadius="16" Padding="20">
                            <StackPanel>
                                <TextBlock Text="🔔 Thông báo mới" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="StatNotifs" Text="0" FontSize="36" FontWeight="Bold"
                                           Foreground="{StaticResource InfoBrush}" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Style="{StaticResource Card}" CornerRadius="20" Padding="24">
                        <StackPanel>
                        <DockPanel Margin="0,0,0,16">
                                <TextBlock Text="Sự kiện sắp tới (7 ngày)" FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <Button Content="+ Thêm sự kiện" Style="{StaticResource BtnSecondary}"
                                        HorizontalAlignment="Right" Height="36" Padding="12,0" FontSize="13"
                                    Click="BtnAddEvent_Click"/>
                        </DockPanel>
                        <ItemsControl x:Name="EventList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                        <Border Background="#F8FAFC" CornerRadius="12" Padding="16,12" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="48"/>
                                                <ColumnDefinition/>
                                                    <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                                <Border Width="40" Height="40" CornerRadius="20" Background="White" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding EventTypeIcon}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" Margin="4,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}" FontWeight="Bold"
                                                               FontSize="14"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding Location}" FontSize="12"
                                                           Foreground="{StaticResource TextMutedBrush}"/>
                                            </StackPanel>
                                                <Border Grid.Column="2" Background="{StaticResource PrimaryLightBrush}" CornerRadius="8" Padding="10,6" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding StartTime, StringFormat='dd/MM HH:mm'}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{StaticResource PrimaryBrush}"
                                                               TextAlignment="Center"/>
                                                </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock x:Name="TxtNoEvent"
                                   Text="Không có sự kiện nào trong 7 ngày tới."
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="13" HorizontalAlignment="Center"
                                   Margin="0,20" Visibility="Collapsed"/>
                    </StackPanel>
                </Border>
                </StackPanel>

                <!-- Cột phải: Đổ nền xanh biển giống ảnh tham khảo -->
                <Border Grid.Column="2" Background="{StaticResource PrimaryBrush}" CornerRadius="24" Padding="24" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Lịch hôm nay" FontSize="18" FontWeight="Bold"
                                   Foreground="White" Margin="0,0,0,20"/>
                        <ItemsControl x:Name="TodaySchedule">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Làm mờ trong suốt thẻ lịch để nổi trên nền xanh -->
                                    <Border Background="#1AFFFFFF"
                                            CornerRadius="12" Padding="16,14" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="{Binding TenMonHoc}" FontWeight="SemiBold"
                                                       FontSize="14"
                                                       Foreground="White"/>
                                            <TextBlock FontSize="12"
                                                       Foreground="#E2E8F0"
                                                       Margin="0,6,0,0">
                                                <Run Text="Tiết "/><Run Text="{Binding StartTime}"/>
                                                <Run Text=" — "/><Run Text="{Binding TenPhong}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock x:Name="TxtNoSchedule" Text="Hôm nay không có lịch học."
                                   Foreground="#CBD5E1"
                                   FontSize="14" HorizontalAlignment="Center"
                                   Margin="0,20" Visibility="Collapsed"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>