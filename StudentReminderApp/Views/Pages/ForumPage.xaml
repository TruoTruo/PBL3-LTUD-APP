<UserControl
    x:Class="StudentReminderApp.Views.Pages.ForumPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:StudentReminderApp.ViewModels"
    Background="#F0F2F5"
    mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <UserControl.DataContext>
        <vm:ForumViewModel />
    </UserControl.DataContext>

    <Grid x:Name="MainGrid">
        <ScrollViewer x:Name="PostScrollViewer" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="MainStackPanel">
                <Border
                    x:Name="HeaderBorder"
                    Background="#2D3436"
                    ClipToBounds="True"
                    CornerRadius="0,0,20,20">
                    <Grid>
                        <Image
                            Source="/Resources/Images/APUIp.jpg"
                            Stretch="Uniform" 
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top" />
                        
                        <Border VerticalAlignment="Bottom" Height="120">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="Transparent" Offset="0" />
                                    <GradientStop Color="#CC000000" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <StackPanel Margin="40,0,40,25" VerticalAlignment="Bottom">
                            <TextBlock
                                FontSize="32"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="Nhóm Sinh viên Đại học">
                                <TextBlock.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.8" />
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock
                                FontSize="14"
                                Foreground="#E2E8F0"
                                Text="Chia sẻ kiến thức • Kết nối bạn bè" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border
                    x:Name="CreatePostArea"
                    MaxWidth="500"
                    Margin="0,20"
                    Background="White"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="12">
                    <Grid Margin="15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Width="45" Height="45" Margin="0,0,12,0" ClipToBounds="True" CornerRadius="22.5">
                            <Image Source="/Resources/Images/user.png" Stretch="UniformToFill" />
                        </Border>

                        <Border
                            x:Name="PostInputTrigger"
                            Grid.Column="1"
                            Height="45"
                            Background="#F0F2F5"
                            CornerRadius="22.5"
                            Cursor="Hand"
                            MouseLeftButtonUp="OpenCreatePost_Click">
                            <TextBlock
                                Margin="20,0"
                                VerticalAlignment="Center"
                                FontSize="15"
                                Foreground="#65676B"
                                Text="Bạn đang nghĩ gì?" />
                        </Border>

                        <Button
                            x:Name="BtnCreatePost"
                            Grid.Column="2"
                            Margin="12,0,0,0"
                            Background="#1877F2"
                            Click="OpenCreatePost_Click"
                            Content="Đăng bài"
                            Cursor="Hand"
                            FontWeight="Bold"
                            Foreground="White">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border
                                        Padding="15,0"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="18">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <ItemsControl
                    x:Name="ForumPostsControl"
                    MaxWidth="500"
                    Margin="0,0,0,30"
                    ItemsSource="{Binding Posts}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,0,0,15"
                                Background="White"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Padding="15,12,15,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="40" Height="40" ClipToBounds="True" CornerRadius="20">
                                                <Image Source="{Binding DisplayAvatar}" Stretch="UniformToFill" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                                                <TextBlock FontSize="15" FontWeight="Bold" Foreground="#050505" Text="{Binding DisplayName}" />
                                                <TextBlock FontSize="12" Foreground="#65676B" Text="{Binding TimeAgo}" />
                                            </StackPanel>
                                            <Button
                                                Grid.Column="2"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Command="{Binding DataContext.DeletePostCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Content="✕"
                                                Cursor="Hand"
                                                FontWeight="Bold"
                                                Foreground="#65676B"
                                                Visibility="{Binding IsMyPost, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsColored}" Value="True">
                                                        <Setter Property="Background" Value="{Binding BackgroundColor}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock
                                            Margin="15,5,15,10"
                                            LineHeight="22"
                                            Text="{Binding Content}"
                                            TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontSize" Value="15" />
                                                    <Setter Property="Foreground" Value="#050505" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsColored}" Value="True">
                                                            <Setter Property="FontSize" Value="24" />
                                                            <Setter Property="FontWeight" Value="Bold" />
                                                            <Setter Property="Foreground" Value="White" />
                                                            <Setter Property="TextAlignment" Value="Center" />
                                                            <Setter Property="Margin" Value="30,60" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <ItemsControl Grid.Row="2" ItemsSource="{Binding ImagePaths}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#F0F2F5" BorderThickness="0,1">
                                                    <Image MaxHeight="500" Source="{Binding}" Stretch="Uniform" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Border Grid.Row="3" Margin="15,10,15,0" Padding="12"
                                            Background="#F8F9FA" BorderBrush="#CED0D4" BorderThickness="1" CornerRadius="10">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsShared}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Margin="0,0,0,5" FontWeight="Bold" Foreground="#050505" Text="{Binding OriginalPost.DisplayName}" />
                                            <TextBlock MaxHeight="60" Foreground="#050505" Text="{Binding OriginalPost.Content}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Grid.Row="4" Margin="15,10,15,5">
                                        <TextBlock FontSize="13" Foreground="#65676B" Text="{Binding Likes, StringFormat='👍 {0} lượt thích'}" />
                                        <Rectangle Height="1" Margin="0,5,0,0" Fill="#E2E8F0" />
                                    </StackPanel>

                                    <UniformGrid Grid.Row="5" Columns="3" Margin="5,0,5,5">
                                        <Button Padding="8" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                Command="{Binding DataContext.LikeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Foreground" Value="#65676B" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsLiked}" Value="True">
                                                            <Setter Property="Foreground" Value="#1877F2" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="👍 " />
                                                <TextBlock FontWeight="SemiBold" Text="Thích" />
                                            </StackPanel>
                                        </Button>
                                        
                                        <Button Padding="8" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                Click="CommentButton_Click" Foreground="#65676B">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="💬 " />
                                                <TextBlock FontWeight="SemiBold" Text="Bình luận" />
                                            </StackPanel>
                                        </Button>
                                        
                                        <Button Padding="8" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                Click="ShareButton_Click" CommandParameter="{Binding}" Foreground="#65676B">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="↪️ " />
                                                <TextBlock FontWeight="SemiBold" Text="Chia sẻ" />
                                            </StackPanel>
                                        </Button>
                                    </UniformGrid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>