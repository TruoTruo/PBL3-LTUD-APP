<UserControl x:Class="StudentReminderApp.Views.Pages.ForumPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:StudentReminderApp.ViewModels"
             Background="#F0F2F5">

    <UserControl.DataContext>
        <vm:ForumViewModel />
    </UserControl.DataContext>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border CornerRadius="0,0,20,20" Background="#2D3436" ClipToBounds="True">
                    <Grid>
                        <Image Source="/Resources/Images/APUIp.jpg" 
                               Stretch="Uniform" 
                               MaxHeight="350"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                        
                        <Border VerticalAlignment="Bottom" Height="100">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="Transparent" Offset="0"/>
                                    <GradientStop Color="#99000000" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <StackPanel VerticalAlignment="Bottom" Margin="40,0,40,20">
                            <TextBlock Text="Nhóm Sinh viên Đại học" FontSize="32" FontWeight="Bold" Foreground="White">
                                <TextBlock.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.8"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Text="Chia sẻ kiến thức • Kết nối bạn bè" FontSize="14" Foreground="#E2E8F0" Margin="5,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border MaxWidth="750" Background="White" CornerRadius="12" Padding="15" Margin="0,20" BorderBrush="#E2E8F0" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="45" Height="45" CornerRadius="22.5" ClipToBounds="True" Margin="0,0,12,0">
                            <Image Source="/Resources/Images/user.png" Stretch="UniformToFill"/>
                        </Border>
                        <Border Grid.Column="1" Background="#F0F2F5" CornerRadius="22" Padding="15,0" Cursor="Hand" MouseLeftButtonUp="OpenCreatePost_Click">
                            <TextBlock Text="Bạn đang nghĩ gì?" VerticalAlignment="Center" Foreground="#65676B" FontSize="15"/>
                        </Border>
                        <Button Grid.Column="2" Content="Tạo bài viết" Click="OpenCreatePost_Click" Margin="12,0,0,0" Padding="20,8" Background="#1877F2" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="18">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <ItemsControl x:Name="PostsItemsControl" ItemsSource="{Binding Posts}" MaxWidth="750" Margin="0,0,0,30">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" Margin="0,0,0,15" Padding="15" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" ClipToBounds="True">
                                            <Image Source="{Binding DisplayAvatar}" Stretch="UniformToFill"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" Margin="10,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="15"/>
                                            <TextBlock Text="{Binding TimeAgo}" FontSize="12" Foreground="#65676B"/>
                                        </StackPanel>

                                        <Button x:Name="btnOption"
                                                Grid.Column="2" 
                                                Content="..." 
                                                Background="Transparent" 
                                                BorderThickness="0" 
                                                Foreground="#65676B" 
                                                FontSize="22" 
                                                FontWeight="Bold" 
                                                VerticalAlignment="Top" 
                                                Padding="10,0" 
                                                Cursor="Hand"
                                                Click="OptionButton_Click"
                                                Tag="{Binding DataContext, ElementName=PostsItemsControl}">
                                            <Button.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Xóa bài viết" 
                                                              Command="{Binding PlacementTarget.Tag.DeletePostCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding}"/>
                                                </ContextMenu>
                                            </Button.ContextMenu>
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMyPost}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                    
                                    <TextBlock Text="{Binding Content}" FontSize="15" TextWrapping="Wrap" LineHeight="22" Margin="0,0,0,10"/>
                                    
                                    <Separator Background="#E2E8F0" Margin="0,5,0,10"/>
                                    
                                    <UniformGrid Columns="3">
                                        <Button Content="👍 Thích" Background="Transparent" BorderThickness="0" Foreground="#65676B" Padding="10" Cursor="Hand"/>
                                        <Button Content="💬 Bình luận" Background="Transparent" BorderThickness="0" Foreground="#65676B" Padding="10" Cursor="Hand"/>
                                        <Button Content="↪️ Chia sẻ" Background="Transparent" BorderThickness="0" Foreground="#65676B" Padding="10" Cursor="Hand"/>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>