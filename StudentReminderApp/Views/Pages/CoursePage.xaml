<Page x:Class="StudentReminderApp.Views.Pages.CoursePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:System="clr-namespace:System;assembly=mscorlib"
      xmlns:converters="clr-namespace:StudentReminderApp.Converters"
      Title="Lộ trình học tập"
      Background="{StaticResource BgBrush}">

    <Page.Resources>
        <!-- Custom Flat RadioButton -->
        <Style TargetType="RadioButton">
            <Setter Property="Margin"
                    Value="0,0,16,0"/>
            <Setter Property="FontSize"
                    Value="13"/>
            <Setter Property="FontWeight"
                    Value="SemiBold"/>
            <Setter Property="Foreground"
                    Value="{StaticResource TextSecondaryBrush}"/>
        </Style>

        <!-- Custom TabItem Style for Modern Flat Look -->
        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border"
                                Padding="16,10"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                Background="Transparent"
                                Cursor="Hand"
                                Margin="0,0,24,0">
                            <ContentPresenter x:Name="ContentSite"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected"
                                     Value="True">
                                <Setter TargetName="Border"
                                        Property="BorderBrush"
                                        Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="TextElement.Foreground"
                                        Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected"
                                     Value="False">
                                <Setter Property="TextElement.Foreground"
                                        Value="{StaticResource TextSecondaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Border"
                                        Property="Background"
                                        Value="#F8FAFC"/>
                                <Setter TargetName="Border"
                                        Property="CornerRadius"
                                        Value="6,6,0,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="FontWeight"
                    Value="Bold"/>
        </Style>

        <!-- Danh sách trạng thái học -->
        <x:Array x:Key="StatusList" Type="{x:Type System:String}">
            <System:String>Đã học</System:String>
            <System:String>Đang học</System:String>
            <System:String>Chưa học</System:String>
        </x:Array>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="BorderBrush" Value="#E5E7EB" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EBF5FB" />
                    <Setter Property="Foreground" Value="#1F2937" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WrapTextBlockStyle" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,2,0,2" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="BorderBrush" Value="#E5E7EB" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F9FAFB" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DBEAFE" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <converters:WidthToVisibilityConverter x:Key="IsWideEnoughGridVisibilityConverter"
                                               Threshold="1100"
                                               Invert="False" />
        <converters:WidthToVisibilityConverter x:Key="IsNarrowHintVisibilityConverter"
                                               Threshold="1100"
                                               Invert="True" />
    </Page.Resources>

    <Grid x:Name="RootGrid" Margin="32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= TOP: TRẠNG THÁI & CẤU HÌNH ================= -->
        <Grid Grid.Row="0"
              Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Lộ trình Học tập Cá nhân"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock x:Name="TxtStudentInfo"
                           Text="SV: Nguyễn Quang Hiền - 102240365"
                           FontWeight="SemiBold"
                           FontSize="14"
                           Foreground="{StaticResource PrimaryBrush}"
                           Margin="0,4,0,8"/>

                <TextBlock x:Name="TxtCourseStatus"
                           Text="Đang tải lộ trình học..."
                           FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,16"/>

                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,12">
                    <TextBlock Text="Hệ đào tạo:"
                               VerticalAlignment="Center"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,10,0"/>
                    <ComboBox x:Name="CmbHeDaoTao"
                              Width="180"
                              Height="36"
                              SelectionChanged="Config_Changed">
                        <ComboBoxItem Content="Cử nhân (8 Học kỳ)"
                                      IsSelected="True"/>
                        <ComboBoxItem Content="Kỹ sư (10 Học kỳ)"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Chuyên ngành:"
                               VerticalAlignment="Center"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,10,0"/>
                    <RadioButton x:Name="RbNhat"
                                 Content="CNTT Nhật Bản"
                                 IsChecked="True"
                                 Checked="Config_Changed"/>
                    <RadioButton x:Name="RbDacThu"
                                 Content="CNTT Đặc thù"
                                 Checked="Config_Changed"/>
                    <RadioButton x:Name="RbAI"
                                 Content="Trí tuệ nhân tạo (AI)"
                                 Checked="Config_Changed"/>
                </StackPanel>
            </StackPanel>

            <!-- Môn đang đăng ký (Legend/Status) -->
            <Border Grid.Column="1"
                    Style="{StaticResource Card}"
                    Padding="16,12"
                    Background="#F8FAFC">
                <StackPanel>
                    <TextBlock Text="Chú giải màu sắc"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal"
                                Margin="0,4">
                        <Border Width="12"
                                Height="12"
                                CornerRadius="6"
                                Background="#DBEAFE"
                                Margin="0,0,8,0"/>
                        <TextBlock Text="Đã học (Qua môn)"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal"
                                Margin="0,4">
                        <Border Width="12"
                                Height="12"
                                CornerRadius="6"
                                Background="#FEF3C7"
                                Margin="0,0,8,0"/>
                        <TextBlock Text="Đang học kỳ này"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal"
                                Margin="0,4">
                        <Border Width="12"
                                Height="12"
                                CornerRadius="6"
                                Background="#F1F5F9"
                                Margin="0,0,8,0"/>
                        <TextBlock Text="Chưa học"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ================= MAIN CONTENT (TABS) ================= -->
        <TabControl Grid.Row="1"
                    Background="Transparent"
                    BorderThickness="0">

            <!-- TAB 1: KHUNG CHƯƠNG TRÌNH -->
            <TabItem Header="KHUNG CHƯƠNG TRÌNH">
                <Border Style="{StaticResource Card}"
                        Padding="0"
                        Margin="0,12,0,0">
                    <Grid>
                        <TextBlock Text="Cửa sổ quá nhỏ. Vui lòng phóng to để xem chi tiết."
                                   Visibility="{Binding ActualWidth, ElementName=RootGrid, Converter={StaticResource IsNarrowHintVisibilityConverter}}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Padding="24"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />

                        <DataGrid x:Name="DgRoadmap"
                                  Visibility="{Binding ActualWidth, ElementName=RootGrid, Converter={StaticResource IsWideEnoughGridVisibilityConverter}}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeColumns="True"
                                  CanUserResizeRows="False"
                                  CanUserReorderColumns="False"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  ColumnHeaderHeight="40"
                                  RowBackground="White"
                                  AlternatingRowBackground="#F8FAFC"
                                  BorderThickness="0"
                                  MinRowHeight="36"
                                  FontSize="11.5"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.CanContentScroll="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="TT"
                                                    Binding="{Binding SerialNumber}"
                                                    Width="40"
                                                    ElementStyle="{StaticResource WrapTextBlockStyle}" />
                                <DataGridTextColumn Header="HK"
                                                    Binding="{Binding HocKy}"
                                                    Width="50"
                                                    ElementStyle="{StaticResource WrapTextBlockStyle}" />
                                <DataGridTextColumn Header="Ký hiệu"
                                                    Binding="{Binding Symbol}"
                                                    Width="90"
                                                    ElementStyle="{StaticResource WrapTextBlockStyle}" />
                                <DataGridTextColumn Header="Mã HP"
                                                    Binding="{Binding MaHocPhan}"
                                                    Width="90"
                                                    ElementStyle="{StaticResource WrapTextBlockStyle}" />
                                <DataGridTextColumn Header="Tên học phần"
                                                    Binding="{Binding TenHocPhan}"
                                                    Width="2*"
                                                    MinWidth="200"
                                                    FontWeight="SemiBold"
                                                    ElementStyle="{StaticResource WrapTextBlockStyle}" />
                                <DataGridTextColumn Header="TC"
                                                    Binding="{Binding SoTC, StringFormat={}{0:0.#}}"
                                                    Width="50"
                                                    ElementStyle="{StaticResource WrapTextBlockStyle}" />
                                <DataGridTextColumn Header="Tự chọn"
                                                    Binding="{Binding Optional}"
                                                    Width="90"
                                                    MinWidth="90"
                                                    ElementStyle="{StaticResource WrapTextBlockStyle}" />
                                <DataGridTextColumn Header="HT ĐA"
                                                    Binding="{Binding HtDa}"
                                                    Width="90"
                                                    MinWidth="90"
                                                    ElementStyle="{StaticResource WrapTextBlockStyle}" />
                                <DataGridTextColumn Header="TQ ĐA"
                                                    Binding="{Binding TqDa}"
                                                    Width="90"
                                                    MinWidth="90"
                                                    ElementStyle="{StaticResource WrapTextBlockStyle}" />
                                <DataGridTextColumn Header="Học phần cần học trước"
                                                    Binding="{Binding PreStudyCourses}"
                                                    Width="1.8*"
                                                    MinWidth="140"
                                                    ElementStyle="{StaticResource WrapTextBlockStyle}" />
                                <DataGridTextColumn Header="Học song hành với học phần"
                                                    Binding="{Binding CoStudyCourses}"
                                                    Width="1.5*"
                                                    MinWidth="130"
                                                    ElementStyle="{StaticResource WrapTextBlockStyle}" />
                                <DataGridTextColumn Header="Đăng Ký"
                                                    Binding="{Binding Registration}"
                                                    Width="120"
                                                    ElementStyle="{StaticResource WrapTextBlockStyle}" />
                                <DataGridTemplateColumn Header="Trạng thái"
                                                        Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding BgColor}"
                                                    CornerRadius="14"
                                                    Padding="8,4"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    MinWidth="100">
                                                <TextBlock Text="{Binding StatusText}"
                                                           Foreground="{Binding FgColor}"
                                                           FontWeight="Bold"
                                                           FontSize="11"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           TextAlignment="Center"
                                                           TextWrapping="NoWrap" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- TAB 2: MÔN ĐANG ĐĂNG KÝ -->
            <TabItem Header="MÔN ĐANG ĐĂNG KÝ">
                <Border Style="{StaticResource Card}"
                        Padding="0"
                        Margin="0,12,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Danh sách môn học đang đăng ký"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Padding="16,16,16,8"/>

                        <DataGrid x:Name="DgCurrentCourses"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserResizeColumns="True"
                                  CanUserResizeRows="False"
                                  CanUserReorderColumns="False"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  ColumnHeaderHeight="40"
                                  RowBackground="White"
                                  AlternatingRowBackground="#FAFAFA"
                                  BorderThickness="0"
                                  MinRowHeight="36"
                                  FontSize="11.5"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.CanContentScroll="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Mã HP"
                                                    Binding="{Binding MaHocPhan}"
                                                    Width="120"
                                                    Foreground="{StaticResource TextMutedBrush}"
                                                    ElementStyle="{StaticResource WrapTextBlockStyle}" />
                                <DataGridTextColumn Header="Tên học phần"
                                                    Binding="{Binding TenHocPhan}"
                                                    Width="2*"
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource TextPrimaryBrush}"
                                                    ElementStyle="{StaticResource WrapTextBlockStyle}" />
                                <DataGridTextColumn Header="Tín chỉ"
                                                    Binding="{Binding SoTC, StringFormat={}{0:0.#} TC}"
                                                    Width="90"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    ElementStyle="{StaticResource WrapTextBlockStyle}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- TAB 3: LỊCH SỬ ĐÁNH GIÁ -->
            <TabItem Header="LỊCH SỬ ĐÁNH GIÁ">
                <Border Style="{StaticResource Card}"
                        Padding="0"
                        Margin="0,12,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Lịch sử Học tập &amp; Điểm số"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Padding="16,16,16,8"/>

                        <DataGrid x:Name="DgHistory"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserResizeColumns="True"
                                  CanUserResizeRows="False"
                                  CanUserReorderColumns="False"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  ColumnHeaderHeight="40"
                                  RowBackground="White"
                                  AlternatingRowBackground="#FAFAFA"
                                  BorderThickness="0"
                                  MinRowHeight="36"
                                  FontSize="11.5"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.CanContentScroll="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Mã HP"
                                                    Binding="{Binding MaHocPhan}"
                                                    Width="110"
                                                    Foreground="{StaticResource TextMutedBrush}"
                                                    ElementStyle="{StaticResource WrapTextBlockStyle}" />
                                <DataGridTextColumn Header="Tên học phần"
                                                    Binding="{Binding TenHocPhan}"
                                                    Width="2*"
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource TextPrimaryBrush}"
                                                    ElementStyle="{StaticResource WrapTextBlockStyle}" />
                                <DataGridTextColumn Header="Học kỳ"
                                                    Binding="{Binding HocKy}"
                                                    Width="70"
                                                    ElementStyle="{StaticResource WrapTextBlockStyle}" />
                                <DataGridTextColumn Header="Tín chỉ"
                                                    Binding="{Binding SoTC, StringFormat={}{0:0.#}}"
                                                    Width="70"
                                                    ElementStyle="{StaticResource WrapTextBlockStyle}" />
                                <DataGridTextColumn Header="Điểm chữ"
                                                    Binding="{Binding DiemChu}"
                                                    Width="90">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextWrapping" Value="Wrap" />
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Setter Property="Margin" Value="0,2,0,2" />
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Điểm hệ 4"
                                                    Binding="{Binding DiemSo}"
                                                    Width="100"/>
                                <DataGridTextColumn Header="Trạng thái"
                                                    Binding="{Binding StatusText}"
                                                    Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Page>