<Page x:Class="StudentReminderApp.Views.Pages.CoursePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Lộ trình học tập"
      Background="{StaticResource BgBrush}">

    <Page.Resources>
        <!-- Custom Flat RadioButton -->
        <Style TargetType="RadioButton">
            <Setter Property="Margin"
                    Value="0,0,16,0"/>
            <Setter Property="FontSize"
                    Value="13"/>
            <Setter Property="FontWeight"
                    Value="SemiBold"/>
            <Setter Property="Foreground"
                    Value="{StaticResource TextSecondaryBrush}"/>
        </Style>

        <!-- Custom TabItem Style for Modern Flat Look -->
        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border"
                                Padding="16,10"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                Background="Transparent"
                                Cursor="Hand"
                                Margin="0,0,24,0">
                            <ContentPresenter x:Name="ContentSite"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected"
                                     Value="True">
                                <Setter TargetName="Border"
                                        Property="BorderBrush"
                                        Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="TextElement.Foreground"
                                        Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected"
                                     Value="False">
                                <Setter Property="TextElement.Foreground"
                                        Value="{StaticResource TextSecondaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Border"
                                        Property="Background"
                                        Value="#F8FAFC"/>
                                <Setter TargetName="Border"
                                        Property="CornerRadius"
                                        Value="6,6,0,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="FontWeight"
                    Value="Bold"/>
        </Style>
    </Page.Resources>

    <Grid Margin="32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= TOP: TRẠNG THÁI & CẤU HÌNH ================= -->
        <Grid Grid.Row="0"
              Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Lộ trình Học tập Cá nhân"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock x:Name="TxtStudentInfo"
                           Text="SV: Nguyễn Quang Hiền - 102240365"
                           FontWeight="SemiBold"
                           FontSize="14"
                           Foreground="{StaticResource PrimaryBrush}"
                           Margin="0,4,0,12"/>

                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,12">
                    <TextBlock Text="Hệ đào tạo:"
                               VerticalAlignment="Center"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,10,0"/>
                    <ComboBox x:Name="CmbHeDaoTao"
                              Width="180"
                              Height="36"
                              SelectionChanged="Config_Changed">
                        <ComboBoxItem Content="Cử nhân (8 Học kỳ)"
                                      IsSelected="True"/>
                        <ComboBoxItem Content="Kỹ sư (10 Học kỳ)"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Chuyên ngành:"
                               VerticalAlignment="Center"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,10,0"/>
                    <RadioButton x:Name="RbNhat"
                                 Content="CNTT Nhật Bản"
                                 IsChecked="True"
                                 Checked="Config_Changed"/>
                    <RadioButton x:Name="RbDacThu"
                                 Content="CNTT Đặc thù"
                                 Checked="Config_Changed"/>
                    <RadioButton x:Name="RbAI"
                                 Content="Trí tuệ nhân tạo (AI)"
                                 Checked="Config_Changed"/>
                </StackPanel>
            </StackPanel>

            <!-- Môn đang đăng ký (Legend/Status) -->
            <Border Grid.Column="1"
                    Style="{StaticResource Card}"
                    Padding="16,12"
                    Background="#F8FAFC">
                <StackPanel>
                    <TextBlock Text="Chú giải màu sắc"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal"
                                Margin="0,4">
                        <Border Width="12"
                                Height="12"
                                CornerRadius="6"
                                Background="#DBEAFE"
                                Margin="0,0,8,0"/>
                        <TextBlock Text="Đã học (Qua môn)"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal"
                                Margin="0,4">
                        <Border Width="12"
                                Height="12"
                                CornerRadius="6"
                                Background="#FEF3C7"
                                Margin="0,0,8,0"/>
                        <TextBlock Text="Đang học kỳ này"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal"
                                Margin="0,4">
                        <Border Width="12"
                                Height="12"
                                CornerRadius="6"
                                Background="#F1F5F9"
                                Margin="0,0,8,0"/>
                        <TextBlock Text="Chưa học"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ================= MAIN CONTENT (TABS) ================= -->
        <TabControl Grid.Row="1"
                    Background="Transparent"
                    BorderThickness="0">

            <!-- TAB 1: KHUNG CHƯƠNG TRÌNH -->
            <TabItem Header="KHUNG CHƯƠNG TRÌNH">
                <Border Style="{StaticResource Card}"
                        Padding="0"
                        Margin="0,12,0,0">
                    <DataGrid x:Name="DgRoadmap"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              RowBackground="White"
                              AlternatingRowBackground="#F8FAFC"
                              BorderThickness="0"
                              CanUserResizeRows="False"
                              RowHeight="40"
                              FontSize="12.5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="HK"
                                                Binding="{Binding HocKy}"
                                                Width="50"/>
                            <DataGridTextColumn Header="Mã HP"
                                                Binding="{Binding MaHocPhan}"
                                                Width="100"/>
                            <DataGridTextColumn Header="Tên học phần"
                                                Binding="{Binding TenHocPhan}"
                                                Width="*"
                                                FontWeight="SemiBold"/>
                            <DataGridTextColumn Header="TC"
                                                Binding="{Binding SoTC, StringFormat={}{0:0.#}}"
                                                Width="50"/>
                            <DataGridTextColumn Header="Giảng viên"
                                                Binding="{Binding GiangVien}"
                                                Width="150"/>
                            <DataGridTextColumn Header="Thời khóa biểu"
                                                Binding="{Binding ThoiKhoaBieu}"
                                                Width="160"
                                                Foreground="{StaticResource TextSecondaryBrush}"/>
                            <DataGridTextColumn Header="Tuần học"
                                                Binding="{Binding TuanHoc}"
                                                Width="100"
                                                Foreground="{StaticResource TextSecondaryBrush}"/>
                            <DataGridTemplateColumn Header="Trạng thái"
                                                    Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding BgColor}"
                                                CornerRadius="12"
                                                Padding="8,4"
                                                Margin="4">
                                            <TextBlock Text="{Binding StatusText}"
                                                       Foreground="{Binding FgColor}"
                                                       FontWeight="Bold"
                                                       FontSize="11"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

            <!-- TAB 2: MÔN ĐANG ĐĂNG KÝ -->
            <TabItem Header="MÔN ĐANG ĐĂNG KÝ">
                <Border Style="{StaticResource Card}"
                        Padding="0"
                        Margin="0,12,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Danh sách môn học đang đăng ký"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Padding="16,16,16,8"/>

                        <DataGrid x:Name="DgCurrentCourses"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  RowBackground="White"
                                  AlternatingRowBackground="#FAFAFA"
                                  BorderThickness="0"
                                  CanUserResizeRows="False"
                                  RowHeight="40"
                                  FontSize="12.5">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Mã HP"
                                                    Binding="{Binding MaHocPhan}"
                                                    Width="120"
                                                    Foreground="{StaticResource TextMutedBrush}"/>
                                <DataGridTextColumn Header="Tên học phần"
                                                    Binding="{Binding TenHocPhan}"
                                                    Width="*"
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource TextPrimaryBrush}"/>
                                <DataGridTextColumn Header="Tín chỉ"
                                                    Binding="{Binding SoTC, StringFormat={}{0:0.#} TC}"
                                                    Width="100"
                                                    Foreground="{StaticResource TextSecondaryBrush}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- TAB 3: LỊCH SỬ ĐÁNH GIÁ -->
            <TabItem Header="LỊCH SỬ ĐÁNH GIÁ">
                <Border Style="{StaticResource Card}"
                        Padding="0"
                        Margin="0,12,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Lịch sử Học tập &amp; Điểm số"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Padding="16,16,16,8"/>

                        <DataGrid x:Name="DgHistory"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  RowBackground="White"
                                  AlternatingRowBackground="#FAFAFA"
                                  BorderThickness="0"
                                  CanUserResizeRows="False"
                                  RowHeight="44"
                                  FontSize="13.5">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Mã HP"
                                                    Binding="{Binding MaHocPhan}"
                                                    Width="100"
                                                    Foreground="{StaticResource TextMutedBrush}"/>
                                <DataGridTextColumn Header="Tên học phần"
                                                    Binding="{Binding TenHocPhan}"
                                                    Width="*"
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource TextPrimaryBrush}"/>
                                <DataGridTextColumn Header="Học kỳ"
                                                    Binding="{Binding HocKy}"
                                                    Width="80"/>
                                <DataGridTextColumn Header="Tín chỉ"
                                                    Binding="{Binding SoTC, StringFormat={}{0:0.#}}"
                                                    Width="70"/>
                                <DataGridTextColumn Header="Điểm chữ"
                                                    Binding="{Binding DiemChu}"
                                                    Width="90">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight"
                                                    Value="Bold"/>
                                            <Setter Property="HorizontalAlignment"
                                                    Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Điểm hệ 4"
                                                    Binding="{Binding DiemSo}"
                                                    Width="100"/>
                                <DataGridTextColumn Header="Trạng thái"
                                                    Binding="{Binding StatusText}"
                                                    Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Page>