<Page x:Class="StudentReminderApp.Views.Pages.CourseRegistrationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="CourseRegistrationPage"
      Background="#F8FAFC">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOOLBAR -->
        <Border Grid.Row="0"
                Background="White"
                Padding="32,20"
                BorderBrush="#E2E8F0"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnBack"
                        Grid.Column="0"
                        Content="← Quay lại"
                        Background="Transparent"
                        Foreground="#64748B"
                        BorderThickness="0"
                        Cursor="Hand"
                        FontWeight="SemiBold"
                        Click="BtnBack_Click"
                        VerticalAlignment="Center"
                        FontSize="15"/>
                <TextBlock Grid.Column="1"
                           Text="CHI TIẾT LỊCH HỌC DỰ KIẾN"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#0284C7"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                <Button x:Name="BtnRefresh"
                        Grid.Column="2"
                        Content="Làm mới"
                        Background="#F1F5F9"
                        Foreground="#475569"
                        BorderThickness="0"
                        Padding="20,10"
                        Cursor="Hand"
                        Click="BtnRefresh_Click"
                        FontSize="14"
                        FontWeight="SemiBold">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius"
                                    Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1"
                Margin="32,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TOP BAR: PRIORITY SETTINGS -->
            <Border Grid.Row="0"
                    Background="White"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="24,16"
                    Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚙ Cài đặt ưu tiên:"
                            FontWeight="Bold"
                            FontSize="15"
                            Foreground="#1E293B"
                            VerticalAlignment="Center"
                            Margin="0,0,24,0"/>
                    <RadioButton x:Name="RbPrioritySubject"
                            Content="Ưu tiên theo Thời gian rảnh"
                            GroupName="Priority"
                            IsChecked="True"
                            Foreground="#475569"
                            FontWeight="SemiBold"
                            FontSize="14"
                            VerticalAlignment="Center"
                            Margin="0,0,24,0"
                            Checked="QuickFilter_Changed"/>
                    <RadioButton x:Name="RbPriorityTeacher"
                            Content="Ưu tiên theo Giảng viên"
                            GroupName="Priority"
                            Foreground="#475569"
                            FontWeight="SemiBold"
                            FontSize="14"
                            VerticalAlignment="Center"
                            Margin="0,0,24,0"
                            Checked="QuickFilter_Changed"/>

                    <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="12,0,0,0">
                        <TextBlock Text="Lọc Giảng viên:"
                                FontSize="14"
                                Foreground="#64748B"
                                FontWeight="SemiBold"
                                VerticalAlignment="Center"
                                Margin="0,0,12,0"/>
                        <ComboBox x:Name="CmbTeacherFilter"
                                Width="200"
                                Height="36"
                                SelectionChanged="QuickFilter_Changed"
                                FontSize="14">
                            <ComboBoxItem Content="Tất cả giảng viên"
                                    IsSelected="True"/>
                            <ComboBoxItem Content="PGS.TS Phạm Thị Hoa"/>
                            <ComboBoxItem Content="TS. Nguyễn Văn Hùng"/>
                            <ComboBoxItem Content="ThS. Trần Thị Lan"/>
                            <ComboBoxItem Content="ThS. Lê Văn Minh"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="48,0,0,0">
                        <TextBlock Text="Hệ lớp:"
                                FontSize="14"
                                Foreground="#64748B"
                                FontWeight="SemiBold"
                                VerticalAlignment="Center"
                                Margin="0,0,12,0"/>
                        <ComboBox x:Name="CmbClassGroup"
                                Width="140"
                                Height="36"
                                SelectionChanged="CmbClassGroup_SelectionChanged"
                                FontSize="14">
                            <ComboBoxItem Content="24.Nh99"
                                    IsSelected="True"/>
                            <ComboBoxItem Content="24.Nh16"/>
                            <ComboBoxItem Content="24.Nh17"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- DATA GRID -->
            <Border Grid.Row="1"
                    Background="White"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="1">
                <DataGrid x:Name="DgResultClasses"
                          AutoGenerateColumns="False"
                        IsReadOnly="True"
                        CanUserAddRows="False"
                          GridLinesVisibility="Horizontal"
                        HorizontalGridLinesBrush="#F1F5F9"
                          HeadersVisibility="Column"
                        BorderThickness="0"
                          Background="White"
                        RowBackground="White"
                        AlternatingRowBackground="#FAFAFA"
                          LoadingRow="DgResultClasses_LoadingRow"
                          RowHeight="52"
                        FontSize="14"
                        Foreground="#334155">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"
                                    Value="#F8FAFC"/>
                            <Setter Property="Foreground"
                                    Value="#475569"/>
                            <Setter Property="FontWeight"
                                    Value="Bold"/>
                            <Setter Property="Padding"
                                    Value="16,14"/>
                            <Setter Property="BorderBrush"
                                    Value="#E2E8F0"/>
                            <Setter Property="BorderThickness"
                                    Value="0,0,0,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver"
                                        Value="True">
                                    <Setter Property="Background"
                                            Value="#E0F2FE"/>
                                    <!-- Hiệu ứng hover màu xanh nhạt -->
                                </Trigger>
                                <DataTrigger Binding="{Binding IsConflict}"
                                        Value="True">
                                    <Setter Property="Background"
                                            Value="#FEE2E2"/>
                                    <Setter Property="Foreground"
                                            Value="#B91C1C"/>
                                    <Setter Property="ToolTip"
                                            Value="Trùng lịch học!"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã Lớp HP"
                                Binding="{Binding IdLopHp}"
                                Width="120"/>
                        <DataGridTextColumn Header="Tên Môn Học"
                                Binding="{Binding TenMonHoc}"
                                Width="*"/>
                        <DataGridTextColumn Header="Giảng Viên"
                                Binding="{Binding TenGiangVien}"
                                Width="1.5*"/>
                        <DataGridTextColumn Header="Số TC"
                                Binding="{Binding SoTinChi}"
                                Width="70"/>
                        <DataGridTextColumn Header="Phòng Học"
                                Binding="{Binding TenPhong}"
                                Width="100"/>
                        <DataGridTextColumn Header="Thời Gian"
                                Binding="{Binding NgayThu}"
                                Width="140"/>
                        <DataGridTextColumn Header="Tuần Học"
                                Binding="{Binding TuanHoc}"
                                Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- ACTION FOOTER -->
        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="0,1,0,0"
                Padding="32,24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="CreditStatusBorder"
                        Grid.Column="0"
                        Background="#10B981"
                        CornerRadius="8"
                        Padding="24,12"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="TxtTotalNewCredits"
                            Text="Tổng số tín chỉ dự kiến: 0 TC"
                            Foreground="White"
                            FontSize="16"
                            FontWeight="Bold"
                            VerticalAlignment="Center"/>
                </Border>

                <Button x:Name="BtnConfirmAll"
                        Grid.Column="1"
                        Content="Xác nhận Đăng ký"
                        Background="#0284C7"
                        Foreground="White"
                        BorderThickness="0"
                        HorizontalAlignment="Right"
                        Height="52"
                        Padding="40,0"
                        FontSize="16"
                        FontWeight="Bold"
                        Click="BtnConfirmAll_Click"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius"
                                    Value="8"/>
                            <!-- Bo góc 8px theo yêu cầu -->
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Page>