<Page x:Class="StudentReminderApp.Views.Pages.PreferencePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F8FAFC"
      Title="Cài đặt ưu tiên">
    <Grid>
        <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MinWidth="480">
            <Border Background="White"
                    CornerRadius="12"
                    Padding="32"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Thiết lập ưu tiên đăng ký"
                            FontSize="24"
                            FontWeight="Bold"
                            Foreground="#0284C7"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,12"/>
                    <TextBlock Text="Bạn muốn hệ thống ưu tiên tiêu chí nào khi gợi ý và đăng ký học phần tự động?"
                            FontSize="14"
                            Foreground="#64748B"
                            TextWrapping="Wrap"
                            HorizontalAlignment="Center"
                            TextAlignment="Center"
                            Margin="0,0,0,40"/>

                    <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,48">
                        <TextBlock Text="Ưu tiên Giáo viên"
                                FontSize="16"
                                FontWeight="SemiBold"
                                VerticalAlignment="Center"
                                Margin="0,0,16,0"
                                Foreground="#334155"/>

                        <!-- Toggle Switch (Nút gạt bật tắt) -->
                        <ToggleButton x:Name="TogglePreference"
                                Width="56"
                                Height="28"
                                Cursor="Hand">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="Border"
                                            CornerRadius="14"
                                            Background="#94A3B8">
                                        <Ellipse x:Name="Knob"
                                                Width="24"
                                                Height="24"
                                                Fill="White"
                                                HorizontalAlignment="Left"
                                                Margin="2,0,0,0">
                                            <Ellipse.Effect>
                                                <DropShadowEffect BlurRadius="4"
                                                        ShadowDepth="1"
                                                        Opacity="0.1"/>
                                            </Ellipse.Effect>
                                        </Ellipse>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked"
                                                Value="True">
                                            <Setter TargetName="Border"
                                                    Property="Background"
                                                    Value="#0EA5E9"/>
                                            <Setter TargetName="Knob"
                                                    Property="HorizontalAlignment"
                                                    Value="Right"/>
                                            <Setter TargetName="Knob"
                                                    Property="Margin"
                                                    Value="0,0,2,0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <TextBlock Text="Ưu tiên Môn học"
                                FontSize="16"
                                FontWeight="SemiBold"
                                VerticalAlignment="Center"
                                Margin="16,0,0,0"
                                Foreground="#334155"/>
                    </StackPanel>

                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BtnBack"
                                Grid.Column="0"
                                Content="Quay lại"
                                Height="44"
                                Foreground="#475569"
                                Background="Transparent"
                                BorderBrush="#CBD5E1"
                                BorderThickness="1"
                                Cursor="Hand"
                                Click="BtnBack_Click"/>
                        <Button x:Name="BtnContinue"
                                Grid.Column="2"
                                Content="Tiếp tục"
                                Height="44"
                                Style="{StaticResource BtnPrimary}"
                                Cursor="Hand"
                                Click="BtnContinue_Click"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>