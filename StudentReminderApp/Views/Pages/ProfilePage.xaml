<Page x:Class="StudentReminderApp.Views.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:fa="http://schemas.fontawesome.io/icons/"
      mc:Ignorable="d" 
      d:DesignHeight="1200" d:DesignWidth="800"
      Title="Hồ sơ cá nhân" Background="#F8FAFC">

    <Page.Resources>
        <!-- Premium Shadow for Cards -->
        <DropShadowEffect x:Key="PremiumShadow" Color="#000000" BlurRadius="30" ShadowDepth="5" Opacity="0.04"/>

        <!-- Tab Button Active -->
        <Style x:Key="TabBtnActive" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="BorderThickness" Value="1,1,1,0"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="Padding" Value="32,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12,12,0,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab Button Inactive -->
        <Style x:Key="TabBtnInactive" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="BorderThickness" Value="1,1,1,0"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Padding" Value="32,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12,12,0,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#2563EB"/>
                                <Setter Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Form Label -->
        <Style x:Key="ProFieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" BorderThickness="0">
        <StackPanel Margin="24,16,24,40">
            <!-- Header Title -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Hồ sơ cá nhân" FontSize="28" FontWeight="ExtraBold" Foreground="#0F172A"/>
                    <TextBlock Text="Quản lý, cá nhân hóa thông tin chính khóa và cấu hình tài khoản của bạn" 
                               FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
                </StackPanel>
                <!-- Last Updated -->
                <Border Grid.Column="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" 
                        CornerRadius="12" Padding="16,8" VerticalAlignment="Center" Effect="{StaticResource PremiumShadow}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="6" Height="6" Fill="#3B82F6" Margin="0,0,8,0"/>
                        <TextBlock Text="Cập nhật: " FontSize="12" Foreground="#64748B"/>
                        <TextBlock x:Name="TxtLastUpdated" Text="Vừa xong" FontSize="12" FontWeight="SemiBold" Foreground="#334155"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Premium Avatar Profile Header -->
            <Border Background="White" CornerRadius="20" BorderBrush="#F1F5F9" BorderThickness="1" Padding="32" Margin="0,0,0,24" Effect="{StaticResource PremiumShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Avatar Box -->
                    <Border Width="96" Height="96" CornerRadius="24" Background="#EFF6FF" BorderBrush="#DBEAFE" BorderThickness="2" Margin="0,0,24,0">
                        <Border.Clip>
                            <RectangleGeometry RadiusX="22" RadiusY="22" Rect="0,0,92,92"/>
                        </Border.Clip>
                        <Grid>
                            <TextBlock x:Name="TxtHeaderAvatar" Text="V" FontSize="40" FontWeight="Black" Foreground="#2563EB" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Image x:Name="ImgAvatar" Stretch="UniformToFill" Visibility="Collapsed"/>
                        </Grid>
                    </Border>
                    
                    <!-- Info Text -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtHeaderName" Text="Họ Tên Sinh Viên" FontSize="24" FontWeight="ExtraBold" Foreground="#0F172A"/>
                        <TextBlock x:Name="TxtHeaderUsername" Text="@mssv" FontSize="14" FontWeight="Medium" Foreground="#94A3B8" Margin="0,2,0,12"/>
                        
                        <StackPanel Orientation="Horizontal">
                            <!-- MSSV Badge -->
                            <Border Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="12" Padding="12,6" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <fa:ImageAwesome Icon="IdCard" Width="14" Foreground="#1D4ED8" Margin="0,0,6,0"/>
                                    <TextBlock x:Name="TxtBadgeMssv" Text="MSSV: 102240358" FontSize="12" FontWeight="Bold" Foreground="#1D4ED8"/>
                                </StackPanel>
                            </Border>
                            <!-- Sinh viên Badge -->
                            <Border Background="#F1F5F9" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="12,6" Margin="0,0,16,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <fa:ImageAwesome Icon="GraduationCap" Width="14" Foreground="#334155" Margin="0,0,6,0"/>
                                    <TextBlock x:Name="TxtBadgeRole" Text="Sinh viên" FontSize="12" FontWeight="Bold" Foreground="#334155"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Actions -->
                            <Button Content="Đổi ảnh" Background="#F1F5F9" Foreground="#334155" FontWeight="SemiBold" FontSize="12" Cursor="Hand" Click="BtnChangeAvatar_Click" Margin="0,0,8,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="12,6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Content="Xóa ảnh" Background="#FEF2F2" Foreground="#EF4444" FontWeight="SemiBold" FontSize="12" Cursor="Hand" Click="BtnDeleteAvatar_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="12,6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                    
                    <!-- Status Indicator -->
                    <Border Grid.Column="2" VerticalAlignment="Top" Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1" CornerRadius="12" Padding="12,6">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="8" Height="8" Fill="#10B981" Margin="0,0,6,0"/>
                            <TextBlock Text="ĐANG HOẠT ĐỘNG" FontSize="11" FontWeight="ExtraBold" Foreground="#047857"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Tabs Navigation -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,0" ZIndex="10">
                <Button x:Name="BtnTabInfo" Content="Thông tin hồ sơ" Style="{StaticResource TabBtnActive}" Click="BtnTabInfo_Click" Margin="0,0,8,0"/>
                <Button x:Name="BtnTabReminder" Content="Cài đặt nhắc nhở" Style="{StaticResource TabBtnInactive}" Click="BtnTabReminder_Click" Margin="0,0,8,0"/>
                <Button x:Name="BtnTabPassword" Content="Đổi mật khẩu" Style="{StaticResource TabBtnInactive}" Click="BtnTabPassword_Click"/>
            </StackPanel>
            
            <Border BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Margin="0,0,0,24"/>

            <!-- TAB 1: INFO & REMINDER -->
            <StackPanel x:Name="ContainerInfo" Visibility="Visible">
                
                <!-- Personal Info Card -->
                <Border Background="White" CornerRadius="16" BorderBrush="#F1F5F9" BorderThickness="1" Effect="{StaticResource PremiumShadow}" Margin="0,0,0,24">
                    <StackPanel>
                        <!-- Card Header -->
                        <Border Background="#F8FAFC" BorderThickness="0,0,0,1" BorderBrush="#F1F5F9" Padding="24" CornerRadius="16,16,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="40" Height="40" Background="#EFF6FF" CornerRadius="12" Margin="0,0,16,0">
                                    <fa:ImageAwesome Icon="User" Width="16" Foreground="#2563EB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Thông tin cá nhân &amp; Ngành học" FontSize="18" FontWeight="ExtraBold" Foreground="#0F172A"/>
                                    <TextBlock Text="Vui lòng kiểm tra kỹ lưỡng các thông tin hồ sơ của bạn" FontSize="12" Foreground="#94A3B8" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="2" Background="#DBEAFE" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="12" Padding="12,6" VerticalAlignment="Center">
                                    <TextBlock Text="Thông tin chính khóa" FontSize="12" FontWeight="Bold" Foreground="#2563EB"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Card Body (Form) -->
                        <Border Padding="32">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="32"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Row 1: Tên & Email -->
                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock Text="HỌ VÀ TÊN" Style="{StaticResource ProFieldLabel}"/>
                                    <TextBox x:Name="TxtEditHoTen" Style="{StaticResource InputModern}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="2">
                                    <TextBlock Text="EMAIL LIÊN HỆ" Style="{StaticResource ProFieldLabel}"/>
                                    <TextBox x:Name="TxtEditEmail" Style="{StaticResource InputModern}"/>
                                </StackPanel>

                                <!-- Row 2: SĐT & Ngày sinh -->
                                <StackPanel Grid.Row="2" Grid.Column="0">
                                    <TextBlock Text="SỐ ĐIỆN THOẠI" Style="{StaticResource ProFieldLabel}"/>
                                    <TextBox x:Name="TxtEditSdt" Style="{StaticResource InputModern}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="2">
                                    <TextBlock Text="NGÀY SINH" Style="{StaticResource ProFieldLabel}"/>
                                    <DatePicker x:Name="DpNgaySinh" Height="42" FontSize="14" BorderBrush="#CBD5E1" Background="#F8FAFC" VerticalContentAlignment="Center"/>
                                </StackPanel>

                                <!-- Row 3: MSSV & Trường -->
                                <StackPanel Grid.Row="4" Grid.Column="0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                                        <TextBlock Text="MÃ SỐ SINH VIÊN (MSSV) " FontSize="11" FontWeight="Bold" Foreground="#94A3B8"/>
                                        <fa:ImageAwesome Icon="Lock" Width="10" Foreground="#CBD5E1"/>
                                    </StackPanel>
                                    <TextBox x:Name="TxtEditMssv" Style="{StaticResource InputModern}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="4" Grid.Column="2">
                                    <TextBlock Text="TRƯỜNG ĐẠI HỌC" Style="{StaticResource ProFieldLabel}"/>
                                    <ComboBox x:Name="CmbTruong" Height="42" FontSize="14" VerticalContentAlignment="Center" Background="#F8FAFC" BorderBrush="#CBD5E1" SelectionChanged="CmbTruong_SelectionChanged">
                                        <ComboBoxItem Content="— Chọn trường —"/>
                                        <ComboBoxItem Content="Trường ĐH Bách Khoa Đà Nẵng"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Row 4: Khoa & Ngành -->
                                <StackPanel Grid.Row="6" Grid.Column="0">
                                    <TextBlock Text="KHOA" Style="{StaticResource ProFieldLabel}"/>
                                    <ComboBox x:Name="CmbKhoa" Height="42" FontSize="14" VerticalContentAlignment="Center" Background="#F8FAFC" BorderBrush="#CBD5E1" SelectionChanged="CmbKhoa_SelectionChanged">
                                        <ComboBoxItem Content="— Chọn khoa —"/>
                                        <ComboBoxItem Content="Công Nghệ Thông Tin"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Row="6" Grid.Column="2">
                                    <TextBlock Text="NGÀNH HỌC CHÍNH" Style="{StaticResource ProFieldLabel}"/>
                                    <ComboBox x:Name="CmbNganhHoc" Height="42" FontSize="14" VerticalContentAlignment="Center" Background="#F8FAFC" BorderBrush="#CBD5E1" IsEnabled="False" SelectionChanged="CmbNganhHoc_SelectionChanged">
                                        <ComboBoxItem Content="— Chọn ngành học —"/>
                                        <ComboBoxItem Content="CNTT Nhật Bản"/>
                                        <ComboBoxItem Content="CNTT Đặc Thù"/>
                                        <ComboBoxItem Content="Trí Tuệ Nhân Tạo (AI)"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Row 5: Lớp & Nhóm -->
                                <StackPanel Grid.Row="8" Grid.Column="0">
                                    <TextBlock Text="LỚP SINH HOẠT" Style="{StaticResource ProFieldLabel}"/>
                                    <ComboBox x:Name="CmbClass" Height="42" FontSize="14" DisplayMemberPath="TenLop" SelectedValuePath="IdLop" VerticalContentAlignment="Center" Background="#F8FAFC" BorderBrush="#CBD5E1" IsEnabled="False"/>
                                </StackPanel>
                                <StackPanel Grid.Row="8" Grid.Column="2">
                                    <TextBlock Text="NHÓM HIỆN TẠI" Style="{StaticResource ProFieldLabel}"/>
                                    <ComboBox x:Name="CmbNhom" Height="42" FontSize="14" VerticalContentAlignment="Center" Background="#F8FAFC" BorderBrush="#CBD5E1">
                                        <ComboBoxItem Content="— Chọn nhóm —"/>
                                        <ComboBoxItem Content="2499"/>
                                        <ComboBoxItem Content="2498"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Row 6: Quê quán -->
                                <StackPanel Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="3">
                                    <TextBlock Text="QUÊ QUÁN (TỈNH/THÀNH PHỐ)" Style="{StaticResource ProFieldLabel}"/>
                                    <ComboBox x:Name="CmbQueQuan" Height="42" FontSize="14" VerticalContentAlignment="Center" Background="#F8FAFC" BorderBrush="#CBD5E1"/>
                                </StackPanel>

                                <!-- Nút Lưu -->
                                <StackPanel Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal">
                                    <Button Content="Lưu thông tin hồ sơ" Background="#2563EB" Foreground="White" FontWeight="Bold" FontSize="14" Height="48" Padding="24,0" BorderThickness="0" Cursor="Hand" Click="BtnSaveProfile_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <TextBlock x:Name="TxtProfileMsg" VerticalAlignment="Center" FontSize="13" Margin="16,0,0,0" Foreground="#10B981" FontWeight="SemiBold" Visibility="Collapsed"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- TAB 1.5: REMINDER -->
            <StackPanel x:Name="ContainerReminder" Visibility="Collapsed">
                <!-- Reminder Card -->
                <Border Background="White" CornerRadius="16" BorderBrush="#F1F5F9" BorderThickness="1" Effect="{StaticResource PremiumShadow}" Margin="0,0,0,24">
                    <StackPanel>
                        <!-- Card Header -->
                        <Border Background="#F8FAFC" BorderThickness="0,0,0,1" BorderBrush="#F1F5F9" Padding="24" CornerRadius="16,16,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="40" Height="40" Background="#EEF2FF" CornerRadius="12" Margin="0,0,16,0">
                                    <fa:ImageAwesome Icon="Bell" Width="16" Foreground="#4F46E5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Cài đặt nhắc nhở" FontSize="18" FontWeight="ExtraBold" Foreground="#0F172A"/>
                                    <TextBlock Text="Nhận thông báo lịch thi, hạn nộp bài tập và đăng ký môn học" FontSize="12" Foreground="#94A3B8" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Padding="32">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock Text="NHẮC TRƯỚC (PHÚT)" Style="{StaticResource ProFieldLabel}"/>
                                    <TextBox x:Name="TxtMinsBefore" Style="{StaticResource InputModern}" Text="15"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="2">
                                    <TextBlock Text="KÊNH THÔNG BÁO CHÍNH" Style="{StaticResource ProFieldLabel}"/>
                                    <ComboBox x:Name="CmbChannel" Height="42" FontSize="14" VerticalContentAlignment="Center" Background="#F8FAFC" BorderBrush="#CBD5E1">
                                        <ComboBoxItem Content="PUSH (Popup hệ thống)" IsSelected="True"/>
                                        <ComboBoxItem Content="Email sinh viên"/>
                                    </ComboBox>
                                </StackPanel>

                                <CheckBox x:Name="ChkEnabled" Content="Kích hoạt thông báo đẩy tự động" Grid.Row="2" Grid.ColumnSpan="3" IsChecked="True" FontSize="14" FontWeight="SemiBold" Foreground="#334155" Margin="0,8,0,0"/>

                                <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal">
                                    <Button Content="Lưu cài đặt nhắc nhở" Background="#2563EB" Foreground="White" FontWeight="Bold" FontSize="14" Height="48" Padding="24,0" BorderThickness="0" Cursor="Hand" Click="BtnSaveReminder_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <TextBlock x:Name="TxtReminderMsg" VerticalAlignment="Center" FontSize="13" Margin="16,0,0,0" Foreground="#10B981" FontWeight="SemiBold" Visibility="Collapsed"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- TAB 2: PASSWORD -->
            <StackPanel x:Name="ContainerPassword" Visibility="Collapsed">
                <!-- Password Card -->
                <Border Background="White" CornerRadius="16" BorderBrush="#F1F5F9" BorderThickness="1" Effect="{StaticResource PremiumShadow}" Margin="0,0,0,24">
                    <StackPanel>
                        <!-- Card Header -->
                        <Border Background="#F8FAFC" BorderThickness="0,0,0,1" BorderBrush="#F1F5F9" Padding="24" CornerRadius="16,16,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="40" Height="40" Background="#FFF7ED" CornerRadius="12" Margin="0,0,16,0">
                                    <fa:ImageAwesome Icon="Shield" Width="16" Foreground="#EA580C" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Đổi mật khẩu tài khoản" FontSize="18" FontWeight="ExtraBold" Foreground="#0F172A"/>
                                    <TextBlock Text="Nên thay đổi mật khẩu định kỳ để nâng cao bảo mật tài khoản" FontSize="12" Foreground="#94A3B8" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel Margin="32" MaxWidth="600" HorizontalAlignment="Left">
                            <TextBlock Text="MẬT KHẨU HIỆN TẠI" Style="{StaticResource ProFieldLabel}"/>
                            <PasswordBox x:Name="PwdCurrent" Style="{StaticResource PwdModern}" Margin="0,0,0,24" Width="400" HorizontalAlignment="Left"/>

                            <TextBlock Text="MẬT KHẨU MỚI" Style="{StaticResource ProFieldLabel}"/>
                            <PasswordBox x:Name="PwdNew" Style="{StaticResource PwdModern}" Margin="0,0,0,24" Width="400" HorizontalAlignment="Left"/>

                            <TextBlock Text="XÁC NHẬN MẬT KHẨU MỚI" Style="{StaticResource ProFieldLabel}"/>
                            <PasswordBox x:Name="PwdConfirm" Style="{StaticResource PwdModern}" Margin="0,0,0,32" Width="400" HorizontalAlignment="Left"/>

                            <StackPanel Orientation="Horizontal">
                                <Button Content="Đổi mật khẩu tài khoản" Background="#2563EB" Foreground="White" FontWeight="Bold" FontSize="14" Height="48" Padding="24,0" BorderThickness="0" Cursor="Hand" Click="BtnChangePwd_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <TextBlock x:Name="TxtPwdMsg" VerticalAlignment="Center" FontSize="13" Margin="16,0,0,0" Foreground="#10B981" FontWeight="SemiBold" Visibility="Collapsed"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
