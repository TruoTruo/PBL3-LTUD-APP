<Application x:Class="StudentReminderApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:StudentReminderApp.Converters"
             StartupUri="Views/Auth/LoginWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Colors.xaml"/>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:BoolToBgConverter     x:Key="BoolToBgConverter"/>
            <conv:BoolToFgConverter     x:Key="BoolToFgConverter"/>
            <conv:BoolToStatusConverter x:Key="BoolToStatusConverter"/>
            <conv:BoolToActionConverter x:Key="BoolToActionConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
